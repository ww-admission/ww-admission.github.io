# ============================================================
# WWA — Variables d'environnement de production
# À copier en .env.production sur www-admission, valeurs réelles
# injectées par Komodo (ou manuellement) — NE JAMAIS committer
# le fichier .env.production rempli dans Git.
# ============================================================

# ---------- Registre Harbor ----------
# IP Tailscale de ndewo. Le pull de www-admission vers Harbor
# transite par le tunnel Tailscale, jamais sur internet public.
HARBOR_REGISTRY=100.98.227.73

# Projet Harbor cible. "wwa_dev" pour le déploiement courant (dev/staging),
# "www_prod" le jour où une vraie prod séparée sera nécessaire — voir
# discussion : on garde un seul docker-compose.yml tant qu'aucune
# divergence réelle de configuration entre les deux n'est identifiée.
HARBOR_PROJECT=wwa_dev

# Tag d'image à déployer (ex: sha du commit, ou "latest" pour la dernière
# build sur develop). Géré par la CI/CD à terme.
IMAGE_TAG=latest

# ---------- Application Laravel ----------
# Générer avec : php artisan key:generate --show
# (à faire une seule fois, puis réutiliser la même clé à chaque déploiement —
# changer cette clé invalide tous les cookies de session et données chiffrées)
APP_KEY=

# URL publique réelle du site (sans slash final)
PUBLIC_SITE_URL=https://worldwise-admission.com

# ---------- Laravel Reverb (WebSocket) ----------
# Générer 3 valeurs aléatoires distinctes, ex: openssl rand -hex 16
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Domaine/sous-domaine public que SafeLine routera vers le service "reverb".
# Pas encore défini (à renseigner à l'étape 7 quand le routage SafeLine
# pour le WebSocket sera mis en place). Exemple possible : ws.worldwise-admission.com
PUBLIC_REVERB_HOST=
PUBLIC_REVERB_PORT=443
PUBLIC_REVERB_SCHEME=https

# ============================================================
# Notes de déploiement
# ============================================================
#
# Volumes bind mount attendus sur www-admission AVANT le premier
# démarrage du compose (les créer manuellement si absents) :
#   mkdir -p /data/wwa/database /data/wwa/storage
#   touch /data/wwa/database/database.sqlite
#
# Migrations à exécuter après le premier déploiement (et à chaque
# changement de schéma) :
#   docker exec wwa-api php artisan migrate --force
#
# Toutes les variables ci-dessus doivent être non vides avant de lancer
# "docker compose up -d" — APP_KEY et REVERB_* vides feront planter
# les containers au démarrage.
