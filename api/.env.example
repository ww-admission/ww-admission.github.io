APP_NAME=WWA-API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:4321

# Compte Super Admin (valeurs réelles dans .env uniquement)
SUPER_ADMIN_EMAIL=info@worldwise-admission.com
SUPER_ADMIN_PASSWORD=your-secure-password-here

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# En production : reverb | En local sans Reverb : log
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# database = jobs stockés en SQLite/MySQL, traités par queue:work
# redis    = Redis (Phase 2 multi-instances, activer REVERB_SCALING_ENABLED aussi)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Reverb WebSocket ────────────────────────────────────────────────────────
REVERB_APP_ID=your-app-id
REVERB_APP_KEY=your-app-key
REVERB_APP_SECRET=your-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Origines autorisées pour la connexion WebSocket — séparer par virgule
# JAMAIS '*' en production → Cross-Site WebSocket Hijacking
REVERB_ALLOWED_ORIGINS=http://localhost:4321

# Rate limiting (60 événements / 60 s par connexion)
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

# Scaling multi-instances (Phase 2 → activer + configurer Redis)
# REVERB_SCALING_ENABLED=false

# ── Variables côté Astro (frontend) ────────────────────────────────────────
# PUBLIC_REVERB_APP_KEY=your-app-key
# PUBLIC_REVERB_HOST=localhost
# PUBLIC_REVERB_PORT=8080
# PUBLIC_REVERB_SCHEME=http
