---
// Basic Contact Form
// ------------
// Description: A basic contact form with fields for first name, last name, email, phone number and message.
// Properties:
// - classes: Additional classes to be added to the block
// ------------

// Components
// - UI
import Card from '../../ui/cards/partials/Card.astro'
import CardBody from '../../ui/cards/partials/CardBody.astro'
import Form from '../../ui/forms/Form.astro'
import FormField from '../../ui/forms/partials/FormField.astro'
import InputField from '../../ui/forms/form-elements/InputField.astro'
import TextArea from '../../ui/forms/form-elements/TextArea.astro'
import Button from '../../ui/Button.astro'
import { Icon } from 'astro-icon/components'

// Props
type Props = {
	classes?: string
}
const { classes } = Astro.props
---

<Card classes={classes}>
	<CardBody>
		<Form id="contactForm">
			<h2 class="text-2xl">Nous contacter</h2>
			<FormField>
				<InputField type="text" id="firstName" label="Nom" />
				<InputField type="text" id="lastName" label="Prénom" />
			</FormField>
			<FormField>
				<InputField type="email" id="email" label="Adresse Email" required />
			</FormField>
			<FormField>
				<InputField type="tel" id="phone" label="Numéro de téléphone" />
			</FormField>
			<FormField><TextArea id="message" label="Votre Message" /></FormField>

			<FormField>
				<div class="relative w-full">
					<input
						type="file"
						id="attachment"
						name="attachment"
						accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
						class="peer absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0"
					/>
					<label
						for="attachment"
						class="flex cursor-pointer items-center gap-3 rounded border border-dashed border-neutral-200 px-4 py-3 transition-all hover:border-primary-400 peer-focus-visible:border-primary-500 dark:border-neutral-700 dark:bg-neutral-900 dark:hover:border-primary-600"
					>
						<Icon name="document-text" class="h-6 w-6 shrink-0 text-neutral-400 dark:text-neutral-500" aria-hidden="true" />
						<div class="flex flex-col gap-0.5">
							<span id="fileLabelMain" class="text-sm font-medium text-neutral-500 dark:text-neutral-400">
								Joindre un fichier
							</span>
							<span id="fileLabelSub" class="text-xs text-neutral-400 dark:text-neutral-500">
								PDF, DOC, DOCX, JPG, PNG — max 5 Mo
							</span>
						</div>
					</label>
				</div>
			</FormField>

			<Button style="primary" type="submit">Envoyer</Button>
		</Form>
	</CardBody>
</Card>

<div id="formStatus" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<div
	id="loadingOverlay"
	class="hidden fixed inset-0 z-50 flex items-center justify-center bg-white/70 backdrop-blur-sm dark:bg-neutral-900/70"
	role="status"
	aria-label="Envoi en cours"
>
	<div class="flex flex-col items-center gap-4 rounded border border-neutral-100 bg-white p-8 shadow-xl shadow-neutral-700/5 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-neutral-950/50">
		<svg
			class="h-10 w-10 animate-spin text-primary-500"
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			aria-hidden="true"
		>
			<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
			<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
		</svg>
		<p class="mb-0 text-sm font-medium text-neutral-700 dark:text-neutral-200">Envoi en cours…</p>
	</div>
</div>

<div
	id="successModal"
	class="hidden fixed inset-0 z-50 flex items-center justify-center bg-white/50 backdrop-blur-sm dark:bg-neutral-900/50"
	role="dialog"
	aria-modal="true"
	aria-labelledby="successModalTitle"
>
	<div class="m-6 flex w-96 max-w-full flex-col overflow-hidden rounded border border-neutral-100 bg-white text-neutral-500 shadow-xl shadow-neutral-700/5 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:shadow-neutral-950/50">
		<div class="flex items-center justify-between gap-6 border-b border-neutral-100 px-6 py-2 dark:border-neutral-800">
			<h2 id="successModalTitle" class="mb-0 truncate text-lg font-medium text-neutral-700 dark:text-neutral-50">
				Demande envoyée !
			</h2>
			<button
				id="closeSuccessHeader"
				type="button"
				class="inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-neutral-500 transition-all hover:text-neutral-900 dark:text-neutral-200 dark:hover:text-white"
				aria-label="Fermer"
			>
				<Icon name="x-mark" class="h-5 w-5" aria-hidden="true" />
				<span class="sr-only">Fermer</span>
			</button>
		</div>
		<div class="flex flex-col items-center gap-4 p-6 text-center">
			<Icon name="check-circle" class="h-14 w-14 text-primary-500" aria-hidden="true" />
			<div>
				<h3 class="mb-2 text-base font-semibold text-neutral-700 dark:text-neutral-100">
					Votre demande a été envoyée avec succès !
				</h3>
				<p class="mb-0 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
					Merci pour votre message. Notre équipe vous contactera dans les plus brefs délais
					pour vous accompagner dans votre projet d'études à l'étranger.
				</p>
			</div>
			<div class="flex w-full flex-col gap-3 pt-2">
				<button
					id="closeSuccessBtn"
					type="button"
					class="inline-flex h-10 w-full cursor-pointer items-center justify-center gap-2 rounded bg-primary-500 px-5 text-sm font-bold tracking-wide text-white outline-none transition-all hover:bg-primary-700 focus:bg-primary-700"
				>
					Fermer
				</button>
				<a
					href="/"
					class="inline-flex h-10 w-full cursor-pointer items-center justify-center gap-2 rounded border border-primary-500 px-5 text-sm font-bold tracking-wide text-primary-500 outline-none transition-all hover:border-primary-700 hover:text-primary-700 focus:border-primary-700 focus:text-primary-700 dark:border-primary-400 dark:text-primary-400 dark:hover:border-primary-300 dark:hover:text-primary-300"
				>
					Revenir à l'accueil
				</a>
			</div>
		</div>
	</div>
</div>

<div
	id="errorModal"
	class="hidden fixed inset-0 z-50 flex items-center justify-center bg-white/50 backdrop-blur-sm dark:bg-neutral-900/50"
	role="dialog"
	aria-modal="true"
	aria-labelledby="errorModalTitle"
>
	<div class="m-6 flex w-96 max-w-full flex-col overflow-hidden rounded border border-neutral-100 bg-white text-neutral-500 shadow-xl shadow-neutral-700/5 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:shadow-neutral-950/50">
		<div class="flex items-center justify-between gap-6 border-b border-neutral-100 px-6 py-2 dark:border-neutral-800">
			<h2 id="errorModalTitle" class="mb-0 truncate text-lg font-medium text-neutral-700 dark:text-neutral-50">
				Une erreur est survenue
			</h2>
			<button
				id="closeErrorHeader"
				type="button"
				class="inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-neutral-500 transition-all hover:text-neutral-900 dark:text-neutral-200 dark:hover:text-white"
				aria-label="Fermer"
			>
				<Icon name="x-mark" class="h-5 w-5" aria-hidden="true" />
				<span class="sr-only">Fermer</span>
			</button>
		</div>
		<div class="flex flex-col items-center gap-4 p-6 text-center">
			<Icon name="bell-alert" class="h-12 w-12 text-red-500 dark:text-red-400" aria-hidden="true" />
			<p class="mb-0 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
				L'envoi de votre message a échoué. Veuillez vérifier votre connexion et réessayer,
				ou contactez-nous directement.
			</p>
			<button
				id="closeErrorBtn"
				type="button"
				class="inline-flex h-10 w-full cursor-pointer items-center justify-center gap-2 rounded bg-primary-500 px-5 text-sm font-bold tracking-wide text-white outline-none transition-all hover:bg-primary-700 focus:bg-primary-700"
			>
				Réessayer
			</button>
		</div>
	</div>
</div>

<script>
	// ============================================================
	// CONFIGURATION EMAILJS
	// Obtenez vos IDs sur https://www.emailjs.com
	// Templates HTML dans src/emails/
	// ============================================================
	const EMAILJS_SERVICE_ID = 'service_q8qwzak'
	const EMAILJS_TEMPLATE_CONFIRMATION = 'template_oa8l1qg'
	// EMAILJS_TEMPLATE_NOTIFICATION = 'template_185swgh'
	// Désactivé : FormBold envoie déjà la notification à l'équipe WWA.
	// Conserver cet ID pour quand on remplacera FormBold par une solution
	// supportant les pièces jointes (ex. Laravel + Resend).
	const EMAILJS_PUBLIC_KEY = 'cjpR8h9jpq_o2xDhu'

	const sendEmail = async (templateId: string, params: Record<string, string>) => {
		const res = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				service_id: EMAILJS_SERVICE_ID,
				template_id: templateId,
				user_id: EMAILJS_PUBLIC_KEY,
				template_params: params,
			}),
		})
		if (!res.ok) throw new Error(`EmailJS ${res.status}`)
	}

	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('contactForm') as HTMLFormElement | null
		if (!form) return

		const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]')
		const loadingOverlay = document.getElementById('loadingOverlay')
		const successModal = document.getElementById('successModal')
		const errorModal = document.getElementById('errorModal')
		const formStatus = document.getElementById('formStatus')
		const fileInput = form.querySelector<HTMLInputElement>('#attachment')
		const fileLabelMain = document.getElementById('fileLabelMain')
		const fileLabelSub = document.getElementById('fileLabelSub')

		if (!submitBtn || !loadingOverlay || !successModal || !errorModal) return

		fileInput?.addEventListener('change', () => {
			const file = fileInput.files?.[0]
			if (!file) return

			if (file.size > 5 * 1024 * 1024) {
				fileInput.value = ''
				if (fileLabelMain) {
					fileLabelMain.textContent = 'Fichier trop volumineux (max 5 Mo)'
					fileLabelMain.classList.add('text-red-500')
					fileLabelMain.classList.remove('text-neutral-500')
				}
				if (fileLabelSub) fileLabelSub.textContent = 'Veuillez choisir un fichier plus léger'
				return
			}

			if (fileLabelMain) {
				fileLabelMain.textContent = file.name
				fileLabelMain.classList.add('text-primary-600', 'dark:text-primary-400')
				fileLabelMain.classList.remove('text-neutral-500', 'text-red-500')
			}
			if (fileLabelSub) fileLabelSub.textContent = `${(file.size / 1024).toFixed(0)} Ko`
		})

		const show = (el: HTMLElement) => el.classList.remove('hidden')
		const hide = (el: HTMLElement) => el.classList.add('hidden')

		const closeSuccess = () => {
			hide(successModal)
			form.reset()
			if (fileLabelMain) fileLabelMain.textContent = 'Joindre un fichier'
			if (fileLabelSub) fileLabelSub.textContent = 'PDF, DOC, DOCX, JPG, PNG — max 5 Mo'
			if (fileLabelMain) {
				fileLabelMain.classList.remove('text-primary-600', 'dark:text-primary-400', 'text-red-500')
				fileLabelMain.classList.add('text-neutral-500')
			}
			submitBtn.focus()
		}

		const closeError = () => {
			hide(errorModal)
			submitBtn.focus()
		}

		document.addEventListener('keydown', (e: KeyboardEvent) => {
			if (e.key !== 'Escape') return
			if (!successModal.classList.contains('hidden')) closeSuccess()
			else if (!errorModal.classList.contains('hidden')) closeError()
		})

		successModal.addEventListener('click', (e) => {
			if (e.target === successModal) closeSuccess()
		})
		errorModal.addEventListener('click', (e) => {
			if (e.target === errorModal) closeError()
		})

		document.getElementById('closeSuccessBtn')?.addEventListener('click', closeSuccess)
		document.getElementById('closeSuccessHeader')?.addEventListener('click', closeSuccess)
		document.getElementById('closeErrorBtn')?.addEventListener('click', closeError)
		document.getElementById('closeErrorHeader')?.addEventListener('click', closeError)

		const trapFocus = (modal: HTMLElement) => {
			modal.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key !== 'Tab') return
				const focusables = modal.querySelectorAll<HTMLElement>(
					'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
				)
				if (focusables.length === 0) return
				const first = focusables[0]
				const last = focusables[focusables.length - 1]
				if (e.shiftKey) {
					if (document.activeElement === first) { last.focus(); e.preventDefault() }
				} else {
					if (document.activeElement === last) { first.focus(); e.preventDefault() }
				}
			})
		}
		trapFocus(successModal)
		trapFocus(errorModal)

		form.addEventListener('submit', async (e: Event) => {
			e.preventDefault()

			submitBtn.disabled = true
			form.setAttribute('aria-busy', 'true')
			show(loadingOverlay)
			if (formStatus) formStatus.textContent = 'Envoi en cours…'

			const data = new FormData(form)
			const firstName = (data.get('firstName') as string) || ''
			const lastName = (data.get('lastName') as string) || ''
			const fullName = `${firstName} ${lastName}`.trim()
			const email = (data.get('email') as string) || ''

			try {
				const response = await fetch('https://formbold.com/s/9E4Xb', {
					method: 'POST',
					body: data,
				})

				if (!response.ok) throw new Error(`FormBold HTTP ${response.status}`)

				hide(loadingOverlay)
				show(successModal)
				if (formStatus) formStatus.textContent = 'Votre demande a été envoyée avec succès !'
				successModal.querySelector<HTMLElement>('button')?.focus()

				// Confirmation à l'utilisateur uniquement.
				// La notification WWA est gérée par FormBold.
				if (email) {
					sendEmail(EMAILJS_TEMPLATE_CONFIRMATION, {
						to_name: fullName || email,
						email:   email,
					})
				}
			} catch {
				hide(loadingOverlay)
				show(errorModal)
				if (formStatus) formStatus.textContent = "Une erreur est survenue lors de l'envoi."
				errorModal.querySelector<HTMLElement>('button')?.focus()
			} finally {
				submitBtn.disabled = false
				form.setAttribute('aria-busy', 'false')
			}
		})
	})
</script>
