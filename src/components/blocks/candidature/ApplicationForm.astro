<script>
  import { PROGRAMMES } from '../../../config/programs.config'
  import { ETABLISSEMENTS_GABON, VALIDATION, RELEVÉS_PAR_NIVEAU } from '../../../config/candidature.config'

  // ── EmailJS — confirmation candidat ──────────────────────
  const EMAILJS_SERVICE_ID  = 'service_q8qwzak'
  const EMAILJS_PUBLIC_KEY  = 'cjpR8h9jpq_o2xDhu'
  const EMAILJS_TEMPLATE_CANDIDATURE = 'template_185swgh'

  async function sendConfirmationEmail(params: Record<string, string>) {
    try {
      await fetch('https://api.emailjs.com/api/v1.0/email/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          service_id:  EMAILJS_SERVICE_ID,
          template_id: EMAILJS_TEMPLATE_CANDIDATURE,
          user_id:     EMAILJS_PUBLIC_KEY,
          template_params: params,
        }),
      })
    } catch { /* fire-and-forget — l'échec de l'email ne bloque pas la soumission */ }
  }

  // ── Constantes ────────────────────────────────────────────
  const PANEL_LABELS: Record<number, string> = {
    1: 'Personnel',
    2: 'Académique',
    3: 'Programme',
    4: 'Complémentaire',
    5: 'Documents',
    6: 'Récapitulatif',
  }

  const STORAGE_KEY           = 'wwa_candidature_v2'
  const STORAGE_KEY_SUBMITTED = 'wwa_candidature_result'
  const SUGGESTION_ITEM_CLASS = 'cursor-pointer px-4 py-2.5 text-sm text-neutral-700 transition-colors hover:bg-neutral-50 dark:text-neutral-200 dark:hover:bg-neutral-800'

  let currentPanel = 1
  let saveDebounce: ReturnType<typeof setTimeout>

  // ── Séquence d'étapes dynamique ────────────────────────────
  function getStepSeq(): number[] {
    const dest = document.querySelector<HTMLInputElement>('input[name="destination"]:checked')?.value
    if (!dest || dest === 'chine') return [1, 2, 3, 4, 5, 6]
    return [1, 2, 3, 5, 6]
  }

  // ── XSS guard ──────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  // ── Marquage d'erreur par champ ───────────────────────────
  function markErr(id: string) {
    const el = document.getElementById(id)
    if (el) { el.parentElement?.setAttribute('data-field-error', 'true'); return }
    document.querySelector(`[data-phone-input][data-id="${id}"]`)?.setAttribute('data-field-error', 'true')
    document.querySelector(`[data-multiselect][data-id="${id}"]`)?.setAttribute('data-field-error', 'true')
  }

  function markRadioErr(groupName: string) {
    document.querySelector(`fieldset[data-radio-group="${groupName}"]`)?.setAttribute('data-field-error', 'true')
  }

  // ── Reset vers panneau 1 (sans réenregistrer les listeners) ──
  function resetFormToPanel1(submittedView?: HTMLElement | null) {
    submittedView?.classList.add('hidden')
    document.getElementById('formContent')?.classList.remove('hidden')
    document.querySelectorAll<HTMLElement>('[data-step-panel]').forEach((el) => el.classList.add('hidden'))
    currentPanel = 0
    ;(document.getElementById('applicationForm') as HTMLFormElement)?.reset()
    document.querySelector('[data-multiselect-tags]')?.replaceChildren()
    document.querySelector('[data-multiselect-hidden-inputs]')?.replaceChildren()
    document.getElementById('draftIndicator')?.classList.add('hidden')
    document.getElementById('dejaChineDetails')?.classList.add('hidden')
    document.getElementById('specialiteAutreWrapper')?.classList.add('hidden')
    document.getElementById('sourceFinancementAutreWrapper')?.classList.add('hidden')
    clearErrors()
    goToPanel(1)
  }

  // ── Initialisation ────────────────────────────────────────
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('applicationForm') as HTMLFormElement | null
    if (!form) return

    // Vérifier si une candidature a déjà été soumise avant d'initialiser le formulaire
    if (checkSubmittedState()) return

    restoreFromLocal()
    renderStepIndicator()
    initNavigation()
    initAutoSave()
    initAddressAutocomplete()
    initEtablissementAutocomplete()
    initProgrammeConditional()
    initSpecialiteConditional()
    initDestinationChange()
    initDejaChineConditional()
    initSourceFinancementConditional()
    initEmailValidation()
    initGeolocation()
    initPassportExpiryCheck()
    initCountryDropdown()
    initReset()
  })

  // ── Réinitialisation depuis le dashboard (wwa:form-reset) ─────
  // Déclenché par startFresh()/startPrefill() pour corriger la race condition
  // entre checkSubmittedState() (sync) et migrateResult() (async).
  document.addEventListener('wwa:form-reset', () => {
    const form = document.getElementById('applicationForm') as HTMLFormElement | null
    if (!form) return
    const submittedView = document.getElementById('submittedView')
    resetFormToPanel1(submittedView)
    // Générer une nouvelle référence d'idempotence pour le prochain dossier
    delete (window as any).__wwa_form_ref__
    if (localStorage.getItem('wwa_candidature_v2')) {
      restoreFromLocal()
    }
  })

  // ── Navigation ────────────────────────────────────────────
  function initNavigation() {
    const btnNext   = document.getElementById('btnNext')!
    const btnPrev   = document.getElementById('btnPrev')!
    const form      = document.getElementById('applicationForm') as HTMLFormElement

    btnNext.addEventListener('click', () => {
      const errors = validateCurrentPanel()
      if (errors.length) { showErrors(errors); return }
      clearErrors()
      saveToLocal()
      const seq = getStepSeq()
      const idx = seq.indexOf(currentPanel)
      if (idx < seq.length - 1) goToPanel(seq[idx + 1])
    })

    btnPrev.addEventListener('click', () => {
      clearErrors()
      const seq = getStepSeq()
      const idx = seq.indexOf(currentPanel)
      if (idx > 0) goToPanel(seq[idx - 1])
    })

    form.addEventListener('submit', handleSubmit)

    document.getElementById('appCloseSuccessBtn')?.addEventListener('click', () =>
      document.getElementById('appSuccessModal')?.classList.add('hidden'))
    document.getElementById('appCloseErrorBtn')?.addEventListener('click', () =>
      document.getElementById('appErrorModal')?.classList.add('hidden'))
    document.getElementById('appRetryBtn')?.addEventListener('click', () =>
      document.getElementById('appErrorModal')?.classList.add('hidden'))

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Escape') return
      document.getElementById('appSuccessModal')?.classList.add('hidden')
      document.getElementById('appErrorModal')?.classList.add('hidden')
    })
  }

  // Scroll the real scroll container to top (works in both dashboard <main> and standalone page)
  function scrollToTop(anchor: Element | null) {
    let el: Element | null = anchor?.parentElement ?? null
    while (el && el !== document.documentElement) {
      const oy = getComputedStyle(el as HTMLElement).overflowY
      if (oy === 'auto' || oy === 'scroll') {
        ;(el as HTMLElement).scrollTo({ top: 0, behavior: 'smooth' })
        return
      }
      el = el.parentElement
    }
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  function goToPanel(panelNum: number) {
    document.querySelector(`[data-step-panel="${currentPanel}"]`)?.classList.add('hidden')
    currentPanel = panelNum
    document.querySelector(`[data-step-panel="${currentPanel}"]`)?.classList.remove('hidden')

    const seq    = getStepSeq()
    const idx    = seq.indexOf(currentPanel)
    const isLast = idx === seq.length - 1

    document.getElementById('btnPrev')!.classList.toggle('hidden', idx === 0)
    document.getElementById('btnNext')!.classList.toggle('hidden', isLast)
    document.getElementById('btnSubmit')!.classList.toggle('hidden', !isLast)

    // Panel-specific side effects
    if (currentPanel === 5) renderDynamicDocs()
    if (isLast) renderReview()

    renderStepIndicator()
    updateDestinationDependentUI()
    scrollToTop(document.getElementById('applicationForm'))

    const statusEl = document.getElementById('formStatus')
    if (statusEl) statusEl.textContent = `Étape ${idx + 1} sur ${seq.length}`
  }

  // ── Indicateur d'étapes ───────────────────────────────────
  function renderStepIndicator() {
    const container = document.getElementById('stepIndicatorDynamic')
    if (!container) return

    const seq    = getStepSeq()
    const panIdx = seq.indexOf(currentPanel)

    container.innerHTML = `
      <div class="flex items-start justify-between w-full" role="list" aria-label="Progression du formulaire">
        ${seq.map((panelNum, i) => {
          const label  = PANEL_LABELS[panelNum]
          const done   = i < panIdx
          const active = i === panIdx

          const lineColor   = (done || active) ? 'bg-primary-500' : 'bg-neutral-200 dark:bg-neutral-700'
          const circleColor = done
            ? 'border-primary-500 bg-primary-500 text-white'
            : active
              ? 'border-primary-500 text-primary-500 bg-white dark:bg-neutral-900'
              : 'border-neutral-200 text-neutral-400 bg-white dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-500'
          const labelColor  = active
            ? 'text-primary-500 font-semibold'
            : done
              ? 'text-neutral-500 dark:text-neutral-400'
              : 'text-neutral-300 dark:text-neutral-600'

          return `
            <div class="relative flex flex-1 flex-col items-center gap-2" role="listitem" ${active ? 'aria-current="step"' : ''}>
              ${i > 0 ? `<div class="absolute top-4 right-1/2 h-px w-full -translate-y-1/2 ${lineColor}" aria-hidden="true"></div>` : ''}
              <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full border-2 text-sm font-semibold transition-all duration-300 ${circleColor}">
                ${done
                  ? `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
                  : i + 1}
              </div>
              <span class="hidden text-center text-xs sm:block ${labelColor}">${escapeHtml(label)}</span>
            </div>
          `
        }).join('')}
      </div>
    `
  }

  // ── Validation par panneau ────────────────────────────────
  function validateCurrentPanel(): string[] {
    clearErrors()
    const errors: string[] = []
    const get = (id: string) => (document.getElementById(id) as HTMLInputElement | null)?.value.trim() ?? ''

    if (currentPanel === 1) {
      if (!get('nom'))            { errors.push('Le nom est requis.');                 markErr('nom') }
      if (!get('prenom'))         { errors.push('Le prénom est requis.');              markErr('prenom') }
      if (!get('dateNaissance'))  { errors.push('La date de naissance est requise.');  markErr('dateNaissance') }
      if (!get('lieuNaissance'))  { errors.push('Le lieu de naissance est requis.');   markErr('lieuNaissance') }

      const natInputs = document.querySelectorAll('input[name^="nationalites"]')
      if (!natInputs.length)      { errors.push('Au moins une nationalité est requise.'); markErr('nationalites') }

      const sexeVal = document.querySelector<HTMLInputElement>('input[name="sexe"]:checked')?.value
      if (!sexeVal)               { errors.push('Le sexe est requis.'); markRadioErr('sexe') }

      if (!get('situationMatrimoniale')) { errors.push('La situation matrimoniale est requise.'); markErr('situationMatrimoniale') }
      if (!get('numPasseport'))   { errors.push('Le numéro de passeport est requis.'); markErr('numPasseport') }
      if (!get('dateExpirationPasseport')) { errors.push("La date d'expiration du passeport est requise."); markErr('dateExpirationPasseport') }

      const phoneVal = document.querySelector<HTMLInputElement>('[data-phone-number]')?.value.trim() ?? ''
      if (!phoneVal) {
        errors.push('Le numéro de téléphone est requis.')
        document.querySelector('[data-phone-input]')?.setAttribute('data-field-error', 'true')
      }

      const email = get('email')
      if (!email)                                                    { errors.push("L'adresse email est requise.");  markErr('email') }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email))       { errors.push("Format d'email invalide.");      markErr('email') }
    }

    if (currentPanel === 2) {
      if (!get('niveauEtude'))    { errors.push("Le niveau d'étude est requis.");      markErr('niveauEtude') }
      if (!get('etablissement'))  { errors.push("L'établissement est requis.");         markErr('etablissement') }
      const spe = get('specialite')
      if (!spe)                   { errors.push('La spécialité est requise.');          markErr('specialite') }
      if (spe === 'autre' && !get('specialiteAutre')) {
        errors.push('Précisez votre spécialité.')
        markErr('specialiteAutre')
      }
      const moyRaw = get('moyenne')
      const moy = parseFloat(moyRaw)
      if (!moyRaw)                           { errors.push('La moyenne générale est requise.');           markErr('moyenne') }
      else if (isNaN(moy) || moy < 0 || moy > 20) { errors.push('La moyenne doit être entre 0 et 20.'); markErr('moyenne') }
    }

    if (currentPanel === 3) {
      const dest = document.querySelector<HTMLInputElement>('input[name="destination"]:checked')?.value
      if (!dest) {
        errors.push('Veuillez sélectionner une destination.')
        document.getElementById('destinationErrorMsg')?.classList.remove('hidden')
      } else {
        document.getElementById('destinationErrorMsg')?.classList.add('hidden')
      }
      if (!get('niveauVise'))  { errors.push('Le niveau visé est requis.');         markErr('niveauVise') }
      if (!get('programme'))   { errors.push('Le programme souhaité est requis.');  markErr('programme') }
      if (!get('faculte'))     { errors.push('La faculté est requise.');            markErr('faculte') }
    }

    if (currentPanel === 4) {
      if (!get('contactNom'))         { errors.push("Le nom du contact d'urgence est requis."); markErr('contactNom') }
      if (!get('contactLienParente')) { errors.push('Le lien de parenté est requis.');          markErr('contactLienParente') }
      if (!get('contactTel'))         { errors.push('Le téléphone du contact est requis.');     markErr('contactTel') }
      if (!get('contactEmail'))       { errors.push("L'email du contact est requis.");          markErr('contactEmail') }

      const dejaChine = document.querySelector<HTMLInputElement>('input[name="dejaChine"]:checked')?.value
      if (!dejaChine) { errors.push("Indiquez si vous avez déjà étudié en Chine."); markRadioErr('dejaChine') }

      if (!get('sourceFinancement')) { errors.push('La source de financement est requise.'); markErr('sourceFinancement') }
    }

    if (currentPanel === 5) {
      const required = ['diplome', 'piece_identite', 'photo_identite']
      const docLabels: Record<string, string> = {
        diplome: 'la copie du diplôme',
        piece_identite: "la pièce d'identité",
        photo_identite: "la photo d'identité",
      }
      required.forEach((docId) => {
        const input = document.getElementById(`file-${docId}`) as HTMLInputElement | null
        if (!input?.files?.length) errors.push(`Veuillez joindre ${docLabels[docId]}.`)
      })

      // Validate dynamic relevés
      const relevéInputs = document.querySelectorAll<HTMLInputElement>('input[name^="releve_dyn_"]')
      relevéInputs.forEach((inp, i) => {
        if (!inp.files?.length) errors.push(`Veuillez joindre le relevé de notes ${i + 1}.`)
      })
    }

    return errors
  }

