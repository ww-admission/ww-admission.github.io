---
// Application Form — Formulaire de candidature multi-étapes (6 panneaux)
// Soumission via FormBold. Persistance localStorage avec auto-sauvegarde.

import Card from '../../ui/cards/partials/Card.astro'
import CardBody from '../../ui/cards/partials/CardBody.astro'
import FormField from '../../ui/forms/partials/FormField.astro'
import InputField from '../../ui/forms/form-elements/InputField.astro'
import SelectField from '../../ui/forms/form-elements/SelectField.astro'
import MultiSelect from '../../ui/forms/form-elements/MultiSelect.astro'
import PhoneInput from '../../ui/forms/form-elements/PhoneInput.astro'
import FileUpload from '../../ui/forms/form-elements/FileUpload.astro'
import { Icon } from 'astro-icon/components'

import {
  NIVEAUX_ETUDE,
  SPECIALITES,
  DOCUMENTS_REQUIS,
  DESTINATIONS,
  SEXES,
  SITUATIONS_MATRIMONIALES,
  SOURCES_FINANCEMENT,
  LIENS_PARENTE,
} from '../../../config/candidature.config'
import { getProgrammesByDomain } from '../../../config/programs.config'

const niveauxOptions     = NIVEAUX_ETUDE.map((n) => ({ value: n.value, label: n.label }))
const niveauxViseOptions = niveauxOptions.slice(3)

const specialitesGrouped = [
  ...SPECIALITES.map((cat) => ({
    group: cat.category,
    options: cat.items.map((item) => ({ value: item, label: item })),
  })),
  { group: 'Autre', options: [{ value: 'autre', label: 'Autre (préciser)' }] },
]

const programmesByDomain = getProgrammesByDomain()
const programmesGrouped  = Object.entries(programmesByDomain).map(([domain, progs]) => ({
  group: domain,
  options: progs.map((p) => ({ value: p.value, label: p.label })),
}))

const situationsOptions = SITUATIONS_MATRIMONIALES.map((s) => ({ value: s.value, label: s.label }))
const sourcesOptions    = SOURCES_FINANCEMENT.map((s) => ({ value: s.value, label: s.label }))
const liensOptions      = LIENS_PARENTE.map((l) => ({ value: l.value, label: l.label }))
const staticDocs        = DOCUMENTS_REQUIS.filter((d) => d.id !== 'releve_notes')

const todayStr = new Date().toISOString().split('T')[0]

type Props = { classes?: string; successHref?: string }
const { classes, successHref = '/' } = Astro.props

const inputClass       = 'peer relative h-12 w-full rounded border border-neutral-200 bg-transparent px-4 text-sm text-neutral-500 placeholder-transparent outline-none transition-all focus:border-amber-400 focus:outline-none focus-visible:outline-none disabled:cursor-not-allowed disabled:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400'
const labelClass       = 'absolute -top-2 left-2 z-[1] cursor-text px-2 text-xs text-neutral-400 transition-all before:absolute before:left-0 before:top-0 before:z-[-1] before:block before:h-full before:w-full before:bg-white before:transition-all peer-placeholder-shown:top-3 peer-placeholder-shown:text-sm peer-focus:-top-2 peer-focus:cursor-default peer-focus:text-xs peer-focus:text-amber-500 peer-required:after:text-neutral-400 peer-required:after:content-[\'\\00a0*\'] peer-disabled:text-neutral-300 peer-disabled:before:bg-transparent dark:before:bg-neutral-900'
const selectLabelClass = 'absolute -top-2 left-2 z-[1] cursor-default px-2 text-xs text-neutral-400 transition-colors before:absolute before:left-0 before:top-0 before:z-[-1] before:block before:h-full before:w-full before:bg-white before:transition-all peer-focus:text-amber-500 peer-required:after:text-neutral-400 peer-required:after:content-[\'\\00a0*\'] dark:before:bg-neutral-900'
const selectFieldClass = 'peer relative h-12 w-full rounded border border-neutral-200 bg-transparent px-4 pr-10 text-sm text-neutral-500 outline-none transition-all focus:border-amber-400 focus:outline-none disabled:cursor-not-allowed disabled:bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 cursor-pointer appearance-none'
---

<div class={classes}>
  <Card>
    <CardBody>

      <!-- ════════════════════════════════════════
           VUE : CANDIDATURE DÉJÀ SOUMISE
           Affichée si localStorage contient une candidature envoyée.
           ════════════════════════════════════════ -->
      <div id="submittedView" class="hidden">

        <!-- En-tête -->
        <div class="mb-8 flex items-center gap-4 border-b border-neutral-100 pb-6 dark:border-neutral-800">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary-100 dark:bg-primary-950/50">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <h2 class="mb-0 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Candidature envoyée</h2>
            <p id="submittedDate" class="mt-0.5 text-sm text-neutral-400"></p>
          </div>
        </div>

        <!-- Grille 2 colonnes -->
        <div class="grid gap-8 lg:grid-cols-2">

          <!-- ── Colonne gauche : Récapitulatif ── -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Votre dossier</h3>
            <div id="submittedRecap" class="flex flex-col gap-px overflow-hidden rounded border border-neutral-100 dark:border-neutral-800"></div>
          </div>

          <!-- ── Colonne droite : Suivi ── -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Suivi de traitement</h3>

            <!-- Timeline de statut -->
            <div class="relative flex flex-col gap-0">

              <!-- Ligne verticale de connexion -->
              <div class="absolute left-4 top-8 h-[calc(100%-2rem)] w-px bg-neutral-100 dark:bg-neutral-800" aria-hidden="true"></div>

              <!-- Étape 1 : Envoyée ✅ -->
              <div class="relative flex items-start gap-4 pb-6">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border-2 border-green-500 bg-green-500 text-white z-10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="pt-1">
                  <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Candidature envoyée</p>
                  <p class="text-xs text-neutral-400">Votre dossier a bien été reçu par l'équipe WWA.</p>
                </div>
              </div>

              <!-- Étape 2 : En cours ⏳ -->
              <div class="relative flex items-start gap-4 pb-6">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border-2 border-amber-400 bg-amber-50 dark:bg-amber-950/30 z-10">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="pt-1">
                  <p class="text-sm font-semibold text-amber-600 dark:text-amber-400">En cours de traitement</p>
                  <p class="text-xs text-neutral-400">L'équipe examine votre dossier et vos documents.</p>
                </div>
              </div>

              <!-- Étape 3 : Réponse ○ -->
              <div class="relative flex items-start gap-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border-2 border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900 z-10">
                  <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-600"></div>
                </div>
                <div class="pt-1">
                  <p class="text-sm font-semibold text-neutral-400 dark:text-neutral-500">Réponse de l'équipe WWA</p>
                  <p class="text-xs text-neutral-400">Vous serez contacté(e) à l'adresse email renseignée.</p>
                </div>
              </div>

            </div><!-- /timeline -->

            <!-- Message d'information -->
            <div class="mt-6 rounded border border-neutral-100 bg-neutral-50 p-4 dark:border-neutral-800 dark:bg-neutral-900/50">
              <p class="mb-2 text-sm font-semibold text-neutral-600 dark:text-neutral-300">Rappel important</p>
              <p class="mb-0 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
                N'oubliez pas d'envoyer vos <strong>pièces jointes</strong> (diplôme, relevé de notes, pièce d'identité, photo) par email à
                <a href="mailto:info@worldwise-admission.com" class="font-medium text-primary-500 hover:underline">info@worldwise-admission.com</a>
                en indiquant votre nom et prénom dans l'objet.
              </p>
            </div>

            <!-- Bouton réinitialiser -->
            <button
              id="btnNewCandidature"
              type="button"
              class="mt-6 text-xs text-neutral-300 transition-colors hover:text-red-400 dark:text-neutral-600 dark:hover:text-red-500"
            >
              Soumettre une nouvelle candidature
            </button>

          </div><!-- /colonne droite -->
        </div><!-- /grille -->
      </div><!-- /#submittedView -->


      <!-- ════════════════════════════════════════
           VUE : FORMULAIRE
           ════════════════════════════════════════ -->
      <div id="formContent">

      <!-- Indicateur de progression -->
      <div id="stepIndicatorDynamic" class="mb-6" aria-label="Progression du formulaire"></div>

      <form id="applicationForm" novalidate>

        <!-- ════════════════════════════════════════
             PANEL 1 — Informations personnelles
             ════════════════════════════════════════ -->
        <div data-step-panel="1">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Informations personnelles</h2>
            <p class="mb-0 text-sm text-neutral-400">Les champs marqués d'un <span class="font-medium text-neutral-500">*</span> sont obligatoires.</p>
          </div>

          <FormField>
            <InputField type="text" id="nom"    label="Nom"    required />
            <InputField type="text" id="prenom" label="Prénom" required />
          </FormField>

          <FormField>
            <div class="relative w-full">
              <input type="date" id="dateNaissance" name="dateNaissance" required
                class={inputClass}
                max={todayStr}
              />
              <label for="dateNaissance" class={selectLabelClass}>Date de naissance <span class="text-neutral-400" aria-hidden="true">&nbsp;*</span></label>
            </div>
            <InputField type="text" id="lieuNaissance" label="Lieu de naissance" required />
          </FormField>

          <FormField>
            <MultiSelect id="nationalites" label="Nationalité(s)" placeholder="Rechercher un pays…" required />
          </FormField>

          <FormField>
            <!-- Sexe -->
            <div class="relative w-full">
              <fieldset class="rounded border border-neutral-200 px-4 pb-3.5 pt-2 transition-colors dark:border-neutral-800" data-radio-group="sexe">
                <legend class="px-1 text-xs text-neutral-400">Sexe <span aria-hidden="true">*</span></legend>
                <div class="mt-1.5 flex gap-6">
                  {SEXES.map((s) => (
                    <label class="flex cursor-pointer items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                      <input type="radio" name="sexe" value={s.value} class="h-4 w-4 accent-[#E2187D]" />
                      {s.label}
                    </label>
                  ))}
                </div>
              </fieldset>
            </div>
            <!-- Situation matrimoniale -->
            <SelectField id="situationMatrimoniale" label="Situation matrimoniale" options={situationsOptions} required />
          </FormField>

          <FormField>
            <InputField type="text" id="numPasseport" label="Numéro de passeport" required />
            <div class="relative w-full">
              <input type="date" id="dateExpirationPasseport" name="dateExpirationPasseport" required
                class={inputClass}
                min={todayStr}
              />
              <label for="dateExpirationPasseport" class={selectLabelClass}>Expiration du passeport <span class="text-neutral-400" aria-hidden="true">&nbsp;*</span></label>
              <p id="passportExpiryWarning" class="hidden mt-1 px-1 text-xs"></p>
            </div>
          </FormField>

          <!-- Adresse + géoloc -->
          <FormField>
            <div class="relative w-full" data-address-wrapper>
              <InputField type="text" id="adresse" label="Adresse" />
              <div
                class="absolute left-0 top-full z-50 mt-0.5 hidden w-full overflow-y-auto rounded border border-neutral-100 bg-white shadow-lg dark:border-neutral-800 dark:bg-neutral-900"
                style="max-height:12rem"
                data-address-suggestions
              ></div>
            </div>
            <button
              type="button"
              id="geolocBtn"
              class="flex h-12 flex-shrink-0 cursor-pointer items-center gap-2 rounded border border-neutral-200 bg-neutral-50 px-4 text-sm text-neutral-500 transition-all hover:border-primary-400 hover:text-primary-500 disabled:cursor-wait dark:border-neutral-800 dark:bg-neutral-800 dark:text-neutral-400"
              aria-label="Utiliser ma position"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <span id="geolocBtnText" class="whitespace-nowrap">Ma position</span>
            </button>
          </FormField>

          <FormField>
            <InputField type="text" id="ville" label="Ville" />
            <div class="relative w-full">
              <select id="pays" name="pays" class={selectFieldClass} data-pays-select>
                <option value="">Sélectionner…</option>
              </select>
              <label for="pays" class={selectLabelClass}>Pays</label>
              <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </div>
          </FormField>

          <FormField>
            <PhoneInput id="telephone" label="Téléphone" required />
          </FormField>

          <FormField>
            <div class="relative w-full">
              <InputField type="email" id="email" label="Adresse email" required />
              <span id="emailStatus" class="absolute right-3 top-3 text-base leading-none" aria-live="polite"></span>
            </div>
          </FormField>
        </div><!-- /panel 1 -->


        <!-- ════════════════════════════════════════
             PANEL 2 — Informations académiques
             ════════════════════════════════════════ -->
        <div data-step-panel="2" class="hidden">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Informations académiques</h2>
            <p class="mb-0 text-sm text-neutral-400">Les champs marqués d'un <span class="font-medium text-neutral-500">*</span> sont obligatoires.</p>
          </div>

          <FormField>
            <SelectField id="niveauEtude" label="Niveau d'étude actuel" options={niveauxOptions} required />
          </FormField>

          <FormField>
            <div class="relative w-full" data-etablissement-wrapper>
              <InputField type="text" id="etablissement" label="Établissement fréquenté" required />
              <div
                class="absolute left-0 top-full z-50 mt-0.5 hidden w-full overflow-y-auto rounded border border-neutral-100 bg-white shadow-lg dark:border-neutral-800 dark:bg-neutral-900"
                style="max-height:12rem"
                data-etablissement-suggestions
              ></div>
            </div>
          </FormField>

          <FormField>
            <SelectField id="specialite" label="Spécialité / filière" options={specialitesGrouped} required />
          </FormField>

          <div id="specialiteAutreWrapper" class="hidden">
            <FormField>
              <InputField type="text" id="specialiteAutre" label="Précisez votre spécialité" />
            </FormField>
          </div>

          <FormField>
            <div class="relative w-full">
              <input
                type="number" id="moyenne" name="moyenne"
                required min="0" max="20" step="0.01"
                placeholder="Moyenne générale"
                class={inputClass}
              />
              <label for="moyenne" class={labelClass}>
                Moyenne générale
                <span class="font-normal text-neutral-300">&nbsp;/ 20</span>
              </label>
              <small class="absolute flex w-full px-4 py-1 text-xs text-neutral-400"><span>Entre 0 et 20</span></small>
            </div>
          </FormField>
        </div><!-- /panel 2 -->


        <!-- ════════════════════════════════════════
             PANEL 3 — Destination & Programme
             ════════════════════════════════════════ -->
        <div data-step-panel="3" class="hidden">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Destination &amp; Programme</h2>
            <p class="mb-0 text-sm text-neutral-400">Les champs marqués d'un <span class="font-medium text-neutral-500">*</span> sont obligatoires.</p>
          </div>

          <!-- Destination picker -->
          <div class="mb-6">
            <p class="mb-3 text-sm font-medium text-neutral-600 dark:text-neutral-300">Destination souhaitée <span class="text-neutral-400" aria-hidden="true">*</span></p>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-4" id="destinationPicker">
              {DESTINATIONS.map((dest) => {
                const cardClass = dest.available
                  ? 'relative flex flex-col items-center gap-2 rounded border border-neutral-200 p-4 text-center transition-all cursor-pointer hover:border-amber-300 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 dark:border-neutral-700 dark:hover:border-amber-700 dark:has-[:checked]:border-primary-500 dark:has-[:checked]:bg-primary-950/20'
                  : 'relative flex flex-col items-center gap-2 rounded border border-neutral-100 p-4 text-center cursor-not-allowed select-none opacity-50 dark:border-neutral-800'
                return (
                  <label class={cardClass}>
                    <input
                      type="radio"
                      name="destination"
                      value={dest.value}
                      class="sr-only"
                      disabled={!dest.available}
                      data-destination-radio
                    />
                    <span class="text-2xl leading-none">{dest.flag}</span>
                    <span class={dest.available ? 'text-sm font-medium text-neutral-700 dark:text-neutral-200' : 'text-sm font-medium text-neutral-400'}>
                      {dest.label}
                    </span>
                    {!dest.available && (
                      <span class="text-xs text-neutral-300 dark:text-neutral-600">Prochainement</span>
                    )}
                  </label>
                )
              })}
            </div>
            <p id="destinationErrorMsg" class="hidden mt-2 text-xs text-red-400">Veuillez sélectionner une destination.</p>
          </div>

          <FormField>
            <SelectField id="niveauVise" label="Niveau visé" options={niveauxViseOptions} required />
          </FormField>

          <FormField>
            <SelectField id="programme" label="Programme souhaité" options={programmesGrouped} required />
          </FormField>

          <FormField>
            <div class="relative w-full">
              <select id="faculte" name="faculte" required disabled class={selectFieldClass} data-faculte-select>
                <option value="">Choisissez d'abord un programme…</option>
              </select>
              <label for="faculte" class={selectLabelClass}>Faculté <span class="text-neutral-400" aria-hidden="true">&nbsp;*</span></label>
              <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </div>
          </FormField>
        </div><!-- /panel 3 -->


        <!-- ════════════════════════════════════════
             PANEL 4 — Infos complémentaires (Chine)
             ════════════════════════════════════════ -->
        <div data-step-panel="4" class="hidden">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Informations complémentaires</h2>
            <p class="mb-0 text-sm text-neutral-400">Ces informations sont spécifiques à votre candidature en Chine.</p>
          </div>

          <!-- Contact d'urgence -->
          <div class="mb-6">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Contact d'urgence</h3>

            <FormField>
              <InputField type="text" id="contactNom" label="Nom et prénom du contact" required />
              <SelectField id="contactLienParente" label="Lien de parenté" options={liensOptions} required />
            </FormField>

            <FormField>
              <div class="relative w-full">
                <input
                  type="tel" id="contactTel" name="contactTel" required
                  placeholder="Téléphone du contact"
                  class={inputClass}
                />
                <label for="contactTel" class={labelClass}>Téléphone du contact</label>
                <small class="absolute flex w-full px-4 py-1 text-xs text-neutral-400"><span>Avec indicatif — ex: +241 07 12 34 56</span></small>
              </div>
              <InputField type="email" id="contactEmail" label="Email du contact" required />
            </FormField>

            <FormField>
              <InputField type="text" id="contactAdresse" label="Adresse du contact" />
            </FormField>
          </div>

          <!-- Expérience en Chine -->
          <div class="mb-6">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Expérience en Chine</h3>

            <FormField>
              <div class="relative w-full">
                <fieldset class="rounded border border-neutral-200 px-4 pb-3.5 pt-2 transition-colors dark:border-neutral-800" data-radio-group="dejaChine">
                  <legend class="px-1 text-xs text-neutral-400">Avez-vous déjà étudié en Chine ? <span aria-hidden="true">*</span></legend>
                  <div class="mt-1.5 flex gap-6">
                    <label class="flex cursor-pointer items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                      <input type="radio" name="dejaChine" value="non" class="h-4 w-4 accent-[#E2187D]" data-deja-chine />
                      Non
                    </label>
                    <label class="flex cursor-pointer items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                      <input type="radio" name="dejaChine" value="oui" class="h-4 w-4 accent-[#E2187D]" data-deja-chine />
                      Oui
                    </label>
                  </div>
                </fieldset>
              </div>
            </FormField>

            <div id="dejaChineDetails" class="hidden">
              <FormField>
                <InputField type="text" id="dejaChineEtablissement" label="Établissement en Chine" />
                <InputField type="text" id="dejaChineAnnees" label="Période d'études (ex : 2019–2021)" />
              </FormField>
            </div>
          </div>

          <!-- Source de financement -->
          <div class="mb-6">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Financement</h3>
            <FormField>
              <SelectField id="sourceFinancement" label="Source de financement" options={sourcesOptions} required />
            </FormField>
            <div id="sourceFinancementAutreWrapper" class="hidden">
              <FormField>
                <InputField type="text" id="sourceFinancementAutre" label="Précisez la source de financement" />
              </FormField>
            </div>
          </div>
        </div><!-- /panel 4 -->


        <!-- ════════════════════════════════════════
             PANEL 5 — Documents
             ════════════════════════════════════════ -->
        <div data-step-panel="5" class="hidden">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Documents à joindre</h2>
            <p class="mb-0 text-sm text-neutral-400">Les documents <span class="font-medium text-neutral-500">*</span> sont obligatoires. Formats acceptés : PDF, JPG, PNG (5 Mo max).</p>
          </div>

          <!-- Relevés de notes dynamiques (selon niveau visé) -->
          <div class="mb-6">
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Relevés de notes</h3>
            <div id="relevesContainer" class="flex flex-col gap-3">
              <p class="text-sm text-neutral-400 italic">Sélectionnez un niveau visé (étape 3) pour voir les relevés requis.</p>
            </div>
          </div>

          <!-- Documents statiques -->
          <div class="mb-6">
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Documents d'identité &amp; diplôme</h3>
            <div class="flex flex-col gap-4">
              {staticDocs.map((doc) => (
                <FileUpload
                  id={doc.id}
