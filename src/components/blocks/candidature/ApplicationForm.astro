            </div>
          </div>

          <!-- Formulaire de candidature Chine (conditionnel) -->
          <div id="formulaireChineSection" class="hidden mb-6">
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Formulaire de candidature universitaire</h3>
            <div class="rounded border border-amber-200 bg-amber-50 p-4 dark:border-amber-900/50 dark:bg-amber-950/20">
              <p class="mb-3 text-sm text-amber-800 dark:text-amber-300">
                Téléchargez le formulaire de candidature universitaire, remplissez-le, puis joignez-le ci-dessous.
              </p>
              <a
                href="#"
                id="formulaireChineDownload"
