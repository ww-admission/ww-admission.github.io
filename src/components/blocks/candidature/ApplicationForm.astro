  function initEtablissementAutocomplete() {
    const input    = document.getElementById('etablissement') as HTMLInputElement | null
    const suggestEl = document.querySelector<HTMLElement>('[data-etablissement-suggestions]')
    if (!input || !suggestEl) return

    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase()
      if (q.length < 2) { suggestEl.classList.add('hidden'); return }
      const matches = ETABLISSEMENTS_GABON.filter((e) => e.toLowerCase().includes(q)).slice(0, 8)
      if (!matches.length) { suggestEl.classList.add('hidden'); return }

      suggestEl.innerHTML = matches.map((e) =>
        `<div class="${SUGGESTION_ITEM_CLASS}" tabindex="0" role="option">${escapeHtml(e)}</div>`
      ).join('')
      suggestEl.querySelectorAll('[role="option"]').forEach((item) => {
        item.addEventListener('mousedown', (e) => {
          e.preventDefault()
          input.value = (item as HTMLElement).textContent || ''
          suggestEl.classList.add('hidden')
