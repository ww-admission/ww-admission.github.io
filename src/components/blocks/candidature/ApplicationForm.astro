  // ── localStorage ──────────────────────────────────────────
  function saveToLocal() {
    const fieldIds = [
      'nom','prenom','dateNaissance','lieuNaissance',
      'situationMatrimoniale','numPasseport','dateExpirationPasseport',
      'adresse','ville','email',
      'niveauEtude','etablissement','specialite','specialiteAutre','moyenne',
      'niveauVise','programme',
      'contactNom','contactLienParente','contactTel','contactEmail','contactAdresse',
      'dejaChineEtablissement','dejaChineAnnees',
      'sourceFinancement','sourceFinancementAutre',
    ]
    const data: Record<string, string> = { currentPanel: String(currentPanel) }

    fieldIds.forEach((id) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null
      if (el) data[id] = el.value
    })

    // Special fields
    const faculteEl = document.querySelector<HTMLSelectElement>('[data-faculte-select]')
    if (faculteEl) data['faculte'] = faculteEl.value
    const paysEl = document.querySelector<HTMLSelectElement>('[data-pays-select]')
    if (paysEl) data['pays'] = paysEl.value

    const phoneEl    = document.querySelector<HTMLInputElement>('[data-phone-number]')
    const indicatifEl = document.querySelector<HTMLInputElement>('[data-phone-hidden-code]')
    if (phoneEl)     data['telephone'] = phoneEl.value
    if (indicatifEl) data['indicatif'] = indicatifEl.value

    // Radios
    const sexeChecked = document.querySelector<HTMLInputElement>('input[name="sexe"]:checked')
    if (sexeChecked) data['sexe'] = sexeChecked.value
    const destChecked = document.querySelector<HTMLInputElement>('input[name="destination"]:checked')
    if (destChecked) data['destination'] = destChecked.value
    const dejaChecked = document.querySelector<HTMLInputElement>('input[name="dejaChine"]:checked')
    if (dejaChecked) data['dejaChine'] = dejaChecked.value

    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)) } catch { /* quota */ }
  }

  function restoreFromLocal() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return
      const data = JSON.parse(raw) as Record<string, string>

      const skipKeys = new Set(['currentPanel', 'pays', 'faculte', 'telephone', 'indicatif',
                                'sexe', 'destination', 'dejaChine'])

      Object.entries(data).forEach(([id, value]) => {
        if (skipKeys.has(id)) return
        const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null
        if (el) el.value = value
      })

      // Phone
      if (data['telephone']) {
        const el = document.querySelector<HTMLInputElement>('[data-phone-number]')
        if (el) el.value = data['telephone']
      }
      if (data['indicatif']) {
        const el = document.querySelector<HTMLInputElement>('[data-phone-hidden-code]')
        if (el) {
          el.value = data['indicatif']
          const codeText = document.querySelector<HTMLElement>('[data-phone-code]')
          if (codeText) codeText.textContent = data['indicatif']
        }
      }

      // Radios
      if (data['sexe']) {
        const el = document.querySelector<HTMLInputElement>(`input[name="sexe"][value="${data['sexe']}"]`)
        if (el) el.checked = true
      }
      if (data['destination']) {
        const el = document.querySelector<HTMLInputElement>(`input[name="destination"][value="${data['destination']}"]`)
        if (el) el.checked = true
      }
      if (data['dejaChine']) {
        const el = document.querySelector<HTMLInputElement>(`input[name="dejaChine"][value="${data['dejaChine']}"]`)
        if (el) { el.checked = true }
        if (data['dejaChine'] === 'oui') document.getElementById('dejaChineDetails')?.classList.remove('hidden')
      }

      // Conditionals
      if (data['specialite'] === 'autre') {
        document.getElementById('specialiteAutreWrapper')?.classList.remove('hidden')
        const autreInput = document.getElementById('specialiteAutre') as HTMLInputElement | null
        if (autreInput) autreInput.required = true
      }
      if (data['sourceFinancement'] === 'autre') {
        document.getElementById('sourceFinancementAutreWrapper')?.classList.remove('hidden')
      }

      // Programme → trigger faculte population, then restore
      const progEl = document.getElementById('programme') as HTMLSelectElement | null
      if (progEl?.value) {
        progEl.dispatchEvent(new Event('change'))
        if (data['faculte']) {
          setTimeout(() => {
            const facEl = document.querySelector<HTMLSelectElement>('[data-faculte-select]')
            if (facEl) facEl.value = data['faculte']
          }, 50)
        }
      }

      const panel = parseInt(data['currentPanel'] || '1', 10)
      if (panel > 1) goToPanel(panel)
    } catch { /* corrupt data */ }
  }

