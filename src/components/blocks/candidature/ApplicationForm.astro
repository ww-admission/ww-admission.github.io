<!-- Error modal -->
<div id="appErrorModal" class="fixed inset-0 z-50 hidden bg-white/50 backdrop-blur-sm dark:bg-neutral-900/50" role="dialog" aria-modal="true" aria-labelledby="appErrorTitle">
  <div class="flex h-full items-center justify-center">
