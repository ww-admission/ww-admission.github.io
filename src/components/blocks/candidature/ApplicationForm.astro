                download
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Télécharger le formulaire (Word)
              </a>
            </div>
            <div class="mt-4">
              <FileUpload
                id="formulaire_chine"
                label="Formulaire complété et signé"
                description="Formulaire de candidature rempli"
                accept=".pdf,.doc,.docx"
                maxMo={10}
                required={false}
              />
            </div>
          </div>
        </div><!-- /panel 5 -->


        <!-- ════════════════════════════════════════
             PANEL 6 — Récapitulatif
             ════════════════════════════════════════ -->
        <div data-step-panel="6" class="hidden">
          <div class="-mx-6 mb-8 border-y border-neutral-100 bg-neutral-50 px-6 py-5 dark:border-neutral-800 dark:bg-neutral-900/50">
            <h2 class="mb-1 text-xl font-semibold text-neutral-700 dark:text-neutral-100">Récapitulatif</h2>
            <p class="mb-0 text-sm text-neutral-400">Vérifiez vos informations avant d'envoyer votre candidature.</p>
          </div>

          <div id="reviewContent" class="flex flex-col gap-4"></div>

          <!-- Confirmations -->
          <div class="mt-6 flex flex-col gap-3 border-t border-neutral-100 pt-6 dark:border-neutral-800">
            <label class="flex cursor-pointer items-start gap-3">
              <input type="checkbox" id="certifExact" name="certifExact" class="mt-0.5 h-4 w-4 flex-shrink-0 accent-[#E2187D]" />
              <span class="text-sm text-neutral-600 dark:text-neutral-400">
                Je certifie que toutes les informations fournies dans ce formulaire sont exactes et complètes.
              </span>
            </label>
            <label class="flex cursor-pointer items-start gap-3">
              <input type="checkbox" id="certifCGU" name="certifCGU" class="mt-0.5 h-4 w-4 flex-shrink-0 accent-[#E2187D]" />
              <span class="text-sm text-neutral-600 dark:text-neutral-400">
                J'accepte les conditions générales de WorldWise Admission et autorise le traitement de mes données personnelles dans le cadre de ma candidature.
              </span>
            </label>
          </div>
        </div><!-- /panel 6 -->


        <!-- Navigation -->
        <div class="mt-10 flex items-center gap-4 border-t border-neutral-100 pt-6 dark:border-neutral-800">
          <button type="button" id="btnPrev"
            class="hidden inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded border border-neutral-300 px-5 text-sm font-bold tracking-wide text-neutral-600 outline-none transition-all hover:border-neutral-500 hover:text-neutral-800 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-neutral-500">
            ← Précédent
          </button>
          <button type="button" id="btnReset"
            class="text-xs text-neutral-300 transition-colors hover:text-red-400 dark:text-neutral-600 dark:hover:text-red-500">
            Réinitialiser
          </button>
          <div class="flex flex-1 justify-end gap-3">
            <button type="button" id="btnNext"
              class="inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded bg-primary-500 px-5 text-sm font-bold tracking-wide text-white outline-none transition-all hover:bg-primary-700">
              Suivant →
            </button>
            <button type="submit" id="btnSubmit"
              class="hidden inline-flex h-10 cursor-pointer items-center justify-center gap-2 rounded bg-primary-500 px-5 text-sm font-bold tracking-wide text-white outline-none transition-all hover:bg-primary-700">
              Envoyer ma candidature
            </button>
          </div>
        </div>

        <!-- Indicateur de sauvegarde automatique -->
        <div id="draftIndicator" class="mt-3 hidden text-right text-xs text-neutral-400"></div>

        <!-- Erreurs de validation -->
        <div id="stepErrors" class="mt-4 hidden rounded border border-red-200 bg-red-50 px-4 py-3 dark:border-red-900/50 dark:bg-red-950/30" role="alert" aria-live="polite">
          <p class="mb-1 text-sm font-semibold text-red-600 dark:text-red-400">Veuillez corriger :</p>
          <ul id="stepErrorList" class="list-inside list-disc text-sm text-red-500 dark:text-red-400"></ul>
        </div>

      </form>
      </div><!-- /#formContent -->
    </CardBody>
  </Card>
</div>

<div id="formStatus" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<!-- Loading overlay -->
