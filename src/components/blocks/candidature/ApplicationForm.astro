  // ── Expiration passeport ──────────────────────────────────
  function initPassportExpiryCheck() {
    const input   = document.getElementById('dateExpirationPasseport') as HTMLInputElement | null
    const warning = document.getElementById('passportExpiryWarning')
    if (!input || !warning) return

    input.addEventListener('change', () => {
      const val = input.value
      if (!val) { warning.classList.add('hidden'); return }
      const expiry          = new Date(val)
      const today           = new Date()
      const sixMonthsFromNow = new Date()
      sixMonthsFromNow.setMonth(sixMonthsFromNow.getMonth() + 6)

      if (expiry < today) {
        warning.textContent = '⚠️ Votre passeport est expiré. Vous devez le renouveler avant de candidater.'
        warning.className   = 'mt-1 px-1 text-xs text-red-500 dark:text-red-400'
        warning.classList.remove('hidden')
      } else if (expiry < sixMonthsFromNow) {
        warning.textContent = '⚠️ Attention : votre passeport expire dans moins de 6 mois. Vérifiez qu\'il sera valide pendant toute la durée des études.'
        warning.className   = 'mt-1 px-1 text-xs text-amber-600 dark:text-amber-400'
        warning.classList.remove('hidden')
      } else {
        warning.classList.add('hidden')
      }
    })
  }

  // ── Validation email ──────────────────────────────────────
  function initEmailValidation() {
    const input  = document.getElementById('email') as HTMLInputElement | null
    const status = document.getElementById('emailStatus')
    if (!input || !status) return

    let debounce: ReturnType<typeof setTimeout>
    const emailReg = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/

    input.addEventListener('input', () => {
      clearTimeout(debounce)
      const val = input.value.trim()
      if (!val) { status.textContent = ''; return }
      if (!emailReg.test(val)) { status.textContent = '❌'; return }
      debounce = setTimeout(() => {
        const domain     = val.split('@')[1] || ''
        const suspicious = ['test','example','localhost','invalid'].some((t) => domain.includes(t))
        status.textContent = suspicious ? '⚠️' : '✅'
      }, 500)
    })
  }

