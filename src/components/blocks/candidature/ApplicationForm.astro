  // ── Autocomplete adresse (Nominatim) ──────────────────────
  function initAddressAutocomplete() {
    const input    = document.getElementById('adresse') as HTMLInputElement | null
    const suggestEl = document.querySelector<HTMLElement>('[data-address-suggestions]')
    if (!input || !suggestEl) return

    let debounce: ReturnType<typeof setTimeout>
    input.addEventListener('input', () => {
      clearTimeout(debounce)
      const q = input.value.trim()
      if (q.length < 3) { suggestEl.classList.add('hidden'); return }
      debounce = setTimeout(() => fetchAddressSuggestions(q, suggestEl, input), 350)
    })
    input.addEventListener('blur', () => setTimeout(() => suggestEl.classList.add('hidden'), 200))
  }

  async function fetchAddressSuggestions(q: string, container: HTMLElement, input: HTMLInputElement) {
    try {
      const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&addressdetails=1&limit=5&accept-language=fr`
      const res = await fetch(url)
      const results = (await res.json()) as any[]
      if (!results.length) { container.classList.add('hidden'); return }

      container.innerHTML = results.map((r) => {
        const city    = escapeHtml(r.address?.city || r.address?.town || r.address?.village || '')
        const country = escapeHtml(r.address?.country || '')
        const display = escapeHtml(r.display_name || '')
        return `<div class="${SUGGESTION_ITEM_CLASS}" tabindex="0" role="option"
              data-city="${city}" data-country="${country}" data-display="${display}">
          ${display}
        </div>`
      }).join('')

      container.querySelectorAll('[data-display]').forEach((item) => {
        item.addEventListener('mousedown', (e) => {
          e.preventDefault()
          const el = item as HTMLElement
          input.value = el.dataset.display || ''
          fillCityCountry(el.dataset.city || '', el.dataset.country || '')
          container.classList.add('hidden')
        })
      })
      container.classList.remove('hidden')
    } catch { container.classList.add('hidden') }
  }

  function fillCityCountry(city: string, country: string) {
    const villeEl = document.getElementById('ville') as HTMLInputElement | null
    if (villeEl && city) villeEl.value = city
    if (country) {
      const paysEl = document.querySelector<HTMLSelectElement>('[data-pays-select]')
      if (paysEl) {
        const opt = Array.from(paysEl.options).find((o) =>
          o.text.toLowerCase().includes(country.toLowerCase())
        )
        if (opt) paysEl.value = opt.value
      }
    }
  }

  // ── Géolocalisation ────────────────────────────────────────
  function initGeolocation() {
    const btn     = document.getElementById('geolocBtn') as HTMLButtonElement | null
    const btnText = document.getElementById('geolocBtnText')
    if (!btn || !btnText) return

    btn.addEventListener('click', () => {
      if (!navigator.geolocation) { btnText.textContent = 'Non disponible'; return }
      btnText.textContent = '…'
      btn.disabled = true

      navigator.geolocation.getCurrentPosition(
        async (pos) => {
          try {
            const { latitude: lat, longitude: lon } = pos.coords
            const res  = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&accept-language=fr`)
            const data = await res.json()
            const adresseEl = document.getElementById('adresse') as HTMLInputElement | null
            if (adresseEl) adresseEl.value = data.display_name || ''
            fillCityCountry(
              data.address?.city || data.address?.town || data.address?.village || '',
              data.address?.country || ''
            )
            btnText.textContent = '✓ Position'
          } catch { btnText.textContent = 'Erreur' }
          finally   { btn.disabled = false }
        },
        () => {
          btnText.textContent = 'Accès refusé'
          btn.disabled = false
          setTimeout(() => { btnText.textContent = 'Ma position' }, 3000)
        },
        { timeout: 10000 }
      )
    })
  }

  // ── Pays dropdown ─────────────────────────────────────────
  async function initCountryDropdown() {
    const select = document.querySelector<HTMLSelectElement>('[data-pays-select]')
    if (!select) return

    const savedPays = (() => {
      try { return (JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}') as Record<string, string>).pays } catch { return undefined }
    })()
    const targetValue = savedPays || 'GA'

    const populate = (pairs: [string, string][]) => {
      select.innerHTML = '<option value="">Sélectionner…</option>'
      pairs.forEach(([code, name]) => {
        const opt = document.createElement('option')
        opt.value = code; opt.textContent = name
        select.appendChild(opt)
      })
      select.value = targetValue
    }

    try {
      const res  = await fetch('https://restcountries.com/v3.1/all?fields=name,cca2,translations')
      const data = (await res.json()) as any[]
      const pairs = data
        .map((c): [string, string] => [c.cca2, c.translations?.fra?.common || c.name.common])
        .sort(([, a], [, b]) => a.localeCompare(b, 'fr'))
      populate(pairs)
    } catch {
      populate([
        ['GA','Gabon'],['FR','France'],['CM','Cameroun'],['CG','Congo'],['CD','RD Congo'],
        ['SN','Sénégal'],['CI',"Côte d'Ivoire"],['CN','Chine'],['NG','Nigéria'],['MA','Maroc'],
      ])
    }
  }

