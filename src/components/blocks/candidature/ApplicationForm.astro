    const dejaChineVal = document.querySelector<HTMLInputElement>('input[name="dejaChine"]:checked')?.value
    const dejaChineDisp = dejaChineVal === 'oui'
      ? `Oui — ${get('dejaChineEtablissement')} (${get('dejaChineAnnees')})`
      : dejaChineVal === 'non' ? 'Non' : '—'

    const sections = [
      {
        title: 'Informations personnelles',
        rows: [
          ['Nom', get('nom')],
          ['Prénom', get('prenom')],
          ['Date de naissance', get('dateNaissance')],
          ['Lieu de naissance', get('lieuNaissance')],
          ['Nationalité(s)', natInputs],
          ['Sexe', escapeHtml(sexeLabels[sexeVal] || sexeVal || '—')],
          ['Situation matrimoniale', getSel('#situationMatrimoniale')],
          ['N° passeport', get('numPasseport')],
          ['Expiration passeport', get('dateExpirationPasseport')],
          ['Adresse', get('adresse')],
          ['Ville', get('ville')],
          ['Pays', getSel('[data-pays-select]')],
          ['Téléphone', telephoneDisplay],
          ['Email', get('email')],
        ],
      },
      {
        title: 'Informations académiques',
        rows: [
          ["Niveau d'étude", getSel('#niveauEtude')],
          ['Établissement', get('etablissement')],
          ['Spécialité', specialiteDisp],
          ['Moyenne', moyenneDisp],
        ],
      },
      {
        title: 'Destination & Programme',
        rows: [
          ['Destination', escapeHtml(destLabels[destVal] || destVal || '—')],
          ['Niveau visé', getSel('#niveauVise')],
          ['Programme', getSel('#programme')],
          ['Faculté', getSel('[data-faculte-select]')],
        ],
      },
      ...(destVal === 'chine' ? [{
        title: 'Informations complémentaires',
        rows: [
          ['Contact urgence', `${get('contactNom')} (${getSel('#contactLienParente')})`],
          ['Tél. contact', get('contactTel')],
          ['Email contact', get('contactEmail')],
          ['Déjà étudié en Chine', escapeHtml(dejaChineDisp)],
          ['Source de financement', getSel('#sourceFinancement')],
        ],
      }] : []),
      {
        title: 'Documents',
        rows: [
          ...relevéInputs.map((inp, i) => {
            const fileName = inp.files?.[0] ? escapeHtml(inp.files[0].name) : '—'
            return [`Relevé ${i + 1}`, inp.files?.[0] ? `✅ ${fileName}` : '—']
          }),
          ...uniqueStaticDocIds.map((docId) => {
            const inp = document.getElementById(`file-${docId}`) as HTMLInputElement | null
            const fileName = inp?.files?.[0] ? escapeHtml(inp.files[0].name) : '—'
            return [staticDocLabels[docId] || docId, inp?.files?.[0] ? `✅ ${fileName}` : '—']
          }),
        ],
      },
    ]

    container.innerHTML = sections.map((section) => `
      <div class="overflow-hidden rounded border border-neutral-100 dark:border-neutral-800">
        <div class="border-b border-neutral-100 bg-neutral-50 px-4 py-2.5 dark:border-neutral-800 dark:bg-neutral-900">
          <h3 class="mb-0 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">${escapeHtml(section.title)}</h3>
        </div>
        <div class="divide-y divide-neutral-50 dark:divide-neutral-900">
          ${section.rows.map(([label, value]) => `
            <div class="flex items-baseline gap-4 px-4 py-2.5">
              <span class="w-40 flex-shrink-0 text-xs text-neutral-400">${escapeHtml(label as string)}</span>
              <span class="flex-1 text-sm text-neutral-700 dark:text-neutral-200">${value}</span>
            </div>
          `).join('')}
        </div>
      </div>
    `).join('')
  }

  // ── État "candidature déjà soumise" ──────────────────────

  function checkSubmittedState(): boolean {
    try {
      const raw = localStorage.getItem(STORAGE_KEY_SUBMITTED)
      if (!raw) return false
      const data = JSON.parse(raw) as Record<string, string>
      showSubmittedView(data)
      return true
    } catch { return false }
  }

  function showSubmittedView(data: Record<string, string>) {
    document.getElementById('formContent')?.classList.add('hidden')
    const view = document.getElementById('submittedView')
    if (!view) return
    view.classList.remove('hidden')

    // Date d'envoi
    if (data['submittedAt']) {
      const d = new Date(data['submittedAt'])
      const dateEl = document.getElementById('submittedDate')
      if (dateEl) dateEl.textContent = `Envoyée le ${d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })} à ${d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}`
    }

    // Récapitulatif
    renderSubmittedRecap(data)

    // Bouton nouvelle candidature
    document.getElementById('btnNewCandidature')?.addEventListener('click', () => {
      if (!confirm('Attention : cela effacera votre candidature enregistrée. Continuer ?')) return
      localStorage.removeItem(STORAGE_KEY_SUBMITTED)
      localStorage.removeItem(STORAGE_KEY)
      resetFormToPanel1(view)
    })
  }

  function renderSubmittedRecap(data: Record<string, string>) {
    const container = document.getElementById('submittedRecap')
    if (!container) return

    const destLabels: Record<string, string> = { chine: '🇨🇳 Chine', ghana: '🇬🇭 Ghana', russie: '🇷🇺 Russie', autre: '🌍 Autre' }
    const sexeLabels: Record<string, string> = { masculin: 'Masculin', feminin: 'Féminin' }

    const rows: [string, string][] = [
      ['Nom & Prénom',   `${data['prenom'] || ''} ${data['nom'] || ''}`.trim() || '—'],
      ['Email',          data['email'] || '—'],
      ['Téléphone',      data['telephone'] || '—'],
      ['Nationalité(s)', data['nationalites'] || '—'],
      ['Sexe',           sexeLabels[data['sexe'] || ''] || data['sexe'] || '—'],
      ['Niveau d\'étude', data['niveauEtude'] || '—'],
      ['Établissement',  data['etablissement'] || '—'],
      ['Spécialité',     data['specialite'] || '—'],
      ['Moyenne',        data['moyenne'] ? `${data['moyenne']} / 20` : '—'],
      ['Destination',    destLabels[data['destination'] || ''] || data['destination'] || '—'],
      ['Programme',      data['programme'] || '—'],
      ['Niveau visé',    data['niveauVise'] || '—'],
    ]
    if (data['sourceFinancement']) rows.push(['Financement', data['sourceFinancement']])

    container.innerHTML = rows.map(([label, value], i) => `
      <div class="flex items-baseline gap-3 px-4 py-2.5 ${i % 2 === 0 ? 'bg-white dark:bg-transparent' : 'bg-neutral-50 dark:bg-neutral-900/50'}">
        <span class="w-32 flex-shrink-0 text-xs text-neutral-400">${escapeHtml(label)}</span>
        <span class="flex-1 text-sm text-neutral-700 dark:text-neutral-200">${escapeHtml(value)}</span>
      </div>
    `).join('')
  }

  function saveSubmittedState(serverId?: number) {
    const getSel = (idOrSel: string) => {
      const el = (idOrSel.startsWith('[') || idOrSel.startsWith('.'))
        ? document.querySelector<HTMLSelectElement>(idOrSel)
        : document.getElementById(idOrSel) as HTMLSelectElement | null
      return el?.options[el?.selectedIndex ?? -1]?.text || el?.value || ''
    }
    const get = (id: string) => (document.getElementById(id) as HTMLInputElement | null)?.value || ''

    const phoneNum  = document.querySelector<HTMLInputElement>('[data-phone-number]')?.value || ''
    const indicatif = document.querySelector<HTMLInputElement>('[data-phone-hidden-code]')?.value || ''
    const natInputs = Array.from(document.querySelectorAll<HTMLInputElement>('input[name^="nationalites"]'))
      .map((i) => i.value).join(', ')

    const data: Record<string, unknown> = {
      submittedAt:       new Date().toISOString(),
      nom:               get('nom'),
      prenom:            get('prenom'),
      email:             get('email'),
      telephone:         `${indicatif} ${phoneNum}`.trim(),
      nationalites:      natInputs,
      sexe:              document.querySelector<HTMLInputElement>('input[name="sexe"]:checked')?.value || '',
      situationMatrimoniale: getSel('situationMatrimoniale'),
      niveauEtude:       getSel('niveauEtude'),
      etablissement:     get('etablissement'),
      specialite:        get('specialite') === 'autre' ? get('specialiteAutre') : getSel('specialite'),
      moyenne:           get('moyenne'),
      destination:       document.querySelector<HTMLInputElement>('input[name="destination"]:checked')?.value || '',
      niveauVise:        getSel('niveauVise'),
      programme:         getSel('programme'),
      faculte:           getSel('[data-faculte-select]') || '',
      sourceFinancement: getSel('sourceFinancement'),
    }
    // Stocker l'ID serveur pour que migrateResult() marque l'entrée comme déjà synchronisée
    if (serverId) {
      data._serverId = serverId
      data.synced    = true
    }
    try { localStorage.setItem(STORAGE_KEY_SUBMITTED, JSON.stringify(data)) } catch { /* quota */ }
  }

  // ── Soumission FormBold ───────────────────────────────────
  async function handleSubmit(e: Event) {
    e.preventDefault()

    // Check confirmation checkboxes
    const certif = (document.getElementById('certifExact') as HTMLInputElement | null)?.checked
    const cgu    = (document.getElementById('certifCGU')   as HTMLInputElement | null)?.checked
    if (!certif || !cgu) {
      showErrors(['Veuillez cocher les cases de confirmation avant de soumettre.'])
      return
    }

    const form          = e.target as HTMLFormElement
    const submitBtn     = document.getElementById('btnSubmit') as HTMLButtonElement
    const loadingOverlay = document.getElementById('appLoadingOverlay')!
    const successModal  = document.getElementById('appSuccessModal')!
    const errorModal    = document.getElementById('appErrorModal')!
    const statusEl      = document.getElementById('formStatus')

    submitBtn.disabled = true
    loadingOverlay.classList.remove('hidden')
    if (statusEl) statusEl.textContent = 'Envoi en cours…'

    try {
      // Build a text-only FormData — FormBold free tier ne supporte pas les fichiers.
      // Les pièces jointes seront transmises via le backend Laravel (à venir).
      const textData = new FormData()

      // Parcourt tous les champs du formulaire, ignore les fichiers
      new FormData(form).forEach((value, key) => {
        if (typeof value === 'string') textData.append(key, value)
      })

      // Champs radio (sélection unique — pas toujours inclus via FormData)
      const sexeChecked = document.querySelector<HTMLInputElement>('input[name="sexe"]:checked')
      if (sexeChecked) textData.set('sexe', sexeChecked.value)
      const destChecked = document.querySelector<HTMLInputElement>('input[name="destination"]:checked')
      if (destChecked) textData.set('destination', destChecked.value)
      const dejaChecked = document.querySelector<HTMLInputElement>('input[name="dejaChine"]:checked')
      if (dejaChecked) textData.set('deja_etudie_chine', dejaChecked.value)

      // Téléphone combiné (indicatif + numéro)
      const phoneNum  = document.querySelector<HTMLInputElement>('[data-phone-number]')?.value || ''
      const indicatif = document.querySelector<HTMLInputElement>('[data-phone-hidden-code]')?.value || ''
      textData.set('telephone_complet', `${indicatif} ${phoneNum}`.trim())

      // Noms des fichiers joints (pour info dans FormBold, sans le contenu)
      const fileInputs = form.querySelectorAll<HTMLInputElement>('input[type="file"]')
      const filesSummary = Array.from(fileInputs)
        .filter((inp) => inp.files?.length)
        .map((inp) => `${inp.name}: ${inp.files![0].name}`)
        .join(' | ')
      if (filesSummary) textData.set('fichiers_joints', filesSummary)

      const res = await fetch(VALIDATION.formboldEndpoint, { method: 'POST', body: textData })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)

      // Quand on est dans le dashboard : enregistrer la candidature + uploader les fichiers.
      let serverId: number | undefined
      if (window.location.pathname.startsWith('/dashboard')) {
        const fd = new FormData(form)
        const nationalites = Array.from(
          document.querySelectorAll<HTMLInputElement>('input[name^="nationalites"]')
        ).map((i) => i.value.trim()).filter(Boolean).join(', ')

        // UUID d'idempotence : généré une seule fois par session de formulaire
        // pour éviter les doublons en cas de double soumission ou retry
        const reference = (window as any).__wwa_form_ref__ ??
          (() => { const r = crypto.randomUUID(); (window as any).__wwa_form_ref__ = r; return r })()

        const apiPayload = {
          reference,
          destination:  destChecked?.value || (fd.get('destination') as string) || '',
          programme:    (fd.get('programme') as string) || '',
          niveau_vise:  (fd.get('niveauVise') as string) || '',
          personal_info: {
            nom:                   (fd.get('nom') as string) || '',
            prenom:                (fd.get('prenom') as string) || '',
            email:                 (fd.get('email') as string) || '',
            telephone:             `${indicatif} ${phoneNum}`.trim(),
            nationalites,
            sexe:                  sexeChecked?.value || '',
            dateNaissance:         (fd.get('dateNaissance') as string) || '',
            lieuNaissance:         (fd.get('lieuNaissance') as string) || '',
            situationMatrimoniale: (fd.get('situationMatrimoniale') as string) || '',
            numPasseport:          (fd.get('numPasseport') as string) || '',
            adresse:               (fd.get('adresse') as string) || '',
            ville:                 (fd.get('ville') as string) || '',
            pays:                  (fd.get('pays') as string) || '',
          },
          academic_info: {
            niveauEtude:    (fd.get('niveauEtude') as string) || '',
            etablissement:  (fd.get('etablissement') as string) || '',
            specialite:     (fd.get('specialite') as string) !== 'autre'
              ? (fd.get('specialite') as string) || ''
              : (fd.get('specialiteAutre') as string) || '',
            moyenne:        (fd.get('moyenne') as string) || '',
          },
          complementary_info: {
            sourceFinancement: (fd.get('sourceFinancement') as string) || '',
            dejaEtudieChine:   dejaChecked?.value || '',
            faculte:           (fd.get('faculte') as string) || '',
          },
        }

        // Créer la candidature (attendu — on a besoin de l'ID pour les pièces jointes)
        try {
          const candResp = await fetch('/api/candidatures', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(apiPayload),
          })
          if (candResp.ok) {
            const saved = await candResp.json()
            serverId = saved.id ?? undefined
          }
        } catch { /* serveur indisponible — syncUnsynced() retentera */ }

        // Uploader les pièces jointes (fichiers sélectionnés dans les inputs)
        if (serverId) {
          const fileInputs = form.querySelectorAll<HTMLInputElement>('input[type="file"]')
          const uploads = Array.from(fileInputs)
            .filter(inp => inp.files && inp.files.length > 0)
            .map(inp => {
              const afd = new FormData()
              afd.append('file',            inp.files![0])
              afd.append('attachable_type', 'candidature')
              afd.append('attachable_id',   String(serverId))
              afd.append('field_name',      inp.name || inp.id || '')
              return fetch('/api/attachments', { method: 'POST', body: afd }).catch(() => {})
            })
          await Promise.allSettled(uploads)
          // Réinitialiser la référence pour la prochaine candidature
          delete (window as any).__wwa_form_ref__
        }
      }

      saveSubmittedState(serverId)
      document.dispatchEvent(new CustomEvent('wwa:candidature-submitted'))
      localStorage.removeItem(STORAGE_KEY)

      loadingOverlay.classList.add('hidden')
      successModal.classList.remove('hidden')
      if (statusEl) statusEl.textContent = 'Candidature envoyée avec succès !'
      successModal.querySelector<HTMLElement>('a')?.focus()

      // Quand l'utilisateur ferme le modal, afficher la vue "déjà soumis"
      const switchToSubmittedView = () => {
        successModal.classList.add('hidden')
        const submitted = localStorage.getItem(STORAGE_KEY_SUBMITTED)
        if (submitted) {
          try { showSubmittedView(JSON.parse(submitted)) } catch {}
        }
      }
      document.getElementById('appCloseSuccessBtn')?.addEventListener('click', switchToSubmittedView, { once: true })
      successModal.addEventListener('click', (e) => {
        if (e.target === successModal) switchToSubmittedView()
      }, { once: true })

      // Email de confirmation au candidat (fire-and-forget)
      const nomVal    = (document.getElementById('nom')    as HTMLInputElement | null)?.value || ''
      const prenomVal = (document.getElementById('prenom') as HTMLInputElement | null)?.value || ''
      const emailVal  = (document.getElementById('email')  as HTMLInputElement | null)?.value || ''
      const progEl    = document.getElementById('programme')  as HTMLSelectElement | null
      const niveauEl  = document.getElementById('niveauVise') as HTMLSelectElement | null
      const destVal   = document.querySelector<HTMLInputElement>('input[name="destination"]:checked')?.value || ''
      const destLabels: Record<string, string> = { chine: 'Chine', ghana: 'Ghana', russie: 'Russie', autre: 'Autre destination' }
      sendConfirmationEmail({
        to_name:     `${prenomVal} ${nomVal}`.trim(),
        to_email:    emailVal,
        destination: destLabels[destVal] || destVal,
        programme:   progEl?.options[progEl.selectedIndex]?.text || '',
        niveau_vise: niveauEl?.options[niveauEl.selectedIndex]?.text || '',
      })
    } catch {
      loadingOverlay.classList.add('hidden')
      errorModal.classList.remove('hidden')
      if (statusEl) statusEl.textContent = 'Une erreur est survenue.'
    } finally {
      submitBtn.disabled = false
    }
  }
</script>

<style is:global>
  /*
   * Erreur par champ — appliquée par JS uniquement après une tentative de navigation.
   * Jamais affichée au chargement initial.
   */
  [data-field-error] > input:not([type="hidden"]):not([type="file"]),
  [data-field-error] > select {
    border-color: rgb(248 113 113) !important;
  }
  [data-field-error] > input:focus:not([type="hidden"]):not([type="file"]),
  [data-field-error] > select:focus {
    border-color: rgb(248 113 113) !important;
  }
  [data-field-error] > div:has([data-phone-number]) {
    border-color: rgb(248 113 113) !important;
  }
  [data-field-error] > [data-multiselect-field] {
    border-color: rgb(248 113 113) !important;
  }
  fieldset[data-field-error] {
    border-color: rgb(248 113 113) !important;
  }
</style>
