---
interface Attachment {
  id: number
  originalName: string
  mimeType: string
  humanSize: string
  fieldName?: string
  isImage: boolean
  createdAt: string
}
interface Props {
  attachments: Attachment[]
  canDelete?: boolean
  emptyLabel?: string
}
const { attachments, canDelete = false, emptyLabel = 'Aucune pièce jointe' } = Astro.props

function iconPath(mime: string): string {
  if (mime === 'application/pdf')   return 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z'
  if (mime.startsWith('image/'))    return 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z'
  return 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
}
function iconColor(mime: string): string {
  if (mime === 'application/pdf')   return 'text-red-400'
  if (mime.startsWith('image/'))    return 'text-blue-400'
  return 'text-neutral-400'
}
---

{attachments.length === 0 ? (
  <p class="text-xs text-neutral-400 italic py-2">{emptyLabel}</p>
) : (
  <ul class="space-y-2" data-attachment-list>
    {attachments.map(a => (
      <li
        class="flex items-center gap-3 rounded border border-neutral-100 bg-neutral-50 p-3 hover:bg-white transition-colors group dark:bg-neutral-800/60 dark:border-neutral-700 dark:hover:bg-neutral-800"
        data-attachment-id={a.id}
      >
        <!-- Icône -->
        <div class="h-8 w-8 rounded bg-white border border-neutral-100 flex items-center justify-center shrink-0 dark:bg-neutral-900 dark:border-neutral-700">
          <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 ${iconColor(a.mimeType)}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d={iconPath(a.mimeType)} />
          </svg>
        </div>

        <!-- Infos -->
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-neutral-700 dark:text-neutral-200 truncate">{a.originalName}</p>
          <p class="text-[10px] text-neutral-400 mt-0.5">
            {a.fieldName && <span class="capitalize mr-1.5">{a.fieldName}</span>}
            {a.humanSize}
          </p>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-1 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
          {(a.isImage || a.mimeType === 'application/pdf') && (
            <a
              href={`/api/attachments/${a.id}/preview`}
              target="_blank"
              rel="noopener"
              class="flex h-7 w-7 items-center justify-center rounded text-neutral-400 hover:bg-primary-50 hover:text-primary-500 transition-colors"
              title="Prévisualiser"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </a>
          )}
          <a
            href={`/api/attachments/${a.id}/download`}
            download
            class="flex h-7 w-7 items-center justify-center rounded text-neutral-400 hover:bg-primary-50 hover:text-primary-500 transition-colors"
            title="Télécharger"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
          </a>
          {canDelete && (
            <button
              class="attachment-delete flex h-7 w-7 items-center justify-center rounded text-neutral-400 hover:bg-red-50 hover:text-red-500 transition-colors"
              data-attachment-id={a.id}
              title="Supprimer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          )}
        </div>
      </li>
    ))}
  </ul>
)}

{canDelete && (
  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.attachment-delete').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('Supprimer ce fichier ?')) return
          const id   = (btn as HTMLElement).dataset.attachmentId
          const resp = await fetch(`/api/attachments/${id}`, { method: 'DELETE' })
          if (resp.ok) document.querySelector(`li[data-attachment-id="${id}"]`)?.remove()
        })
      })
    })
  </script>
)}
