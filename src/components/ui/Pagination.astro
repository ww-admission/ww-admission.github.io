---
/**
 * Pagination.astro - composant de pagination serveur-side
 *
 * Attendus :
 *   currentPage : numéro de la page affichée (1-indexed)
 *   lastPage    : dernier numéro de page
 *   total       : nombre total d'enregistrements
 *   perPage     : nombre de lignes par page actuellement sélectionné
 *   baseUrl     : URL courante (Astro.url) pour construire les liens avec searchParams
 *
 * Usage :
 *   <Pagination currentPage={page} lastPage={meta.last_page} total={meta.total}
 *               perPage={perPage} baseUrl={Astro.url} />
 */

type Props = {
  currentPage: number
  lastPage:    number
  total:       number
  perPage:     number
  baseUrl:     URL
}

const { currentPage, lastPage, total, perPage, baseUrl } = Astro.props

const PER_PAGE_OPTIONS = [30, 50, 100]

const from = total === 0 ? 0 : (currentPage - 1) * perPage + 1
const to   = Math.min(currentPage * perPage, total)

// Construit une URL en changeant un seul paramètre et en conservant les autres
function withParam(key: string, value: string): string {
  const u = new URL(baseUrl)
  u.searchParams.set(key, value)
  return u.pathname + u.search
}

function pageUrl(p: number): string  { return withParam('page', String(p)) }
function ppUrl(pp: number):  string  {
  const u = new URL(baseUrl)
  u.searchParams.set('per_page', String(pp))
  u.searchParams.set('page', '1')  // reset à page 1 quand on change la taille
  return u.pathname + u.search
}

// Algorithme "fenêtre glissante" pour les numéros de page
// Toujours afficher : première, dernière, et delta pages autour de la courante
// null = ellipsis (…)
function getPageNumbers(current: number, last: number, delta = 2): (number | null)[] {
  if (last <= 1) return []
  const range: (number | null)[] = []
  const left  = current - delta
  const right = current + delta

  let prev: number | null = null
  for (let i = 1; i <= last; i++) {
    if (i === 1 || i === last || (i >= left && i <= right)) {
      if (prev !== null && i - prev > 1) range.push(null)  // ellipsis
      range.push(i)
      prev = i
    }
  }
  return range
}

const pages = getPageNumbers(currentPage, lastPage)
const hasPrev = currentPage > 1
const hasNext = currentPage < lastPage
---

{lastPage > 0 && (
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between border-t border-neutral-100 pt-4 dark:border-neutral-800">

    <!-- Info + sélecteur de taille -->
    <div class="flex items-center gap-4 text-xs text-neutral-500 dark:text-neutral-400">
      <span>
        {total === 0
          ? 'Aucun résultat'
          : `${from} – ${to} sur ${total.toLocaleString('fr-FR')} résultat${total > 1 ? 's' : ''}`}
      </span>

      <!-- Lignes par page -->
      <div class="flex items-center gap-1.5">
        <span class="hidden sm:inline whitespace-nowrap">Lignes/page :</span>
        <div class="flex items-center rounded border border-neutral-200 overflow-hidden dark:border-neutral-700">
          {PER_PAGE_OPTIONS.map(pp => (
            <a
              href={ppUrl(pp)}
              class={[
                'px-2.5 py-1 text-xs font-semibold transition-colors',
                pp === perPage
                  ? 'bg-primary-500 text-white hover:text-white'
                  : 'bg-white text-neutral-500 hover:bg-neutral-50 hover:text-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800',
              ].join(' ')}
              aria-current={pp === perPage ? 'page' : undefined}
            >
              {pp}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Navigation pages -->
    {lastPage > 1 && (
      <nav aria-label="Pagination" class="flex items-center gap-1">

        <!-- Précédent -->
        {hasPrev ? (
          <a
            href={pageUrl(currentPage - 1)}
            class="inline-flex h-8 items-center gap-1 rounded border border-neutral-200 bg-white px-2.5 text-xs font-semibold text-neutral-600 transition hover:border-primary-300 hover:text-primary-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400"
            aria-label="Page précédente"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            <span class="hidden sm:inline">Précédent</span>
          </a>
        ) : (
          <span class="inline-flex h-8 items-center gap-1 rounded border border-neutral-100 bg-neutral-50 px-2.5 text-xs font-semibold text-neutral-300 cursor-not-allowed dark:border-neutral-800 dark:bg-neutral-900/50 dark:text-neutral-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            <span class="hidden sm:inline">Précédent</span>
          </span>
        )}

        <!-- Numéros de pages -->
        <div class="hidden sm:flex items-center gap-1">
          {pages.map(p => (
            p === null ? (
              <span class="flex h-8 w-6 items-center justify-center text-xs text-neutral-400 select-none">…</span>
            ) : p === currentPage ? (
              <span
                class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded border border-primary-500 bg-primary-500 px-2 text-xs font-bold text-white"
                aria-current="page"
              >
                {p}
              </span>
            ) : (
              <a
                href={pageUrl(p)}
                class="inline-flex h-8 min-w-[2rem] items-center justify-center rounded border border-neutral-200 bg-white px-2 text-xs font-semibold text-neutral-600 transition hover:border-primary-300 hover:text-primary-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-primary-700"
              >
                {p}
              </a>
            )
          ))}
        </div>

        <!-- Mobile : Page X / Y -->
        <span class="sm:hidden px-2 text-xs text-neutral-500 dark:text-neutral-400">
          Page {currentPage}/{lastPage}
        </span>

        <!-- Suivant -->
        {hasNext ? (
          <a
            href={pageUrl(currentPage + 1)}
            class="inline-flex h-8 items-center gap-1 rounded border border-neutral-200 bg-white px-2.5 text-xs font-semibold text-neutral-600 transition hover:border-primary-300 hover:text-primary-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400"
            aria-label="Page suivante"
          >
            <span class="hidden sm:inline">Suivant</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ) : (
          <span class="inline-flex h-8 items-center gap-1 rounded border border-neutral-100 bg-neutral-50 px-2.5 text-xs font-semibold text-neutral-300 cursor-not-allowed dark:border-neutral-800 dark:bg-neutral-900/50 dark:text-neutral-600">
            <span class="hidden sm:inline">Suivant</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        )}

      </nav>
    )}

  </div>
)}
