---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import Pagination from '../../components/ui/Pagination.astro'
import {
  MOCK_CONTACTS,
  MOCK_ACCOUNTS,
  CONTACT_TYPE_LABELS,
  CONTACT_TYPE_COLORS,
  type Contact,
  type ContactType,
} from '../../lib/contacts-data'
import { backendFetch } from '../../lib/auth'

const session = Astro.locals.session!

const page    = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10))
const perPage = (() => {
  const v = parseInt(Astro.url.searchParams.get('per_page') ?? '30', 10)
  return [30, 50, 100].includes(v) ? v : 30
})()

let allContacts: Contact[] = []
let meta = { total: 0, current_page: page, last_page: 1, per_page: perPage }
let useMock = false

try {
  const qs   = new URLSearchParams({ page: String(page), per_page: String(perPage) })
  const resp = await backendFetch(`/network/contacts?${qs}`, session)
  if (resp.ok) {
    const d = await resp.json()
    allContacts = (d.data ?? d) as Contact[]
    if (d.meta ?? d.last_page) {
      meta = {
        total:        d.meta?.total ?? d.total ?? allContacts.length,
        current_page: d.meta?.current_page ?? d.current_page ?? page,
        last_page:    d.meta?.last_page ?? d.last_page ?? 1,
        per_page:     d.meta?.per_page ?? d.per_page ?? perPage,
      }
    } else {
      meta = { total: allContacts.length, current_page: page, last_page: 1, per_page: perPage }
    }
  } else {
    useMock = true
  }
} catch {
  useMock = true
}

if (useMock) {
  allContacts = MOCK_CONTACTS
  meta = {
    total:        MOCK_CONTACTS.length,
    current_page: page,
    last_page:    Math.max(1, Math.ceil(MOCK_CONTACTS.length / perPage)),
    per_page:     perPage,
  }
}

const stats = {
  total:   meta.total,
  active:  allContacts.filter(c => c.status === 'active').length,
  schools: allContacts.filter(c => c.type === 'school').length,
  advisors:allContacts.filter(c => c.type === 'advisor').length,
}
const types = ['all', ...new Set(allContacts.map(c => c.type))] as ('all' | ContactType)[]
const contacts = useMock ? allContacts.slice((page - 1) * perPage, page * perPage) : allContacts
---

<DashboardLayout title="Contacts" activeNav="contacts">
  <div class="p-6 lg:p-8 max-w-6xl mx-auto space-y-6">

    <!-- En-tête -->
    <div class="flex flex-col sm:flex-row sm:items-end gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Réseau</p>
        <h1 class="font-headings text-2xl font-bold text-neutral-800 dark:text-neutral-100">Contacts</h1>
      </div>
      <button
        id="btn-new-contact"
        class="sm:ml-auto inline-flex items-center gap-2 rounded bg-primary-500 px-4 py-2 text-sm font-bold text-white hover:bg-primary-600 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Nouveau contact
      </button>
    </div>

    <!-- Stats rapides -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { label: 'Total contacts',  value: stats.total,   color: 'text-neutral-700', bg: 'bg-neutral-50 dark:bg-neutral-800' },
        { label: 'Actifs',          value: stats.active,  color: 'text-green-600',   bg: 'bg-green-50  dark:bg-green-950' },
        { label: 'Établissements',  value: stats.schools, color: 'text-red-600',     bg: 'bg-red-50    dark:bg-red-950' },
        { label: 'Conseillers',     value: stats.advisors,color: 'text-purple-600',  bg: 'bg-purple-50 dark:bg-purple-950' },
      ].map(s => (
        <div class="bg-white border border-neutral-100 rounded p-4 dark:bg-neutral-900 dark:border-neutral-800">
          <div class={`inline-flex h-8 w-8 items-center justify-center rounded ${s.bg} mb-3`}>
            <span class={`text-sm font-bold ${s.color}`}>{s.value}</span>
          </div>
          <p class="text-xs text-neutral-400 font-medium">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Barre de recherche -->
    <div class="relative">
      <div class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M16.65 16.65A7.5 7.5 0 1010 17.5a7.5 7.5 0 006.65-.85z"/>
        </svg>
      </div>
      <input
        id="contact-search"
        type="text"
        autocomplete="off"
        placeholder="Rechercher un contact, une école, un conseiller, une localisation…"
        class="h-10 w-full rounded border border-neutral-200 bg-white pl-9 pr-4 text-sm text-neutral-700 placeholder-neutral-400 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500"
      />
    </div>

    <!-- Filtres type -->
    <div class="flex flex-wrap gap-2">
      {types.map(t => (
        <button
          data-filter={t}
          class={`contact-filter-btn inline-flex items-center rounded-full border px-3.5 py-1.5 text-xs font-semibold transition-all duration-200 ${
            t === 'all'
              ? 'bg-primary-500 border-primary-500 text-white'
              : 'bg-white border-neutral-200 text-neutral-500 hover:border-primary-300 hover:text-primary-600 dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400'
          }`}
        >
          {t === 'all' ? 'Tous' : CONTACT_TYPE_LABELS[t as ContactType]}
        </button>
      ))}
    </div>

    <!-- Table -->
    <div class="bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-neutral-100 bg-neutral-50/50 dark:border-neutral-800 dark:bg-neutral-800/40">
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider text-neutral-400 px-5 py-3">Contact</th>
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider text-neutral-400 px-4 py-3 hidden sm:table-cell">Type</th>
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider text-neutral-400 px-4 py-3 hidden md:table-cell">Localisation</th>
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider text-neutral-400 px-4 py-3 hidden lg:table-cell">Spécialisations</th>
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider text-neutral-400 px-4 py-3">Statut</th>
              <th class="px-4 py-3 w-24"></th>
            </tr>
          </thead>
          <tbody id="contacts-tbody">
            {contacts.map((c) => (
              <tr
                class="contact-row border-b border-neutral-100 last:border-0 hover:bg-neutral-50 transition-colors group dark:border-neutral-800 dark:hover:bg-neutral-800"
                data-id={c.id}
                data-type={c.type}
                data-search={[c.name, c.role, c.email, c.location ?? '', c.type, CONTACT_TYPE_LABELS[c.type]].join(' ').toLowerCase()}
              >
                <!-- Contact -->
                <td class="px-5 py-3">
                  <div class="flex items-center gap-3">
                    <div class={`h-9 w-9 rounded-full ${c.avatarColor} flex items-center justify-center shrink-0 shadow-sm`}>
                      <span class="text-xs font-bold text-white">{c.initials}</span>
                    </div>
                    <div class="min-w-0">
                      <div class="flex items-center gap-1.5">
                        <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200 truncate group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{c.name}</p>
                        {c.isDefault && <span class="text-[9px] font-bold uppercase tracking-wide rounded-full bg-primary-100 text-primary-600 px-1.5 py-0.5 shrink-0 dark:bg-primary-950 dark:text-primary-400">Officiel</span>}
                      </div>
                      <p class="text-xs text-neutral-400 truncate">{c.email}</p>
                    </div>
                  </div>
                </td>
                <!-- Type -->
                <td class="px-4 py-3 hidden sm:table-cell">
                  <span class={`inline-flex items-center text-[10px] font-bold uppercase tracking-wide rounded-full border px-2 py-0.5 ${CONTACT_TYPE_COLORS[c.type]}`}>
                    {CONTACT_TYPE_LABELS[c.type]}
                  </span>
                </td>
                <!-- Localisation -->
                <td class="px-4 py-3 text-sm text-neutral-500 dark:text-neutral-400 hidden md:table-cell">{c.location ?? '—'}</td>
                <!-- Spécialisations -->
                <td class="px-4 py-3 hidden lg:table-cell">
                  <div class="flex flex-wrap gap-1">
                    {(c.specializations ?? []).slice(0, 2).map(s => (
                      <span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-1.5 py-0.5 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">{s}</span>
                    ))}
                    {(c.specializations ?? []).length > 2 && (
                      <span class="text-[10px] text-neutral-400">+{(c.specializations ?? []).length - 2}</span>
                    )}
                  </div>
                </td>
                <!-- Statut -->
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center gap-1 text-xs font-medium ${c.status === 'active' ? 'text-green-600 dark:text-green-400' : 'text-neutral-400 dark:text-neutral-500'}`}>
                    <span class={`h-1.5 w-1.5 rounded-full ${c.status === 'active' ? 'bg-green-500 dark:bg-green-400' : 'bg-neutral-300 dark:bg-neutral-600'}`}></span>
                    {c.status === 'active' ? 'Actif' : 'Inactif'}
                  </span>
                </td>
                <!-- Actions -->
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button
                      class="contact-detail-btn inline-flex items-center gap-1 text-xs font-semibold text-neutral-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                      data-id={c.id}
                    >
                      Voir
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <!-- Aucun résultat -->
        <div id="no-contacts" class="hidden py-16 text-center">
          <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400">Aucun contact trouvé</p>
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <Pagination
      currentPage={meta.current_page}
      lastPage={meta.last_page}
      total={meta.total}
      perPage={meta.per_page}
      baseUrl={Astro.url}
    />

  </div>

  <!-- ── Modale détail contact ─────────────────────────────────────── -->
  <div
    id="contact-panel"
    class="hidden fixed inset-0 z-40 items-center justify-center p-4 sm:p-6 bg-neutral-900/40 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-modal-title"
  >
    <!-- Carte modale animée -->
    <div
      id="contact-modal-card"
      class="w-full max-w-2xl max-h-[88vh] flex flex-col rounded-xl border border-neutral-100 bg-white shadow-2xl shadow-neutral-900/20 overflow-hidden transition-all duration-200 opacity-0 scale-95 dark:bg-neutral-900 dark:border-neutral-800"
    >
      <div class="shrink-0 flex items-center justify-between px-6 py-4 border-b border-neutral-100 dark:border-neutral-800">
        <h2 id="contact-modal-title" class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Fiche contact</h2>
        <div class="flex items-center gap-2">
          <button id="btn-edit-contact" class="h-8 px-3 rounded border border-neutral-200 text-xs font-semibold text-neutral-500 hover:border-primary-300 hover:text-primary-600 transition-all dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400">
            Modifier
          </button>
          <button id="panel-close" class="h-8 w-8 flex items-center justify-center rounded-full text-neutral-400 hover:text-neutral-700 hover:bg-neutral-50 transition-all dark:hover:text-neutral-200 dark:hover:bg-neutral-800" aria-label="Fermer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
      <div id="panel-content" class="flex-1 overflow-y-auto"></div>
    </div>
  </div>

  <!-- Modal nouveau contact -->
  <div id="modal-new-contact" class="hidden fixed inset-0 z-50 items-center justify-center bg-neutral-900/40 backdrop-blur-sm">
    <div class="m-6 w-full max-w-lg overflow-hidden rounded border border-neutral-100 bg-white shadow-xl dark:bg-neutral-900 dark:border-neutral-800">
      <div class="flex items-center justify-between border-b border-neutral-100 px-6 py-4 dark:border-neutral-800">
        <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Nouveau contact</h2>
        <button id="modal-close" class="h-8 w-8 flex items-center justify-center rounded-full text-neutral-400 hover:text-neutral-700 hover:bg-neutral-50 transition-all dark:hover:text-neutral-200 dark:hover:bg-neutral-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Nom / Raison sociale *</label>
            <input type="text" placeholder="Ex: Dr. Michel Obame" class="h-10 w-full rounded border border-neutral-200 px-3 text-sm text-neutral-700 outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200"/>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Email *</label>
            <input type="email" placeholder="contact@example.com" class="h-10 w-full rounded border border-neutral-200 px-3 text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200"/>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Téléphone</label>
            <input type="tel" placeholder="+241 07 XX XX XX" class="h-10 w-full rounded border border-neutral-200 px-3 text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200"/>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Type *</label>
            <select class="h-10 w-full rounded border border-neutral-200 px-3 text-sm text-neutral-600 outline-none focus:border-amber-400 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300">
              <option value="">Sélectionner…</option>
              <option value="wwa_team">Équipe WWA</option>
              <option value="referent">Référent</option>
              <option value="school">École / Université</option>
              <option value="company">Cabinet / Entreprise</option>
              <option value="advisor">Conseiller</option>
              <option value="personal">Contact personnel</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Localisation</label>
            <input type="text" placeholder="Libreville, Gabon" class="h-10 w-full rounded border border-neutral-200 px-3 text-sm text-neutral-700 outline-none focus:border-amber-400 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500"/>
          </div>
          <div class="col-span-2">
            <label class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Bio courte</label>
            <textarea rows={3} placeholder="Description du contact…" class="w-full rounded border border-neutral-200 px-3 py-2.5 text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition resize-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500"></textarea>
          </div>
        </div>
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-neutral-100 dark:border-neutral-800">
          <button id="modal-cancel" class="h-9 rounded border border-neutral-200 px-4 text-sm font-medium text-neutral-600 hover:bg-neutral-50 transition dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800">Annuler</button>
          <button class="h-9 rounded bg-primary-500 px-4 text-sm font-bold text-white hover:bg-primary-600 transition">Créer le contact</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ contactsAdmin: allContacts, accountsData: MOCK_ACCOUNTS }}>
    window.__CONTACTS_ADMIN__ = contactsAdmin
    window.__ACCOUNTS_ADMIN__ = accountsData
  </script>

  <script>
    import type { Contact, Account } from '../../lib/contacts-data'

    const ALL_CONTACTS: Contact[] = (window as any).__CONTACTS_ADMIN__ ?? []
    const ALL_ACCOUNTS: Account[] = (window as any).__ACCOUNTS_ADMIN__ ?? []

    function esc(s: string) { return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;') }

    const CTYPE_LABELS: Record<string,string> = { wwa_team:'Équipe WWA', referent:'Référent', school:'École / Université', company:'Cabinet / Entreprise', advisor:'Conseiller', personal:'Contact personnel' }
    const CTYPE_COLORS: Record<string,string> = {
      wwa_team: 'bg-primary-100 text-primary-700 dark:bg-primary-950 dark:text-primary-300',
      referent: 'bg-gold-100 text-gold-800 dark:bg-gold-900/40 dark:text-gold-300',
      school:   'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300',
      company:  'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300',
      advisor:  'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300',
      personal: 'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300',
    }

    let currentContactId = ''

    document.addEventListener('astro:page-load', () => {

      // ── Filtres + recherche ─────────────────────────────────────
      const searchInput = document.getElementById('contact-search') as HTMLInputElement | null
      const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.contact-filter-btn')
      const rows        = document.querySelectorAll<HTMLTableRowElement>('.contact-row')
      const noResults   = document.getElementById('no-contacts')
      let activeFilter  = 'all'

      function refresh() {
        const q = searchInput?.value.trim().toLowerCase() ?? ''
        const terms = q.split(/\s+/).filter(Boolean)
        let visible = 0
        rows.forEach(row => {
          const show = (activeFilter === 'all' || row.dataset.type === activeFilter)
            && (terms.length === 0 || terms.every(t => (row.dataset.search ?? '').includes(t)))
          row.classList.toggle('hidden', !show)
          if (show) visible++
        })
        noResults?.classList.toggle('hidden', visible > 0)
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          activeFilter = btn.dataset.filter!
          filterBtns.forEach(b => {
            const on = b.dataset.filter === activeFilter
            b.classList.toggle('bg-primary-500', on); b.classList.toggle('border-primary-500', on); b.classList.toggle('text-white', on)
            b.classList.toggle('bg-white', !on); b.classList.toggle('border-neutral-200', !on); b.classList.toggle('text-neutral-500', !on)
            b.classList.toggle('hover:text-primary-600', !on); b.classList.toggle('hover:border-primary-300', !on)
          })
          refresh()
        })
      })
      searchInput?.addEventListener('input', refresh)

      // ── Modale ───────────────────────────────────────────────────
      const panel    = document.getElementById('contact-panel')!
      const card     = document.getElementById('contact-modal-card')!
      const content  = document.getElementById('panel-content')!
      const closeBtn = document.getElementById('panel-close')!

      function openPanel(id: string) {
        const c = ALL_CONTACTS.find(x => x.id === id)
        if (!c) return
        currentContactId = id
        showDetail(c)
        panel.classList.remove('hidden')
        panel.classList.add('flex')
        document.body.style.overflow = 'hidden'
        requestAnimationFrame(() => {
          card.classList.remove('opacity-0', 'scale-95')
          card.classList.add('opacity-100', 'scale-100')
        })
      }

      function showDetail(c: Contact) {
        content.innerHTML = buildDetail(c)
        document.getElementById('btn-edit-contact')!.style.display = ''
        // Action buttons via event delegation
        content.querySelector<HTMLElement>('[data-action="conversations"]')?.addEventListener('click', () => {
          window.location.href = '/admin/messages'
        })
        content.querySelector<HTMLElement>('[data-action="assign"]')?.addEventListener('click', () => {
          showAssignPanel(c)
        })
        content.querySelector<HTMLElement>('[data-action="deactivate"]')?.addEventListener('click', () => {
          if (confirm(`Désactiver le contact "${c.name}" ? Il ne sera plus visible par les candidats.`)) {
            c.status = 'inactive' as any
            const rowStatus = document.querySelector<HTMLElement>(`.contact-row[data-id="${c.id}"] .contact-status-dot`)
            if (rowStatus) rowStatus.classList.replace('bg-primary-400', 'bg-neutral-300')
            showDetail(c)
          }
        })
      }

      function showEditForm(c: Contact) {
        document.getElementById('btn-edit-contact')!.style.display = 'none'
        content.innerHTML = buildEditForm(c)
        content.querySelector<HTMLButtonElement>('#edit-cancel')?.addEventListener('click', () => showDetail(c))
        content.querySelector<HTMLButtonElement>('#edit-save')?.addEventListener('click', () => {
          const get = (id: string) => (content.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(`#${id}`)?.value.trim() ?? '')
          c.name         = get('edit-name')  || c.name
          c.role         = get('edit-role')  || c.role
          c.email        = get('edit-email') || c.email
          c.phone        = get('edit-phone') || undefined
          c.location     = get('edit-location') || undefined
          c.availability = get('edit-availability') || undefined
          c.bio          = get('edit-bio') || undefined
          // Sync table row name/email display
          const row = document.querySelector<HTMLElement>(`.contact-row[data-id="${c.id}"]`)
          if (row) {
            const nameEl  = row.querySelector<HTMLElement>('p.text-sm.font-semibold')
            const emailEl = row.querySelector<HTMLElement>('p.text-xs.text-neutral-400')
            if (nameEl)  nameEl.textContent  = c.name
            if (emailEl) emailEl.textContent = c.email
          }
          showDetail(c)
        })
      }

      function showAssignPanel(c: Contact) {
        document.getElementById('btn-edit-contact')!.style.display = 'none'
        content.innerHTML = buildAssignPanel(c)
        content.querySelector<HTMLButtonElement>('#assign-back')?.addEventListener('click', () => {
          document.getElementById('btn-edit-contact')!.style.display = ''
          showDetail(c)
        })
        content.querySelectorAll<HTMLButtonElement>('.assign-candidate-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const cand = ALL_ACCOUNTS.find(a => a.id === btn.dataset.candId)
            if (!cand) return
            if (confirm(`Assigner "${cand.name}" au contact "${c.name}" ?`)) {
              alert(`Contact assigné à ${cand.name}.\nLe candidat verra ce contact dans sa liste.`)
              document.getElementById('btn-edit-contact')!.style.display = ''
              showDetail(c)
            }
          })
        })
      }

      function closePanel() {
        card.classList.remove('opacity-100', 'scale-100')
        card.classList.add('opacity-0', 'scale-95')
        setTimeout(() => {
          panel.classList.add('hidden')
          panel.classList.remove('flex')
          document.body.style.overflow = ''
        }, 200)
      }

      document.querySelectorAll<HTMLButtonElement>('.contact-detail-btn').forEach(btn => {
        btn.addEventListener('click', e => { e.stopPropagation(); openPanel(btn.dataset.id!) })
      })
      document.querySelectorAll<HTMLTableRowElement>('.contact-row').forEach(row => {
        row.style.cursor = 'pointer'
        row.addEventListener('click', () => openPanel(row.dataset.id!))
      })
      closeBtn.addEventListener('click', closePanel)
      panel.addEventListener('click', (e: MouseEvent) => { if (e.target === panel) closePanel() })

      document.getElementById('btn-edit-contact')?.addEventListener('click', () => {
        const c = ALL_CONTACTS.find(x => x.id === currentContactId)
        if (c) showEditForm(c)
      })

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closePanel()
      })

      // ── Modal nouveau contact ────────────────────────────────────
      const modal = document.getElementById('modal-new-contact')!
      document.getElementById('btn-new-contact')?.addEventListener('click', () => {
        modal.classList.remove('hidden'); modal.classList.add('flex')
      })
      const closeModal = () => { modal.classList.add('hidden'); modal.classList.remove('flex') }
      document.getElementById('modal-close')?.addEventListener('click', closeModal)
      document.getElementById('modal-cancel')?.addEventListener('click', closeModal)
      modal.addEventListener('click', e => { if (e.target === modal) closeModal() })
    })

    // ── Builders ─────────────────────────────────────────────────────────────

    function buildDetail(c: Contact): string {
      const specs = (c.specializations ?? []).map(s => `<span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-2 py-1 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">${esc(s)}</span>`).join('')
      const infoRow = (icon: string, val: string, href?: string) => `
        <div class="flex items-center gap-2.5 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="${icon}"/></svg>
          ${href ? `<a href="${esc(href)}" class="text-primary-500 hover:underline truncate">${esc(val)}</a>` : `<span class="text-neutral-600 dark:text-neutral-300 truncate">${esc(val)}</span>`}
        </div>`
      const isActive = (c.status as string) !== 'inactive'

      return `
        <div class="p-6 border-b border-neutral-100 dark:border-neutral-800">
          <div class="flex items-center gap-4 mb-5">
            <div class="${c.avatarColor} h-16 w-16 rounded-full flex items-center justify-center shrink-0 shadow-sm">
              <span class="text-xl font-bold text-white">${esc(c.initials)}</span>
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h3 class="font-headings font-bold text-neutral-800 dark:text-neutral-100 text-base">${esc(c.name)}</h3>
                ${c.isDefault ? '<span class="text-[9px] font-bold uppercase tracking-wide rounded-full bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400 px-1.5 py-0.5">Officiel</span>' : ''}
              </div>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-2">${esc(c.role)}</p>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="${CTYPE_COLORS[c.type]??'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300'} text-[10px] font-bold uppercase tracking-wide rounded-full px-2.5 py-0.5">${CTYPE_LABELS[c.type]??c.type}</span>
                <span class="flex items-center gap-1 text-[10px] font-medium ${isActive ? 'text-neutral-600 dark:text-neutral-300' : 'text-neutral-400 dark:text-neutral-500'}">
                  <span class="contact-status-dot h-1.5 w-1.5 rounded-full ${isActive ? 'bg-primary-400' : 'bg-neutral-300'}"></span>
                  ${isActive ? 'Actif' : 'Inactif'}
                </span>
              </div>
            </div>
          </div>
          <div class="space-y-2">
            ${infoRow('M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', c.email, `mailto:${c.email}`)}
            ${c.phone ? infoRow('M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', c.phone, `tel:${c.phone}`) : ''}
            ${c.location ? infoRow('M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z', c.location) : ''}
            ${c.website ? infoRow('M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', c.website.replace('https://',''), c.website) : ''}
            ${c.availability ? infoRow('M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', c.availability) : ''}
          </div>
        </div>
        ${c.bio ? `<div class="p-6 border-b border-neutral-100 dark:border-neutral-800"><h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">À propos</h4><p class="text-sm text-neutral-600 dark:text-neutral-300 leading-relaxed">${esc(c.bio)}</p></div>` : ''}
        ${c.specializations?.length ? `<div class="p-6 border-b border-neutral-100 dark:border-neutral-800"><h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Spécialisations</h4><div class="flex flex-wrap gap-1.5">${specs}</div></div>` : ''}
        ${c.languages?.length ? `<div class="p-6 border-b border-neutral-100 dark:border-neutral-800"><h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Langues</h4><div class="flex flex-wrap gap-1.5">${(c.languages??[]).map(l=>`<span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-2.5 py-1 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">${esc(l)}</span>`).join('')}</div></div>` : ''}
        <div class="p-6 space-y-1">
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Actions</h4>
          <button data-action="conversations" class="w-full text-left text-sm text-neutral-600 dark:text-neutral-300 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-950 transition-colors py-2 px-3 rounded flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <span class="flex-1">Voir les conversations</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
          <button data-action="assign" class="w-full text-left text-sm text-neutral-600 dark:text-neutral-300 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-primary-950 transition-colors py-2 px-3 rounded flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="flex-1">Assigner à un candidat</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
          ${isActive ? `<button data-action="deactivate" class="w-full text-left text-sm text-red-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-950 transition-colors py-2 px-3 rounded flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
            <span class="flex-1">Désactiver ce contact</span>
          </button>` : `<p class="text-xs text-neutral-400 dark:text-neutral-500 px-3 py-2">Ce contact est désactivé.</p>`}
        </div>`
    }

    function buildEditForm(c: Contact): string {
      const field = (id: string, label: string, type: string, val: string, placeholder = '') => `
        <div>
          <label for="${id}" class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">${label}</label>
          <input id="${id}" type="${type}" value="${esc(val)}" placeholder="${esc(placeholder)}"
            class="h-10 w-full rounded border border-neutral-200 bg-white px-3 text-sm text-neutral-700 outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500"/>
        </div>`

      return `
        <div class="p-6 space-y-4">
          <div class="flex items-center gap-2 pb-3 border-b border-neutral-100 dark:border-neutral-800">
            <div class="${c.avatarColor} h-9 w-9 rounded-full flex items-center justify-center shrink-0">
              <span class="text-sm font-bold text-white">${esc(c.initials)}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">${esc(c.name)}</p>
              <p class="text-[10px] text-neutral-400 uppercase tracking-widest">Modification</p>
            </div>
          </div>
          ${field('edit-name', 'Nom / Raison sociale', 'text', c.name)}
          ${field('edit-role', 'Rôle / Titre', 'text', c.role)}
          <div class="grid grid-cols-2 gap-3">
            ${field('edit-email', 'Email', 'email', c.email)}
            ${field('edit-phone', 'Téléphone', 'tel', c.phone ?? '', '+241 07 …')}
          </div>
          ${field('edit-location', 'Localisation', 'text', c.location ?? '', 'Libreville, Gabon')}
          ${field('edit-availability', 'Disponibilité', 'text', c.availability ?? '', 'Lun–Ven · 9h–17h')}
          <div>
            <label for="edit-bio" class="block text-xs font-semibold text-neutral-500 dark:text-neutral-400 mb-1.5">Bio</label>
            <textarea id="edit-bio" rows="4" placeholder="Description du contact…"
              class="w-full rounded border border-neutral-200 bg-white px-3 py-2.5 text-sm text-neutral-700 outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition resize-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500">${esc(c.bio ?? '')}</textarea>
          </div>
          <div class="flex gap-3 pt-2 border-t border-neutral-100 dark:border-neutral-800">
            <button id="edit-cancel" class="flex-1 h-9 rounded border border-neutral-200 text-sm font-medium text-neutral-600 hover:bg-neutral-50 transition dark:border-neutral-700 dark:text-neutral-400 dark:hover:bg-neutral-800">Annuler</button>
            <button id="edit-save" class="flex-1 h-9 rounded bg-primary-500 text-sm font-bold text-white hover:bg-primary-600 transition">Sauvegarder</button>
          </div>
        </div>`
    }

    function buildAssignPanel(c: Contact): string {
      const candidates = ALL_ACCOUNTS.filter(a => a.role === 'candidate')
      const items = candidates.length
        ? candidates.map(a => `
          <button class="assign-candidate-btn w-full flex items-center gap-3 p-3 rounded border border-neutral-100 hover:border-primary-200 hover:bg-primary-50/50 transition-all text-left mb-2 dark:border-neutral-800 dark:hover:border-primary-700 dark:hover:bg-primary-950/30" data-cand-id="${esc(a.id)}">
            <div class="${a.avatarColor} h-9 w-9 rounded-full flex items-center justify-center shrink-0">
              <span class="text-xs font-bold text-white">${esc(a.initials)}</span>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200 truncate">${esc(a.name)}</p>
              <p class="text-xs text-neutral-400 truncate">${esc(a.email)}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-300 dark:text-neutral-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>`).join('')
        : '<p class="text-sm text-neutral-400 dark:text-neutral-500 py-4 text-center">Aucun candidat disponible</p>'

      return `
        <div class="p-6">
          <div class="flex items-center gap-3 mb-5 pb-4 border-b border-neutral-100 dark:border-neutral-800">
            <button id="assign-back" class="h-8 w-8 flex items-center justify-center rounded border border-neutral-200 text-neutral-400 hover:text-neutral-700 hover:bg-neutral-50 transition-all shrink-0 dark:border-neutral-700 dark:hover:text-neutral-200 dark:hover:bg-neutral-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <div>
              <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Assigner à un candidat</p>
              <p class="text-xs text-neutral-400">${esc(c.name)}</p>
            </div>
          </div>
          <p class="text-xs text-neutral-400 mb-3">Sélectionnez le candidat à associer à ce contact :</p>
          ${items}
        </div>`
    }
  </script>

</DashboardLayout>
