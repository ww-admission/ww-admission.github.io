---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import { MOCK_LOGS, formatDateTime } from '../../lib/mock-data'



const logs = MOCK_LOGS.slice().sort((a, b) => b.createdAt.localeCompare(a.createdAt))

const ACTION_ICONS: Record<string, string> = {
  'candidature.submitted': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'candidature.status_changed': 'M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4',
  'candidature.comment_added': 'M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z',
  'message.sent': 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  'user.login': 'M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1',
}

const ACTION_COLORS: Record<string, string> = {
  'candidature.submitted': 'bg-blue-50 text-blue-600',
  'candidature.status_changed': 'bg-amber-50 text-amber-600',
  'candidature.comment_added': 'bg-purple-50 text-purple-600',
  'message.sent': 'bg-green-50 text-green-600',
  'user.login': 'bg-neutral-50 text-neutral-600',
}

const ROLE_BADGE: Record<string, string> = {
  admin: 'bg-primary-50 text-primary-600',
  candidate: 'bg-amber-50 text-amber-700',
  system: 'bg-neutral-100 text-neutral-500',
}
---

<DashboardLayout title="Logs" activeNav="logs">
  <div class="p-6 max-w-5xl mx-auto space-y-5">

    <div>
      <h1 class="text-2xl font-headings font-semibold text-neutral-700">Logs d'activité</h1>
      <p class="text-sm text-neutral-400 mt-0.5">{logs.length} événements enregistrés</p>
    </div>

    <div class="bg-white rounded-xl border border-neutral-100 overflow-hidden">
      <div class="divide-y divide-neutral-50">
        {logs.map(log => {
          const iconPath = ACTION_ICONS[log.action] ?? 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          const colorClass = ACTION_COLORS[log.action] ?? 'bg-neutral-50 text-neutral-600'
          const roleBadge = ROLE_BADGE[log.actorRole] ?? 'bg-neutral-100 text-neutral-500'

          return (
            <div class="flex items-start gap-4 p-4 hover:bg-neutral-50/40 transition">
              <div class={`h-9 w-9 rounded-full flex items-center justify-center shrink-0 mt-0.5 ${colorClass}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-sm font-medium text-neutral-700">{log.description}</p>
                  <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${roleBadge}`}>
                    {log.actorRole}
                  </span>
                </div>
                <p class="text-xs text-neutral-500 mt-0.5">
                  Par <span class="font-medium">{log.actorName}</span>
                  {log.targetId && log.targetType === 'candidature' && (
                    <> · <a href={`/admin/candidatures/${log.targetId}`} class="text-primary-500 hover:underline">Voir la candidature</a></>
                  )}
                </p>
                {log.meta && (
                  <p class="text-xs text-neutral-400 mt-1">
                    {Object.entries(log.meta).map(([k, v]) => `${k}: ${v}`).join(' · ')}
                  </p>
                )}
              </div>
              <div class="shrink-0 text-right">
                <p class="text-xs text-neutral-400">{formatDateTime(log.createdAt)}</p>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</DashboardLayout>
