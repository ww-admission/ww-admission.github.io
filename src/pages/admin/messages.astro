---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import {
  MOCK_CONVERSATIONS,
  MOCK_MESSAGES,
  formatDateTime,
} from '../../lib/mock-data'



// Conversation active gérée côté client (window.location.search)
const activeId = MOCK_CONVERSATIONS[0]?.id
const activeConv = MOCK_CONVERSATIONS[0]
const messages = activeId ? (MOCK_MESSAGES[activeId] ?? []) : []
---

<DashboardLayout title="Messages" activeNav="messages">
  <div class="flex h-[calc(100vh-4rem)] lg:h-screen overflow-hidden">

    <!-- Liste des conversations -->
    <aside class="w-72 bg-white border-r border-neutral-100 flex flex-col shrink-0 hidden sm:flex">
      <div class="p-4 border-b border-neutral-50">
        <h2 class="text-sm font-semibold text-neutral-700">Conversations</h2>
      </div>
      <div class="flex-1 overflow-y-auto divide-y divide-neutral-50">
        {MOCK_CONVERSATIONS.map(conv => (
          <a
            href={`/admin/messages?conv=${conv.id}`}
            class={`flex items-start gap-3 p-4 hover:bg-neutral-50 transition ${conv.id === activeId ? 'bg-primary-50/50' : ''}`}
          >
            <div class="h-9 w-9 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 text-sm font-semibold text-neutral-600">
              {conv.candidateName.charAt(0)}
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between">
                <p class={`text-sm font-medium truncate ${conv.id === activeId ? 'text-primary-600' : 'text-neutral-700'}`}>
                  {conv.candidateName}
                </p>
                {conv.unreadCount > 0 && (
                  <span class="ml-2 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-primary-500 px-1.5 text-xs font-bold text-white shrink-0">
                    {conv.unreadCount}
                  </span>
                )}
              </div>
              {conv.lastMessage && (
                <p class="text-xs text-neutral-400 truncate mt-0.5">{conv.lastMessage.content}</p>
              )}
              {conv.lastMessage && (
                <p class="text-xs text-neutral-300 mt-0.5">{formatDateTime(conv.lastMessage.createdAt)}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </aside>

    <!-- Zone de conversation -->
    <div class="flex-1 flex flex-col min-w-0">
      {!activeConv ? (
        <div class="flex-1 flex items-center justify-center text-neutral-400">
          <div class="text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <p class="text-sm">Sélectionnez une conversation</p>
          </div>
        </div>
      ) : (
        <>
          <!-- En-tête conversation -->
          <div class="flex items-center gap-3 px-5 h-14 bg-white border-b border-neutral-100 shrink-0">
            <div class="h-8 w-8 rounded-full bg-neutral-100 flex items-center justify-center text-sm font-semibold text-neutral-600 shrink-0">
              {activeConv.candidateName.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-700">{activeConv.candidateName}</p>
              <p class="text-xs text-neutral-400">{activeConv.candidateEmail}</p>
            </div>
            {activeConv.candidatureId && (
              <a
                href={`/admin/candidatures/${activeConv.candidatureId}`}
                class="ml-auto text-xs font-medium text-primary-500 hover:text-primary-600 transition whitespace-nowrap"
              >
                Voir la candidature →
              </a>
            )}
          </div>

          <!-- Messages -->
          <div class="flex-1 overflow-y-auto p-5 space-y-3" id="messages-container">
            {messages.map(msg => (
              <div class={`flex ${msg.senderRole === 'admin' ? 'justify-end' : 'justify-start'}`}>
                <div class={`max-w-[70%] rounded-xl px-4 py-2.5 ${
                  msg.senderRole === 'admin'
                    ? 'bg-primary-500 text-white'
                    : 'bg-white border border-neutral-100 text-neutral-700'
                }`}>
                  <p class="text-sm leading-relaxed">{msg.content}</p>
                  <p class={`text-xs mt-1.5 ${msg.senderRole === 'admin' ? 'text-primary-200' : 'text-neutral-400'}`}>
                    {formatDateTime(msg.createdAt)}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <!-- Zone de saisie -->
          <div class="border-t border-neutral-100 bg-white p-4">
            <div class="flex gap-2">
              <input
                id="message-input"
                type="text"
                placeholder="Écrire un message…"
                class="flex-1 rounded-lg border border-neutral-200 px-3.5 py-2.5 text-sm text-neutral-700 placeholder:text-neutral-400 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 transition"
              />
              <button
                id="send-btn"
                class="rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-600 transition"
              >
                Envoyer
              </button>
            </div>
          </div>
        </>
      )}
    </div>
  </div>

  <script>
    const sendBtn = document.getElementById('send-btn')
    const input = document.getElementById('message-input') as HTMLInputElement

    sendBtn?.addEventListener('click', () => {
      if (!input?.value.trim()) return
      // TODO: appeler l'API backend
      alert('Messagerie disponible après intégration du backend Laravel.')
    })

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        sendBtn?.click()
      }
    })

    // Scroll en bas
    const container = document.getElementById('messages-container')
    if (container) container.scrollTop = container.scrollHeight
  </script>
</DashboardLayout>
