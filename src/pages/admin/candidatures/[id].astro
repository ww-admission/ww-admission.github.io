---
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import {
  MOCK_CANDIDATURES,
  MOCK_CONVERSATIONS,
  MOCK_MESSAGES,
  STATUS_LABELS,
  STATUS_COLORS,
  formatDate,
  formatDateTime,
  type CandidatureStatus,
} from '../../../lib/mock-data'

export function getStaticPaths() {
  return MOCK_CANDIDATURES.map(c => ({ params: { id: c.id } }))
}

const { id } = Astro.params
const candidature = MOCK_CANDIDATURES.find(c => c.id === id)!
const conversation = MOCK_CONVERSATIONS.find(c => c.candidatureId === id)
const messages = conversation ? (MOCK_MESSAGES[conversation.id] ?? []) : []

const ALL_STATUSES: CandidatureStatus[] = ['pending', 'reviewing', 'on_hold', 'accepted', 'rejected']
---

<DashboardLayout title={`Candidature — ${candidature.candidateName}`} activeNav="candidatures">
  <div class="p-6 max-w-5xl mx-auto space-y-6">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-neutral-400">
      <a href="/admin/candidatures" class="hover:text-primary-500 transition">Candidatures</a>
      <span>/</span>
      <span class="text-neutral-700">{candidature.candidateName}</span>
    </div>

    <!-- En-tête candidature -->
    <div class="bg-white rounded-xl border border-neutral-100 p-6">
      <div class="flex flex-col sm:flex-row sm:items-start gap-4">
        <div class="h-14 w-14 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 text-xl font-bold text-neutral-600">
          {candidature.candidateName.charAt(0)}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-3 mb-1">
            <h1 class="text-xl font-headings font-semibold text-neutral-700">{candidature.candidateName}</h1>
            <span class={`rounded-full px-2.5 py-1 text-xs font-medium ${STATUS_COLORS[candidature.status as CandidatureStatus]}`}>
              {STATUS_LABELS[candidature.status as CandidatureStatus]}
            </span>
          </div>
          <p class="text-sm text-neutral-500">{candidature.candidateEmail} · {candidature.candidatePhone}</p>
          <p class="text-sm text-neutral-400 mt-1">
            Soumis le {formatDateTime(candidature.submittedAt)} ·
            <span class="font-medium text-neutral-600">{candidature.destination}</span> ·
            {candidature.programme}
          </p>
        </div>
        <!-- Changer statut -->
        <div class="shrink-0">
          <form id="status-form" class="flex gap-2 items-center">
            <select
              id="status-select"
              name="status"
              class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20"
            >
              {ALL_STATUSES.map(s => (
                <option value={s} selected={s === candidature.status}>
                  {STATUS_LABELS[s]}
                </option>
              ))}
            </select>
            <button
              type="submit"
              class="rounded-lg bg-primary-500 px-3 py-2 text-sm font-semibold text-white hover:bg-primary-600 transition"
            >
              Enregistrer
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Infos personnelles -->
      <div class="bg-white rounded-xl border border-neutral-100 p-5">
        <h2 class="text-sm font-semibold text-neutral-700 mb-4">Informations personnelles</h2>
        <dl class="space-y-2.5">
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Date de naissance</dt>
            <dd class="text-sm text-neutral-700">{formatDate(candidature.personalInfo.dateNaissance)}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Nationalité</dt>
            <dd class="text-sm text-neutral-700">{candidature.personalInfo.nationalite}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Ville / Pays</dt>
            <dd class="text-sm text-neutral-700">{candidature.personalInfo.ville}, {candidature.personalInfo.pays}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Situation</dt>
            <dd class="text-sm text-neutral-700">{candidature.personalInfo.situationFamiliale}</dd>
          </div>
        </dl>
      </div>

      <!-- Infos académiques -->
      <div class="bg-white rounded-xl border border-neutral-100 p-5">
        <h2 class="text-sm font-semibold text-neutral-700 mb-4">Parcours académique</h2>
        <dl class="space-y-2.5">
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Niveau actuel</dt>
            <dd class="text-sm text-neutral-700">{candidature.academicInfo.niveauActuel}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Établissement</dt>
            <dd class="text-sm text-neutral-700">{candidature.academicInfo.etablissement}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Spécialité</dt>
            <dd class="text-sm text-neutral-700">{candidature.academicInfo.specialite}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Moyenne</dt>
            <dd class="text-sm text-neutral-700">{candidature.academicInfo.moyenne}/20</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-xs text-neutral-400 w-32 shrink-0">Langues</dt>
            <dd class="text-sm text-neutral-700">{candidature.academicInfo.langues.join(', ')}</dd>
          </div>
        </dl>
      </div>

      <!-- Documents -->
      <div class="bg-white rounded-xl border border-neutral-100 p-5">
        <h2 class="text-sm font-semibold text-neutral-700 mb-4">Documents fournis</h2>
        {candidature.documents.length === 0 ? (
          <p class="text-sm text-neutral-400">Aucun document</p>
        ) : (
          <ul class="space-y-2">
            {candidature.documents.map(doc => (
              <li class="flex items-center gap-3 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="text-neutral-700">{doc.originalName}</span>
                <span class="text-neutral-400 text-xs">({doc.name})</span>
              </li>
            ))}
          </ul>
        )}
        <p class="text-xs text-neutral-400 mt-3 italic">
          Les vrais fichiers seront disponibles après l'intégration du backend Laravel.
        </p>
      </div>

      <!-- Commentaires admin -->
      <div class="bg-white rounded-xl border border-neutral-100 p-5">
        <h2 class="text-sm font-semibold text-neutral-700 mb-4">Commentaires internes</h2>
        {candidature.comments.length === 0 ? (
          <p class="text-sm text-neutral-400 mb-4">Aucun commentaire</p>
        ) : (
          <div class="space-y-3 mb-4">
            {candidature.comments.map(comment => (
              <div class="rounded-lg bg-neutral-50 p-3">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-semibold text-neutral-700">{comment.authorName}</span>
                  <span class="text-xs text-neutral-400">{formatDateTime(comment.createdAt)}</span>
                </div>
                <p class="text-sm text-neutral-600">{comment.content}</p>
              </div>
            ))}
          </div>
        )}
        <textarea
          id="new-comment"
          rows={3}
          placeholder="Ajouter un commentaire interne…"
          class="w-full rounded-lg border border-neutral-200 px-3 py-2.5 text-sm text-neutral-700 placeholder:text-neutral-400 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 resize-none transition"
        ></textarea>
        <button
          id="add-comment-btn"
          class="mt-2 rounded-lg bg-neutral-100 px-3 py-1.5 text-xs font-semibold text-neutral-700 hover:bg-neutral-200 transition"
        >
          Ajouter
        </button>
      </div>
    </div>

    <!-- Messagerie avec le candidat -->
    <div class="bg-white rounded-xl border border-neutral-100 p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-neutral-700">Messagerie avec {candidature.candidateName}</h2>
        {conversation && (
          <a href="/admin/messages" class="text-xs text-primary-500 hover:text-primary-600 transition">Voir toutes les discussions →</a>
        )}
      </div>

      {messages.length === 0 ? (
        <p class="text-sm text-neutral-400 text-center py-8">Aucun message. Commencez la conversation !</p>
      ) : (
        <div class="space-y-3 mb-4 max-h-64 overflow-y-auto">
          {messages.map(msg => (
            <div class={`flex ${msg.senderRole === 'admin' ? 'justify-end' : 'justify-start'}`}>
              <div class={`max-w-[70%] rounded-xl px-4 py-2.5 ${
                msg.senderRole === 'admin'
                  ? 'bg-primary-500 text-white'
                  : 'bg-neutral-100 text-neutral-700'
              }`}>
                <p class="text-sm">{msg.content}</p>
                <p class={`text-xs mt-1 ${msg.senderRole === 'admin' ? 'text-primary-200' : 'text-neutral-400'}`}>
                  {formatDateTime(msg.createdAt)}
                </p>
              </div>
            </div>
          ))}
        </div>
      )}

      <div class="flex gap-2">
        <input
          id="message-input"
          type="text"
          placeholder="Écrire un message…"
          class="flex-1 rounded-lg border border-neutral-200 px-3.5 py-2.5 text-sm text-neutral-700 placeholder:text-neutral-400 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 transition"
        />
        <button
          id="send-message-btn"
          class="rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-600 transition"
        >
          Envoyer
        </button>
      </div>
    </div>
  </div>

  <script>
    const statusForm = document.getElementById('status-form')
    statusForm?.addEventListener('submit', (e) => {
      e.preventDefault()
      // TODO: appeler l'API backend pour changer le statut
      alert('Fonctionnalité disponible après intégration du backend Laravel.')
    })

    const commentBtn = document.getElementById('add-comment-btn')
    commentBtn?.addEventListener('click', () => {
      const textarea = document.getElementById('new-comment') as HTMLTextAreaElement
      if (!textarea.value.trim()) return
      // TODO: appeler l'API backend pour ajouter le commentaire
      alert('Fonctionnalité disponible après intégration du backend Laravel.')
    })

    const sendBtn = document.getElementById('send-message-btn')
    sendBtn?.addEventListener('click', () => {
      const input = document.getElementById('message-input') as HTMLInputElement
      if (!input.value.trim()) return
      // TODO: appeler l'API backend pour envoyer le message
      alert('Fonctionnalité disponible après intégration du backend Laravel.')
    })
  </script>
</DashboardLayout>
