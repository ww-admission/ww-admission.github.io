---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import { backendFetch } from '../../lib/auth'
import { STATUS_LABELS, STATUS_COLORS, formatDateTime, type CandidatureStatus } from '../../lib/mock-data'

const session = Astro.locals.session!

let stats = { total: 0, pending: 0, reviewing: 0, accepted: 0, rejected: 0, on_hold: 0 }
let recent: any[] = []
let unreadMessages = 0

try {
  const [statsResp, candsResp, convsResp] = await Promise.all([
    backendFetch('/candidatures/stats', session),
    backendFetch('/candidatures?page=1', session),
    backendFetch('/conversations', session),
  ])
  if (statsResp.ok)  stats = await statsResp.json()
  if (candsResp.ok)  { const d = await candsResp.json(); recent = (d.data ?? d).slice(0, 5) }
  if (convsResp.ok)  { const c: any[] = await convsResp.json(); unreadMessages = c.reduce((n, cv) => n + (cv.unreadCount ?? 0), 0) }
} catch {}
---

<DashboardLayout title="Tableau de bord" activeNav="overview">
  <div class="p-6 lg:p-8 max-w-6xl mx-auto space-y-8">

    <!-- En-tête -->
    <div class="flex items-end justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Bienvenue</p>
        <h1 class="font-headings text-2xl font-bold text-neutral-800 dark:text-neutral-100">{session.name}</h1>
      </div>
      <p class="text-sm text-neutral-400 hidden sm:block">
        {new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' })}
      </p>
    </div>

    <!-- ── Statistiques ──────────────────────────────────────────── -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

      <!-- Total -->
      <div class="bg-white border border-neutral-100 rounded p-5 group dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex items-start justify-between mb-3">
          <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400">Total</p>
          <span class="h-8 w-8 rounded bg-neutral-50 flex items-center justify-center dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </span>
        </div>
        <p class="font-headings text-3xl font-bold text-neutral-800 dark:text-neutral-100">{stats.total}</p>
        <p class="text-xs text-neutral-400 mt-1">Candidatures</p>
      </div>

      <!-- En attente -->
      <div class="bg-white border border-neutral-100 rounded p-5 border-t-2 border-t-gold-500 dark:bg-neutral-900 dark:border-neutral-800 dark:border-t-gold-500">
        <div class="flex items-start justify-between mb-3">
          <p class="text-xs font-semibold uppercase tracking-widest text-gold-700 dark:text-gold-400">En attente</p>
          <span class="h-8 w-8 rounded bg-gold-50 flex items-center justify-center dark:bg-gold-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gold-600 dark:text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
        </div>
        <p class="font-headings text-3xl font-bold text-gold-700 dark:text-gold-400">{stats.pending}</p>
        <p class="text-xs text-gold-600/70 dark:text-gold-500/70 mt-1">À traiter</p>
      </div>

      <!-- En examen -->
      <div class="bg-white border border-neutral-100 rounded p-5 border-t-2 border-t-primary-500 dark:bg-neutral-900 dark:border-neutral-800 dark:border-t-primary-500">
        <div class="flex items-start justify-between mb-3">
          <p class="text-xs font-semibold uppercase tracking-widest text-primary-600 dark:text-primary-400">En examen</p>
          <span class="h-8 w-8 rounded bg-primary-50 flex items-center justify-center dark:bg-primary-950">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </span>
        </div>
        <p class="font-headings text-3xl font-bold text-primary-500">{stats.reviewing}</p>
        <p class="text-xs text-primary-400 mt-1">En cours</p>
      </div>

      <!-- Acceptées -->
      <div class="bg-white border border-neutral-100 rounded p-5 border-t-2 border-t-neutral-300 dark:bg-neutral-900 dark:border-neutral-800 dark:border-t-neutral-600">
        <div class="flex items-start justify-between mb-3">
          <p class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Acceptées</p>
          <span class="h-8 w-8 rounded bg-neutral-50 flex items-center justify-center dark:bg-neutral-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
        </div>
        <p class="font-headings text-3xl font-bold text-neutral-700 dark:text-neutral-300">{stats.accepted}</p>
        <p class="text-xs text-neutral-400 mt-1">Validées</p>
      </div>
    </div>

    <!-- ── Contenu principal ─────────────────────────────────────── -->
    <div class="grid lg:grid-cols-3 gap-6">

      <!-- Candidatures récentes -->
      <div class="lg:col-span-2 bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
        <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-50 dark:border-neutral-800">
          <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Candidatures récentes</h2>
          <a href="/admin/candidatures" class="text-xs font-semibold text-primary-500 hover:text-primary-600 transition-colors">
            Voir tout →
          </a>
        </div>

        {recent.length === 0 ? (
          <div class="py-14 text-center">
            <p class="text-sm text-neutral-400">Aucune candidature pour le moment</p>
          </div>
        ) : (
          <ul>
            {recent.map((c: any) => (
              <li class="border-b border-neutral-100 last:border-0 dark:border-neutral-800">
                <a
                  href={`/admin/candidatures/${c.id}`}
                  class="flex items-center gap-4 px-5 py-2.5 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors group"
                >
                  <div class="h-9 w-9 rounded-full bg-primary-50 flex items-center justify-center shrink-0 dark:bg-primary-950">
                    <span class="text-sm font-bold text-primary-500 dark:text-primary-400">{(c.candidateName ?? '?').charAt(0)}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200 truncate group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{c.candidateName}</p>
                    <p class="text-xs text-neutral-400 truncate mt-0.5">{c.destination} · {c.programme}</p>
                  </div>
                  <div class="shrink-0 text-right">
                    <span class={`inline-block rounded-full px-2.5 py-1 text-xs font-medium ${STATUS_COLORS[c.status as CandidatureStatus] ?? 'bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-400'}`}>
                      {STATUS_LABELS[c.status as CandidatureStatus] ?? c.status}
                    </span>
                    <p class="text-xs text-neutral-300 dark:text-neutral-600 mt-1">{formatDateTime(c.submittedAt)}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Panneau latéral -->
      <div class="space-y-4">

        <!-- Accès rapide -->
        <div class="bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
          <div class="px-5 py-4 border-b border-neutral-50 dark:border-neutral-800">
            <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Actions rapides</h2>
          </div>
          <nav class="p-3 space-y-0.5">
            {[
              { href: '/admin/candidatures', label: 'Gérer les candidatures', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
              { href: '/admin/messages',     label: 'Messages',               icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
              { href: '/admin/logs',         label: "Logs d'activité",        icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
            ].map(link => (
              <a href={link.href} class="flex items-center gap-3 rounded px-3 py-2.5 text-sm text-neutral-500 hover:bg-neutral-50 hover:text-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100 transition-colors group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 group-hover:text-primary-400 dark:text-neutral-500 dark:group-hover:text-primary-400 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d={link.icon}/>
                </svg>
                {link.label}
                {link.href === '/admin/messages' && unreadMessages > 0 && (
                  <span class="ml-auto inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-primary-500 px-1.5 text-[10px] font-bold text-white">
                    {unreadMessages}
                  </span>
                )}
              </a>
            ))}
          </nav>
        </div>

        <!-- Alerte messages non lus -->
        {unreadMessages > 0 && (
          <div class="rounded border border-primary-100 bg-primary-50 px-5 py-4 dark:bg-primary-950 dark:border-primary-900">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 h-2 w-2 rounded-full bg-primary-500 shrink-0 animate-pulse"></span>
              <div>
                <p class="text-sm font-semibold text-primary-700 dark:text-primary-300">
                  {unreadMessages} message{unreadMessages > 1 ? 's' : ''} non lu{unreadMessages > 1 ? 's' : ''}
                </p>
                <a href="/admin/messages" class="text-xs text-primary-500 hover:text-primary-600 font-medium mt-1 inline-block transition-colors">
                  Consulter la messagerie →
                </a>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</DashboardLayout>
