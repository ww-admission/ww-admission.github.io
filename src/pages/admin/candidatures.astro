---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import {
  MOCK_CANDIDATURES,
  STATUS_LABELS,
  STATUS_COLORS,
  formatDate,
  type CandidatureStatus,
} from '../../lib/mock-data'



// Filtrage par statut géré côté client (window.location.search)
const filtered = MOCK_CANDIDATURES
---

<DashboardLayout title="Candidatures" activeNav="candidatures">
  <div class="p-6 max-w-7xl mx-auto space-y-5">

    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <div>
        <h1 class="text-2xl font-headings font-semibold text-neutral-700">Candidatures</h1>
        <p class="text-sm text-neutral-400 mt-0.5">{filtered.length} candidature{filtered.length !== 1 ? 's' : ''}</p>
      </div>
    </div>

    <!-- Filtres statut -->
    <div class="flex flex-wrap gap-2">
      {(['all', 'pending', 'reviewing', 'accepted', 'rejected', 'on_hold'] as const).map(s => (
        <a
          href={s === 'all' ? '/admin/candidatures' : `/admin/candidatures?status=${s}`}
          class={`rounded-full px-3.5 py-1.5 text-xs font-medium border transition ${
            statusFilter === s
              ? 'bg-primary-500 text-white border-primary-500'
              : 'bg-white text-neutral-600 border-neutral-200 hover:border-primary-300 hover:text-primary-600'
          }`}
        >
          {s === 'all' ? 'Toutes' : STATUS_LABELS[s as CandidatureStatus]}
        </a>
      ))}
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl border border-neutral-100 overflow-hidden">
      {filtered.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 text-neutral-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-sm">Aucune candidature pour ce filtre</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-neutral-50">
                <th class="text-left text-xs font-semibold text-neutral-400 uppercase tracking-wide px-5 py-3.5">Candidat</th>
                <th class="text-left text-xs font-semibold text-neutral-400 uppercase tracking-wide px-4 py-3.5 hidden sm:table-cell">Destination</th>
                <th class="text-left text-xs font-semibold text-neutral-400 uppercase tracking-wide px-4 py-3.5 hidden md:table-cell">Programme</th>
                <th class="text-left text-xs font-semibold text-neutral-400 uppercase tracking-wide px-4 py-3.5">Statut</th>
                <th class="text-left text-xs font-semibold text-neutral-400 uppercase tracking-wide px-4 py-3.5 hidden lg:table-cell">Date</th>
                <th class="px-4 py-3.5"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-50">
              {filtered.map(c => (
                <tr class="hover:bg-neutral-50/60 transition">
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <div class="h-8 w-8 rounded-full bg-neutral-100 flex items-center justify-center shrink-0 text-xs font-semibold text-neutral-600">
                        {c.candidateName.charAt(0)}
                      </div>
                      <div>
                        <p class="font-medium text-neutral-700">{c.candidateName}</p>
                        <p class="text-xs text-neutral-400">{c.candidateEmail}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-4 hidden sm:table-cell text-neutral-600">{c.destination}</td>
                  <td class="px-4 py-4 hidden md:table-cell text-neutral-600 max-w-[200px] truncate">{c.programme}</td>
                  <td class="px-4 py-4">
                    <span class={`inline-block rounded-full px-2.5 py-1 text-xs font-medium ${STATUS_COLORS[c.status as CandidatureStatus]}`}>
                      {STATUS_LABELS[c.status as CandidatureStatus]}
                    </span>
                  </td>
                  <td class="px-4 py-4 hidden lg:table-cell text-neutral-400 text-xs">{formatDate(c.submittedAt)}</td>
                  <td class="px-4 py-4">
                    <a
                      href={`/admin/candidatures/${c.id}`}
                      class="text-xs font-medium text-primary-500 hover:text-primary-600 transition whitespace-nowrap"
                    >
                      Voir →
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
