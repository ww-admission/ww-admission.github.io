---
import Layout from '../../layouts/Layout.astro'
import BasicDark from '../../components/blocks/CTA/BasicDark.astro'
import { backendFetch } from '../../lib/auth'
import { MOCK_FORMATIONS } from '../../lib/mock-formations-data'
import { MOCK_PAYS, MOCK_NIVEAUX_ETUDE } from '../../lib/mock-universites-data'
import type { Formation } from '../../lib/catalogue-types'

const q          = Astro.url.searchParams.get('q')?.trim() ?? ''
const paysSlug   = Astro.url.searchParams.get('pays') ?? ''
const niveauSlug = Astro.url.searchParams.get('niveau') ?? ''
const uniSlug    = Astro.url.searchParams.get('universite') ?? ''

let formations: Formation[] = []
let useMock = false

try {
  const qs = new URLSearchParams()
  if (q)          qs.set('q', q)
  if (paysSlug)   qs.set('pays', paysSlug)
  if (niveauSlug) qs.set('niveau', niveauSlug)
  if (uniSlug)    qs.set('universite', uniSlug)
  const resp = await backendFetch(`/formations?${qs}`, null)
  if (resp.ok) {
    const d = await resp.json() as { data?: Formation[] } | Formation[]
    formations = Array.isArray(d) ? d : (d.data ?? [])
  } else {
    useMock = true
  }
} catch {
  useMock = true
}

if (useMock) {
  const qLow = q.toLowerCase()
  formations = MOCK_FORMATIONS
    .filter(f => f.est_publie)
    .filter(f => !q          || f.nom.toLowerCase().includes(qLow) || f.description_courte?.toLowerCase().includes(qLow) || f.universite.nom.toLowerCase().includes(qLow))
    .filter(f => !paysSlug   || f.universite.pays.slug === paysSlug)
    .filter(f => !niveauSlug || f.niveau_etude.slug === niveauSlug)
    .filter(f => !uniSlug    || f.universite.slug === uniSlug)
}

const vedettes    = formations.filter(f => f.est_vedette)
const nonVedettes = formations.filter(f => !f.est_vedette)
const total       = formations.length

function formatDuree(mois: number | undefined): string {
  if (!mois) return ''
  if (mois % 12 === 0) return `${mois / 12} an${mois / 12 > 1 ? 's' : ''}`
  return `${mois} mois`
}
---

<Layout title="Formations disponibles - WorldWise Admission" description="Parcourez toutes nos formations en Licence, Master et Doctorat dans nos universités partenaires. Médecine, ingénierie, management, droit et bien plus.">

  <!-- Hero -->
  <section class="bg-white dark:bg-neutral-900 border-b border-neutral-100 dark:border-neutral-800">
    <div class="container mx-auto px-6 py-12 sm:py-16">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-gold-600 dark:text-gold-400 tracking-widest uppercase mb-3">
          Catalogue
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">
          Toutes les formations
        </h1>
        <p class="text-lg text-neutral-500 dark:text-neutral-400 leading-relaxed">
          Licences, Masters et Doctorats proposés par nos universités partenaires en Chine, au Ghana et en Russie.
          Chaque programme inclut les frais, la durée et la langue d'enseignement.
        </p>
      </div>
    </div>
  </section>

  <!-- Filtres -->
  <section class="bg-neutral-50 dark:bg-neutral-950 border-b border-neutral-100 dark:border-neutral-800">
    <div class="container mx-auto px-6 py-3">
      <form method="GET" action="/formations" class="flex flex-wrap gap-2 items-center">

        <!-- Recherche -->
        <div class="relative flex-1 min-w-[200px]">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400 dark:text-neutral-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="search"
            name="q"
            value={q}
            placeholder="Rechercher une formation, spécialité…"
            class="w-full pl-9 pr-3 py-2 text-sm bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-neutral-700 dark:text-neutral-200 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-amber-400"
          />
        </div>

        <!-- Pays -->
        <select
          name="pays"
          class="py-2 pl-3 pr-8 text-sm bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-neutral-700 dark:text-neutral-200 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <option value="">Tous les pays</option>
          {MOCK_PAYS.map(p => (
            <option value={p.slug} selected={paysSlug === p.slug}>
              {p.drapeau} {p.nom}
            </option>
          ))}
        </select>

        <!-- Niveau -->
        <select
          name="niveau"
          class="py-2 pl-3 pr-8 text-sm bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-neutral-700 dark:text-neutral-200 focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          <option value="">Tous les niveaux</option>
          {MOCK_NIVEAUX_ETUDE.map(n => (
            <option value={n.slug} selected={niveauSlug === n.slug}>
              {n.nom}
            </option>
          ))}
        </select>

        <button
          type="submit"
          class="px-4 py-2 text-sm font-medium bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400"
        >
          Filtrer
        </button>

        {(q || paysSlug || niveauSlug || uniSlug) && (
          <a
            href="/formations"
            class="px-3 py-2 text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200 transition-colors"
          >
            Réinitialiser
          </a>
        )}

        <!-- View toggle -->
        <div class="ml-auto flex items-center gap-1 border border-neutral-200 dark:border-neutral-700 rounded-lg p-1 bg-white dark:bg-neutral-800">
          <button type="button" id="view-grid" aria-label="Vue grille"
            class="p-1.5 rounded text-neutral-500 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
            </svg>
          </button>
          <button type="button" id="view-list" aria-label="Vue liste"
            class="p-1.5 rounded text-neutral-500 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Contenu -->
  <section class="bg-neutral-50 dark:bg-neutral-950">
    <div class="container mx-auto px-6 py-8">

      {total === 0 ? (
        <div class="flex flex-col items-center justify-center py-24 text-center">
          <div class="w-16 h-16 rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
            </svg>
          </div>
          <p class="text-neutral-600 dark:text-neutral-400 font-medium mb-1">Aucune formation trouvée</p>
          <p class="text-sm text-neutral-400 dark:text-neutral-500">
            Essayez d'autres filtres ou <a href="/formations" class="text-primary-600 dark:text-primary-400 underline">réinitialisez</a>.
          </p>
        </div>
      ) : (
        <>
          <!-- Formations vedettes -->
          {vedettes.length > 0 && (
            <div class="mb-10">
              <h2 class="text-xs font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-4">
                À la une
              </h2>
              <div id="f-grid-vedettes" class="flex flex-wrap gap-4">
                {vedettes.map(f => (
                  <a
                    href={`/formations/${f.slug}`}
                    class="group block bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 overflow-hidden hover:shadow-lg hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-200"
                    style="width:360px;flex-shrink:0"
                  >
                    <!-- Header -->
                    <div class="h-20 relative overflow-hidden bg-neutral-900">
                      {f.couverture_image_url ? (
                        <img src={f.couverture_image_url} alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                      ) : (
                        <div class={`absolute inset-0 flex items-center justify-center ${f.universite.couleur_bg}`}>
                          <span class="text-4xl font-black text-white/15 select-none">{f.universite.initiales}</span>
                        </div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent" />
                      <div class="absolute bottom-3 left-3 flex items-center gap-2">
                        <span class="text-xs font-medium text-white/90 bg-white/20 backdrop-blur-sm px-2 py-0.5 rounded-full">
                          {f.universite.initiales}
                        </span>
                        <span class="text-xs text-white/70">{f.universite.pays.drapeau} {f.universite.ville}</span>
                      </div>
                      <span class="absolute top-3 right-3 text-xs font-semibold bg-white/20 text-white px-2 py-0.5 rounded-full backdrop-blur-sm">
                        À la une
                      </span>
                    </div>
                    <!-- Info -->
                    <div class="p-4">
                      <div class="mb-2">
                        <span class="inline-block text-xs font-medium bg-gold-100 dark:bg-gold-900/40 text-gold-800 dark:text-gold-300 px-2 py-0.5 rounded-full mb-2">
                          {f.niveau_etude.nom}
                        </span>
                        <h3 class="text-base font-medium text-neutral-800 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2">
                          {f.nom}
                        </h3>
                      </div>
                      <p class="text-xs text-neutral-400 dark:text-neutral-500 mb-3">{f.universite.nom}</p>
                      {f.description_courte && (
                        <p class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-2 mb-4">{f.description_courte}</p>
                      )}
                      <div class="flex flex-wrap gap-x-4 gap-y-1 pt-3 border-t border-neutral-100 dark:border-neutral-800">
                        {f.duree_mois && (
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {formatDuree(f.duree_mois)}
                          </span>
                        )}
                        {f.frais_scolarite && (
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {f.frais_scolarite.toLocaleString('fr-FR')} {f.devise}/an
                          </span>
                        )}
                        <span class="ml-auto text-xs font-medium text-primary-600 dark:text-primary-400 group-hover:underline">
                          Voir →
                        </span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Toutes les formations -->
          {nonVedettes.length > 0 && (
            <div>
              {vedettes.length > 0 && (
                <h2 class="text-xs font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-4">
                  Toutes les formations ({total})
                </h2>
              )}

              <!-- Vue grille -->
              <div id="f-grid-all" class="flex flex-wrap gap-4">
                {nonVedettes.map(f => (
                  <a
                    href={`/formations/${f.slug}`}
                    class="group block bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 overflow-hidden hover:shadow-lg hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-200"
                    style="width:360px;flex-shrink:0"
                  >
                    <div class="h-20 relative overflow-hidden bg-neutral-900">
                      {f.couverture_image_url ? (
                        <img src={f.couverture_image_url} alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                      ) : (
                        <div class={`absolute inset-0 flex items-center justify-center ${f.universite.couleur_bg}`}>
                          <span class="text-4xl font-black text-white/15 select-none">{f.universite.initiales}</span>
                        </div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent" />
                      <div class="absolute bottom-3 left-3 flex items-center gap-2">
                        <span class="text-xs font-medium text-white/90 bg-white/20 backdrop-blur-sm px-2 py-0.5 rounded-full">
                          {f.universite.initiales}
                        </span>
                        <span class="text-xs text-white/70">{f.universite.pays.drapeau} {f.universite.ville}</span>
                      </div>
                    </div>
                    <div class="p-4">
                      <div class="mb-2">
                        <span class="inline-block text-xs font-medium bg-gold-100 dark:bg-gold-900/40 text-gold-800 dark:text-gold-300 px-2 py-0.5 rounded-full mb-2">
                          {f.niveau_etude.nom}
                        </span>
                        <h3 class="text-base font-medium text-neutral-800 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2">
                          {f.nom}
                        </h3>
                      </div>
                      <p class="text-xs text-neutral-400 dark:text-neutral-500 mb-3">{f.universite.nom}</p>
                      {f.description_courte && (
                        <p class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-2 mb-4">{f.description_courte}</p>
                      )}
                      <div class="flex flex-wrap gap-x-4 gap-y-1 pt-3 border-t border-neutral-100 dark:border-neutral-800">
                        {f.duree_mois && (
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {formatDuree(f.duree_mois)}
                          </span>
                        )}
                        {f.frais_scolarite && (
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {f.frais_scolarite.toLocaleString('fr-FR')} {f.devise}/an
                          </span>
                        )}
                        <span class="ml-auto text-xs font-medium text-primary-600 dark:text-primary-400 group-hover:underline">
                          Voir →
                        </span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>

              <!-- Vue liste -->
              <div id="f-list-all" class="hidden flex-col gap-2">
                {nonVedettes.map(f => (
                  <a
                    href={`/formations/${f.slug}`}
                    class="group flex items-center gap-4 bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 p-4 hover:shadow-md hover:border-primary-200 dark:hover:border-primary-800 transition-all duration-200"
                  >
                    <div class={`w-12 h-12 rounded-lg flex-shrink-0 flex items-center justify-center ${f.universite.couleur_bg}`}>
                      <span class="text-xs font-black text-white/80">{f.universite.initiales}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-base font-medium text-neutral-800 dark:text-neutral-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                          {f.nom}
                        </span>
                        <span class="text-xs bg-gold-100 dark:bg-gold-900/40 text-gold-800 dark:text-gold-300 px-2 py-0.5 rounded-full font-medium">
                          {f.niveau_etude.nom}
                        </span>
                      </div>
                      <div class="flex items-center gap-3 mt-0.5 text-sm text-neutral-400 dark:text-neutral-500 flex-wrap">
                        <span>{f.universite.pays.drapeau} {f.universite.nom}</span>
                        {f.duree_mois && <><span>·</span><span>{formatDuree(f.duree_mois)}</span></>}
                        {f.frais_scolarite && <><span>·</span><span>{f.frais_scolarite.toLocaleString('fr-FR')} {f.devise}/an</span></>}
                      </div>
                    </div>
                    <svg class="w-4 h-4 text-neutral-300 dark:text-neutral-600 group-hover:text-primary-500 dark:group-hover:text-primary-400 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )}

        </>
      )}
    </div>
  </section>

  <BasicDark />
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnGrid = document.getElementById('view-grid')
    const btnList = document.getElementById('view-list')
    const grids   = document.querySelectorAll<HTMLElement>('#f-grid-vedettes, #f-grid-all')
    const lists   = document.querySelectorAll<HTMLElement>('#f-list-all')

    const savedView = localStorage.getItem('wwa_directory_view') ?? 'grid'

    const applyView = (view: string) => {
      const isGrid = view === 'grid'
      grids.forEach(el => {
        el.classList.toggle('hidden', !isGrid)
        el.classList.toggle('flex', isGrid)
      })
      lists.forEach(el => {
        el.classList.toggle('hidden', isGrid)
        el.classList.toggle('flex', !isGrid)
      })
      btnGrid?.classList.toggle('bg-neutral-100', isGrid)
      btnGrid?.classList.toggle('dark:bg-neutral-700', isGrid)
      btnGrid?.classList.toggle('text-neutral-700', isGrid)
      btnGrid?.classList.toggle('dark:text-neutral-200', isGrid)
      btnList?.classList.toggle('bg-neutral-100', !isGrid)
      btnList?.classList.toggle('dark:bg-neutral-700', !isGrid)
      btnList?.classList.toggle('text-neutral-700', !isGrid)
      btnList?.classList.toggle('dark:text-neutral-200', !isGrid)
    }

    applyView(savedView)

    btnGrid?.addEventListener('click', () => {
      localStorage.setItem('wwa_directory_view', 'grid')
      applyView('grid')
    })
    btnList?.addEventListener('click', () => {
      localStorage.setItem('wwa_directory_view', 'list')
      applyView('list')
    })
  })
</script>
