---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import Pagination from '../../components/ui/Pagination.astro'
import {
  MOCK_COMMUNITY,
  DESTINATION_FLAGS,
  MEMBER_STATUS_LABELS,
  MEMBER_STATUS_COLORS,
  type CommunityMember,
  type MemberStatus,
} from '../../lib/contacts-data'
import { backendFetch } from '../../lib/auth'

const session = Astro.locals.session!

const page    = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10))
const perPage = (() => {
  const v = parseInt(Astro.url.searchParams.get('per_page') ?? '30', 10)
  return [30, 50, 100].includes(v) ? v : 30
})()

const AVATAR_COLORS = [
  'bg-primary-500', 'bg-primary-700', 'bg-gold-600',
  'bg-neutral-500', 'bg-neutral-600', 'bg-neutral-700',
]

function normalizeServerMember(raw: any, idx: number): CommunityMember {
  const parts = (raw.name ?? '').trim().split(' ')
  const initials = ((parts[0]?.[0] ?? '') + (parts[1]?.[0] ?? '')).toUpperCase() || '?'
  return {
    id:               String(raw.id),
    name:             raw.name ?? '',
    initials,
    avatarColor:      AVATAR_COLORS[idx % AVATAR_COLORS.length],
    nationality:      raw.nationality ?? '—',
    status:           raw.status as MemberStatus,
    destination:      raw.destination ?? '—',
    destinationFlag:  DESTINATION_FLAGS[raw.destination] ?? '🌍',
    city:             raw.city ?? undefined,
    university:       raw.university ?? undefined,
    domain:           raw.domain ?? '—',
    programme:        raw.programme ?? undefined,
    studyYear:        raw.study_year ?? undefined,
    graduationYear:   raw.graduation_year ?? undefined,
    bio:              raw.bio ?? undefined,
    languages:        raw.languages ?? undefined,
    lookingFor:       raw.looking_for ?? undefined,
    isVerified:       Boolean(raw.is_verified),
    joinedAt:         raw.created_at ?? new Date().toISOString(),
    linkedinUrl:      raw.linkedin_url ?? undefined,
    isPublic:         Boolean(raw.is_community_public),
  }
}

let allMembers: CommunityMember[] = []
let meta = { total: 0, current_page: page, last_page: 1, per_page: perPage }
let useMock = false

try {
  const qs   = new URLSearchParams({ page: String(page), per_page: String(perPage) })
  const resp = await backendFetch(`/community?${qs}`, session)
  if (resp.ok) {
    const d   = await resp.json()
    const raw = (d.data ?? d) as any[]
    allMembers = raw.map((m, i) => normalizeServerMember(m, i))
    meta = {
      total:        d.meta?.total ?? d.total ?? allMembers.length,
      current_page: d.meta?.current_page ?? d.current_page ?? page,
      last_page:    d.meta?.last_page ?? d.last_page ?? 1,
      per_page:     d.meta?.per_page ?? d.per_page ?? perPage,
    }
  } else {
    useMock = true
  }
} catch {
  useMock = true
}

if (useMock) {
  const mockFiltered = MOCK_COMMUNITY.filter(m => m.isPublic)
  allMembers = mockFiltered
  meta = {
    total:        mockFiltered.length,
    current_page: page,
    last_page:    Math.max(1, Math.ceil(mockFiltered.length / perPage)),
    per_page:     perPage,
  }
}

const stats = {
  total:       meta.total,
  studying:    allMembers.filter(m => m.status === 'studying').length,
  alumni:      allMembers.filter(m => m.status === 'alumni').length,
  candidature: allMembers.filter(m => m.status === 'candidature').length,
}
const destinations = ['Toutes', ...new Set(allMembers.map(m => m.destination))]
const domains      = ['Tous', ...new Set(allMembers.map(m => m.domain))].sort()
const universities = ['Toutes', ...new Set(allMembers.filter(m => m.university).map(m => m.university!))]
const members = useMock ? allMembers.slice((page - 1) * perPage, page * perPage) : allMembers
---

<DashboardLayout title="Communauté" activeNav="community">

  <!-- Données pour le script client -->
  <script is:inline define:vars={{ membersData: allMembers }}>
    window.__COMMUNITY_MEMBERS__ = membersData
  </script>

  <div class="p-6 lg:p-8 max-w-6xl mx-auto space-y-6">

    <!-- En-tête + stats -->
    <div class="flex flex-col sm:flex-row sm:items-end gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Réseau</p>
        <h1 class="font-headings text-2xl font-bold text-neutral-800 dark:text-neutral-100">Communauté</h1>
        <p class="text-sm text-neutral-400 mt-1">Connecte-toi avec des étudiants du monde entier accompagnés par WWA.</p>
      </div>

      <!-- Compteurs rapides -->
      <div class="sm:ml-auto flex items-center gap-4 flex-wrap text-center">
        <div>
          <p class="font-headings text-2xl font-bold text-neutral-800 dark:text-neutral-100">{stats.total}</p>
          <p class="text-[10px] font-semibold uppercase tracking-wider text-neutral-400">Membres</p>
        </div>
        <div class="h-6 w-px bg-neutral-200 dark:bg-neutral-700 hidden sm:block"></div>
        <div>
          <p class="font-headings text-2xl font-bold text-green-600">{stats.studying}</p>
          <p class="text-[10px] font-semibold uppercase tracking-wider text-neutral-400">En études</p>
        </div>
        <div class="h-6 w-px bg-neutral-200 dark:bg-neutral-700 hidden sm:block"></div>
        <div>
          <p class="font-headings text-2xl font-bold text-purple-600">{stats.alumni}</p>
          <p class="text-[10px] font-semibold uppercase tracking-wider text-neutral-400">Alumni</p>
        </div>
      </div>
    </div>

    <!-- Filtres & recherche -->
    <div class="bg-white border border-neutral-100 rounded p-4 space-y-4 dark:bg-neutral-900 dark:border-neutral-800">
      <!-- Ligne 1: Recherche -->
      <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M16.65 16.65A7.5 7.5 0 1010 17.5a7.5 7.5 0 006.65-.85z"/>
          </svg>
        </div>
        <input
          id="community-search"
          type="text"
          autocomplete="off"
          placeholder="Rechercher par nom, université, ville, domaine…"
          class="h-10 w-full rounded border border-neutral-200 bg-white pl-9 pr-4 text-sm text-neutral-700 placeholder-neutral-400 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200 dark:placeholder-neutral-500"
        />
      </div>

      <!-- Ligne 2: Filtres statut -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mr-1">Statut</span>
        {(['all', 'candidature', 'studying', 'alumni'] as const).map(s => (
          <button
            data-status-filter={s}
            class={`status-filter-btn inline-flex items-center rounded-full border px-3.5 py-1.5 text-xs font-semibold transition-all ${
              s === 'all'
                ? 'bg-primary-500 border-primary-500 text-white'
                : 'bg-white border-neutral-200 text-neutral-500 hover:border-primary-300 hover:text-primary-600 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400'
            }`}
          >
            {s === 'all' ? 'Tous' : MEMBER_STATUS_LABELS[s as MemberStatus]}
          </button>
        ))}
      </div>

      <!-- Ligne 3: Filtres avancés -->
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold uppercase tracking-widest text-neutral-400">Destination</span>
          <select id="filter-destination" class="h-8 rounded border border-neutral-200 bg-white px-2.5 text-xs text-neutral-600 outline-none focus:border-amber-400 transition cursor-pointer dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300">
            {destinations.map(d => <option value={d}>{d}</option>)}
          </select>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold uppercase tracking-widest text-neutral-400">Domaine</span>
          <select id="filter-domain" class="h-8 rounded border border-neutral-200 bg-white px-2.5 text-xs text-neutral-600 outline-none focus:border-amber-400 transition cursor-pointer dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300">
            {domains.map(d => <option value={d}>{d}</option>)}
          </select>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold uppercase tracking-widests text-neutral-400">Université</span>
          <select id="filter-university" class="h-8 rounded border border-neutral-200 bg-white px-2.5 text-xs text-neutral-600 outline-none focus:border-amber-400 transition cursor-pointer dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300">
            {universities.map(u => <option value={u}>{u}</option>)}
          </select>
        </div>
        <button id="reset-filters" class="ml-auto text-xs text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors">
          Réinitialiser les filtres
        </button>
      </div>
    </div>

    <!-- Compteur résultats -->
    <div class="flex items-center justify-between">
      <p id="result-count" class="text-xs text-neutral-400">
        <span class="font-semibold text-neutral-600 dark:text-neutral-300">{members.length}</span> membre{members.length > 1 ? 's' : ''}
      </p>
    </div>

    <!-- Grille membres -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="community-grid">
      {members.map((m) => (
        <div
          class="member-card group relative flex flex-col bg-white border border-neutral-100 rounded overflow-hidden cursor-pointer hover:border-primary-200 hover:shadow-sm transition-all dark:bg-neutral-900 dark:border-neutral-800 dark:hover:border-primary-700"
          data-id={m.id}
          data-status={m.status}
          data-destination={m.destination}
          data-domain={m.domain}
          data-university={m.university ?? ''}
          data-search={[m.name, m.destination, m.city ?? '', m.university ?? '', m.domain, m.programme ?? '', m.nationality, m.status, MEMBER_STATUS_LABELS[m.status]].join(' ').toLowerCase()}
        >
          <!-- Bande couleur statut -->
          <div class={`h-1 ${m.status === 'studying' ? 'bg-primary-400' : m.status === 'alumni' ? 'bg-neutral-300' : 'bg-gold-400'}`}></div>

          <div class="p-5 flex flex-col gap-3 flex-1">
            <!-- Header -->
            <div class="flex items-start gap-3">
              <div class={`relative h-11 w-11 rounded-full ${m.avatarColor} flex items-center justify-center shrink-0 shadow-sm`}>
                <span class="text-sm font-bold text-white">{m.initials}</span>
                {m.isVerified && (
                  <span class="absolute -bottom-0.5 -right-0.5 h-4 w-4 rounded-full bg-white dark:bg-neutral-800 flex items-center justify-center shadow-sm" title="Profil vérifié">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-primary-500" viewBox="0 0 24 24" fill="currentColor">
                      <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.498-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" />
                    </svg>
                  </span>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-100 truncate group-hover:text-primary-600 transition-colors">{m.name}</p>
                <p class="text-xs text-neutral-400 truncate">{m.nationality}</p>
              </div>
            </div>

            <!-- Destination + domaine -->
            <div class="space-y-1.5">
              <div class="flex items-center gap-2 text-xs text-neutral-600 dark:text-neutral-300">
                <span class="text-base leading-none">{m.destinationFlag}</span>
                <span class="font-medium">{m.destination}</span>
                {m.city && <span class="text-neutral-400">· {m.city}</span>}
              </div>
              <div class="flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                </svg>
                <span class="truncate">{m.domain}{m.programme ? ` · ${m.programme}` : ''}</span>
              </div>
              {m.university && (
                <div class="flex items-center gap-1.5 text-xs text-neutral-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                  </svg>
                  <span class="truncate">{m.university}</span>
                </div>
              )}
            </div>

            <!-- Badge statut + année -->
            <div class="flex items-center gap-2 flex-wrap">
              <span class={`inline-flex items-center text-[10px] font-bold uppercase tracking-wide rounded-full border px-2 py-0.5 ${MEMBER_STATUS_COLORS[m.status]}`}>
                {MEMBER_STATUS_LABELS[m.status]}
              </span>
              {m.studyYear && <span class="text-[10px] text-neutral-400">{m.studyYear}</span>}
              {m.graduationYear && <span class="text-[10px] text-neutral-400">Diplômé(e) {m.graduationYear}</span>}
            </div>

            <!-- Je cherche -->
            {m.lookingFor && m.lookingFor.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {m.lookingFor.map(lf => (
                  <span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-2 py-0.5 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">{lf}</span>
                ))}
              </div>
            )}
          </div>

          <!-- Footer card -->
          <div class="shrink-0 border-t border-neutral-100 px-5 py-3 flex items-center justify-between bg-neutral-50/50 dark:bg-neutral-800/40 dark:border-neutral-800">
            <span class="text-xs text-neutral-400">
              Membre depuis {new Date(m.joinedAt).getFullYear()}
            </span>
            <span class="text-xs font-semibold text-primary-500 group-hover:text-primary-600 transition-colors">
              Voir le profil →
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Aucun résultat -->
    <div id="no-members" class="hidden py-20 text-center">
      <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-neutral-50 dark:bg-neutral-800 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-neutral-300 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
      <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400">Aucun membre trouvé</p>
      <p class="text-xs text-neutral-400 dark:text-neutral-500 mt-1">Essayez d'autres critères de recherche</p>
    </div>

    <!-- Pagination -->
    <Pagination
      currentPage={meta.current_page}
      lastPage={meta.last_page}
      total={meta.total}
      perPage={meta.per_page}
      baseUrl={Astro.url}
    />

  </div>

  <!-- ── Offcanvas profil membre ──────────────────────────────────────── -->
  <div
    id="member-panel"
    class="hidden fixed inset-y-0 right-0 z-40 flex-col w-full max-w-md bg-white border-l border-neutral-100 shadow-2xl shadow-neutral-900/10 dark:bg-neutral-900 dark:border-neutral-800 dark:shadow-neutral-950/60 transform translate-x-full transition-transform duration-300"
    role="dialog"
    aria-label="Profil membre"
  >
    <div class="shrink-0 flex items-center justify-between px-5 py-4 border-b border-neutral-100 dark:border-neutral-800">
      <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Profil</h2>
      <button id="panel-close" class="h-8 w-8 flex items-center justify-center rounded-full text-neutral-400 hover:text-neutral-700 hover:bg-neutral-50 dark:hover:text-neutral-200 dark:hover:bg-neutral-800 transition-all" aria-label="Fermer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div id="panel-body" class="flex-1 overflow-y-auto"></div>
  </div>
  <div id="panel-overlay" class="hidden fixed inset-0 z-30 bg-neutral-900/20 dark:bg-neutral-950/50 backdrop-blur-[2px]" aria-hidden="true"></div>

  <script>
    import type { CommunityMember } from '../../lib/contacts-data'

    const MEMBERS: CommunityMember[] = (window as any).__COMMUNITY_MEMBERS__ ?? []

    function esc(s: string) {
      return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
    }

    const STATUS_LABELS: Record<string,string> = {
      candidature: 'En candidature',
      studying: 'En études',
      alumni: 'Diplômé(e)',
    }
    const STATUS_COLORS: Record<string,string> = {
      candidature: 'bg-gold-100 text-gold-800 border-gold-200 dark:bg-gold-900/40 dark:text-gold-300 dark:border-gold-800',
      studying: 'bg-primary-100 text-primary-700 border-primary-200 dark:bg-primary-950 dark:text-primary-300 dark:border-primary-900',
      alumni: 'bg-neutral-100 text-neutral-600 border-neutral-200 dark:bg-neutral-800 dark:text-neutral-300 dark:border-neutral-700',
    }

    function renderMemberDetail(m: CommunityMember): string {
      const statusBar = m.status === 'studying' ? 'bg-green-400' : m.status === 'alumni' ? 'bg-purple-400' : 'bg-amber-400'
      const specs = (m.lookingFor ?? []).map(s => `<span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-2.5 py-1 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">${esc(s)}</span>`).join('')
      const langs = (m.languages ?? []).map(l => `<span class="text-[10px] rounded bg-neutral-50 border border-neutral-100 px-2.5 py-1 text-neutral-500 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-400">${esc(l)}</span>`).join('')

      return `
        <!-- Bande couleur -->
        <div class="h-1.5 ${statusBar}"></div>

        <!-- Header profil -->
        <div class="p-6 border-b border-neutral-100 dark:border-neutral-800">
          <div class="flex items-start gap-4 mb-5">
            <div class="relative ${m.avatarColor} h-18 w-18 h-[72px] w-[72px] rounded-full flex items-center justify-center shrink-0 shadow-md">
              <span class="text-2xl font-bold text-white">${esc(m.initials)}</span>
              ${m.isVerified ? `<span class="absolute -bottom-1 -right-1 h-5 w-5 rounded-full bg-white dark:bg-neutral-800 flex items-center justify-center shadow" title="Profil vérifié">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary-500" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.498-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" /></svg>
              </span>` : ''}
            </div>
            <div class="min-w-0 flex-1 pt-1">
              <h3 class="font-headings font-bold text-neutral-800 dark:text-neutral-100 text-lg leading-tight">${esc(m.name)}</h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-0.5">${esc(m.nationality)}</p>
              <span class="mt-2 inline-flex items-center text-[10px] font-bold uppercase tracking-wide rounded-full border px-2.5 py-0.5 ${STATUS_COLORS[m.status]??''}">
                ${STATUS_LABELS[m.status]??m.status}
              </span>
            </div>
          </div>

          <!-- Infos académiques -->
          <div class="rounded bg-neutral-50 border border-neutral-100 p-4 space-y-2 dark:bg-neutral-800/40 dark:border-neutral-700">
            <div class="flex items-center gap-2.5">
              <span class="text-xl leading-none">${esc(m.destinationFlag)}</span>
              <div>
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">${esc(m.destination)}${m.city ? ` · ${m.city}` : ''}</p>
                <p class="text-xs text-neutral-400">${esc(m.university ?? '—')}</p>
              </div>
            </div>
            <div class="flex items-center gap-2 text-xs text-neutral-600 dark:text-neutral-300 pt-1 border-t border-neutral-100 dark:border-neutral-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
              <span>${esc(m.domain)}${m.programme ? ` - ${m.programme}` : ''}</span>
            </div>
            ${m.studyYear ? `<p class="text-xs text-neutral-400 pl-5">${esc(m.studyYear)}</p>` : ''}
            ${m.graduationYear ? `<p class="text-xs text-neutral-400 pl-5">Diplômé(e) en ${esc(m.graduationYear)}</p>` : ''}
          </div>
        </div>

        ${m.bio ? `<!-- Bio -->
        <div class="p-6 border-b border-neutral-100 dark:border-neutral-800">
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">À propos</h4>
          <p class="text-sm text-neutral-600 dark:text-neutral-300 leading-relaxed">${esc(m.bio)}</p>
        </div>` : ''}

        <!-- Langues -->
        ${(m.languages?.length) ? `<div class="p-6 border-b border-neutral-100 dark:border-neutral-800">
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Langues</h4>
          <div class="flex flex-wrap gap-1.5">${langs}</div>
        </div>` : ''}

        <!-- Je cherche -->
        ${(m.lookingFor?.length) ? `<div class="p-6 border-b border-neutral-100 dark:border-neutral-800">
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Je cherche</h4>
          <div class="flex flex-wrap gap-1.5">${specs}</div>
        </div>` : ''}

        <!-- Membre depuis -->
        <div class="p-6 space-y-3">
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-3">Sur la communauté WWA</h4>
          <p class="text-xs text-neutral-500 dark:text-neutral-400">Membre depuis ${new Date(m.joinedAt).toLocaleDateString('fr-FR', { month:'long', year:'numeric' })}</p>
          <div class="flex items-center gap-2 pt-2">
            ${m.linkedinUrl ? `<a href="${esc(m.linkedinUrl)}" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded border border-neutral-200 px-3 py-1.5 text-xs font-semibold text-neutral-600 hover:border-primary-300 hover:text-primary-600 transition-all dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:text-primary-400">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>` : ''}
            <button class="inline-flex items-center gap-1.5 rounded bg-primary-500 px-3 py-1.5 text-xs font-bold text-white hover:bg-primary-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              Contacter via WWA
            </button>
          </div>
        </div>
      `
    }

    document.addEventListener('astro:page-load', () => {
      const panel    = document.getElementById('member-panel')!
      const overlay  = document.getElementById('panel-overlay')!
      const body     = document.getElementById('panel-body')!
      const closeBtn = document.getElementById('panel-close')!

      const searchInput  = document.getElementById('community-search') as HTMLInputElement
      const destFilter   = document.getElementById('filter-destination') as HTMLSelectElement
      const domainFilter = document.getElementById('filter-domain') as HTMLSelectElement
      const uniFilter    = document.getElementById('filter-university') as HTMLSelectElement
      const resetBtn     = document.getElementById('reset-filters')
      const countEl      = document.getElementById('result-count')
      const noMembers    = document.getElementById('no-members')
      const cards        = Array.from(document.querySelectorAll<HTMLElement>('.member-card'))
      const statusBtns   = document.querySelectorAll<HTMLButtonElement>('.status-filter-btn')

      let activeStatus = 'all'

      // ── Open / close panel ─────────────────────────────────────
      function openPanel(id: string) {
        const m = MEMBERS.find(x => x.id === id)
        if (!m) return
        body.innerHTML = renderMemberDetail(m)
        panel.classList.remove('hidden')
        panel.classList.add('flex')
        overlay.classList.remove('hidden')
        requestAnimationFrame(() => panel.classList.remove('translate-x-full'))
        document.body.style.overflow = 'hidden'
      }

      function closePanel() {
        panel.classList.add('translate-x-full')
        setTimeout(() => {
          panel.classList.add('hidden')
          panel.classList.remove('flex')
          overlay.classList.add('hidden')
          document.body.style.overflow = ''
        }, 300)
      }

      closeBtn.addEventListener('click', closePanel)
      overlay.addEventListener('click', closePanel)
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && !panel.classList.contains('hidden')) closePanel()
      })

      // ── Card click → open panel ────────────────────────────────
      cards.forEach(card => {
        card.addEventListener('click', () => openPanel(card.dataset.id!))
      })

      // ── Filters ────────────────────────────────────────────────
      function applyFilters() {
        const q     = searchInput?.value.trim().toLowerCase() ?? ''
        const terms = q.split(/\s+/).filter(Boolean)
        const dest  = destFilter?.value ?? 'Toutes'
        const dom   = domainFilter?.value ?? 'Tous'
        const uni   = uniFilter?.value ?? 'Toutes'

        let visible = 0
        cards.forEach(card => {
          const ds  = card.dataset
          const show =
            (activeStatus === 'all' || ds.status === activeStatus) &&
            (dest === 'Toutes' || ds.destination === dest) &&
            (dom === 'Tous' || ds.domain === dom) &&
            (uni === 'Toutes' || ds.university === uni) &&
            (terms.length === 0 || terms.every(t => (ds.search ?? '').includes(t)))
          card.classList.toggle('hidden', !show)
          if (show) visible++
        })

        if (countEl) countEl.innerHTML = `<span class="font-semibold text-neutral-600">${visible}</span> membre${visible > 1 ? 's' : ''}`
        noMembers?.classList.toggle('hidden', visible > 0)
      }

      statusBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          activeStatus = btn.dataset.statusFilter!
          statusBtns.forEach(b => {
            const on = b.dataset.statusFilter === activeStatus
            b.classList.toggle('bg-primary-500', on); b.classList.toggle('border-primary-500', on); b.classList.toggle('text-white', on)
            b.classList.toggle('bg-white', !on); b.classList.toggle('dark:bg-neutral-800', !on)
            b.classList.toggle('border-neutral-200', !on); b.classList.toggle('dark:border-neutral-700', !on)
            b.classList.toggle('text-neutral-500', !on); b.classList.toggle('dark:text-neutral-400', !on)
            b.classList.toggle('hover:text-primary-600', !on); b.classList.toggle('hover:border-primary-300', !on)
            b.classList.toggle('dark:hover:border-primary-700', !on); b.classList.toggle('dark:hover:text-primary-400', !on)
          })
          applyFilters()
        })
      })

      searchInput?.addEventListener('input', applyFilters)
      destFilter?.addEventListener('change', applyFilters)
      domainFilter?.addEventListener('change', applyFilters)
      uniFilter?.addEventListener('change', applyFilters)

      resetBtn?.addEventListener('click', () => {
        if (searchInput) searchInput.value = ''
        if (destFilter) destFilter.value = 'Toutes'
        if (domainFilter) domainFilter.value = 'Tous'
        if (uniFilter) uniFilter.value = 'Toutes'
        activeStatus = 'all'
        statusBtns.forEach(b => {
          const on = b.dataset.statusFilter === 'all'
          b.classList.toggle('bg-primary-500', on); b.classList.toggle('border-primary-500', on); b.classList.toggle('text-white', on)
          b.classList.toggle('bg-white', !on); b.classList.toggle('dark:bg-neutral-800', !on)
          b.classList.toggle('border-neutral-200', !on); b.classList.toggle('dark:border-neutral-700', !on)
          b.classList.toggle('text-neutral-500', !on); b.classList.toggle('dark:text-neutral-400', !on)
        })
        applyFilters()
      })
    })
  </script>
</DashboardLayout>
