---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import DoodleBackground from '../../components/DoodleBackground.astro'
import { backendFetch } from '../../lib/auth'

const session = Astro.locals.session!

let conversationId: number | null = null
try {
  const resp = await backendFetch('/conversations', session)
  if (resp.ok) { const c: any[] = await resp.json(); conversationId = c[0]?.id ?? null }
} catch {}
---

<DashboardLayout title="Messages" activeNav="messages">
  <div class="flex flex-col h-full overflow-hidden" id="messages-page" data-conv-id={conversationId ?? ''}>

    <!-- En-tête -->
    <div class="shrink-0 flex items-center gap-3 bg-white border-b border-neutral-100 px-5 py-4 dark:bg-neutral-900 dark:border-neutral-800">
      <div class="h-9 w-9 rounded-full bg-primary-50 flex items-center justify-center shrink-0 dark:bg-primary-950">
        <span class="text-sm font-bold text-primary-500 dark:text-primary-400">W</span>
      </div>
      <div>
        <h1 class="font-headings font-bold text-sm text-neutral-800 dark:text-neutral-100">Équipe WorldWise Admission</h1>
        <p class="text-xs text-neutral-400">Votre espace de communication avec l'équipe</p>
      </div>
    </div>

    <!-- Loading -->
    <div id="loading-state" class="flex-1 flex items-center justify-center">
      <div class="h-6 w-6 border-2 border-primary-100 border-t-primary-500 rounded-full animate-spin"></div>
    </div>

    <!-- Vide -->
    <div id="empty-state" class="hidden flex-1 flex-col items-center justify-center text-center p-8">
      <div class="h-16 w-16 rounded-full bg-neutral-50 border border-neutral-100 flex items-center justify-center mb-5 shadow-sm dark:bg-neutral-800 dark:border-neutral-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-neutral-600">Aucune conversation active</p>
      <p class="text-xs text-neutral-400 mt-1.5 max-w-xs">Une fois votre candidature soumise, l'équipe WWA démarrera une conversation avec vous ici.</p>
      <a href="/dashboard/candidature" class="mt-5 inline-flex items-center gap-1.5 rounded bg-primary-500 px-4 py-2 text-xs font-bold text-white hover:text-white hover:bg-primary-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Déposer ma candidature
      </a>
    </div>

    <!-- Zone messages -->
    <div id="messages-area" class="hidden flex-col flex-1 min-h-0">
      <div class="relative flex flex-col flex-1 min-h-0">
        <DoodleBackground />
        <div class="flex-1 overflow-y-auto px-3 py-4 sm:px-5 sm:py-5 space-y-4" id="messages-container"></div>
      </div>

      <!-- Saisie -->
      <div class="shrink-0 bg-white dark:bg-neutral-900 border-t border-neutral-100 dark:border-neutral-800 px-5 py-3">
        <!-- Chips fichiers sélectionnés -->
        <div id="file-preview" class="hidden flex-wrap gap-2 mb-2"></div>

        <div id="compose-inner" class="relative flex items-end gap-2 rounded-xl border border-neutral-200 bg-white dark:bg-neutral-900 dark:border-neutral-700 shadow-sm overflow-visible">

          <!-- Dropdown pièces jointes -->
          <div id="attach-menu" class="hidden absolute bottom-full left-0 mb-2 w-52 bg-white dark:bg-neutral-800 rounded-xl shadow-lg border border-neutral-100 dark:border-neutral-700 overflow-hidden z-20">
            <label for="file-input" class="flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 dark:text-neutral-200 hover:bg-neutral-50 dark:hover:bg-neutral-700 cursor-pointer transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
              </svg>
              Pièce jointe
            </label>
            <label for="image-input" class="flex items-center gap-3 px-4 py-2.5 text-sm text-neutral-700 dark:text-neutral-200 hover:bg-neutral-50 dark:hover:bg-neutral-700 cursor-pointer transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Image
            </label>
            <input id="file-input"  type="file" class="hidden" multiple/>
            <input id="image-input" type="file" class="hidden" accept="image/*" multiple/>
          </div>

          <!-- Bouton + -->
          <div class="shrink-0 self-end px-2 pb-2">
            <button id="attach-btn" type="button" class="h-8 w-8 rounded-lg flex items-center justify-center text-neutral-400 hover:text-primary-500 hover:bg-primary-50 dark:hover:bg-primary-950 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
            </button>
          </div>

          <textarea
            id="message-input"
            rows={1}
            placeholder="Écrire un message à l'équipe WWA…"
            class="flex-1 resize-none bg-transparent py-3 text-sm text-neutral-700 placeholder:text-neutral-400 focus:outline-none dark:text-neutral-200 dark:placeholder:text-neutral-500 max-h-32"
          ></textarea>

          <div class="shrink-0 self-end px-2 pb-2">
            <button
              id="send-btn"
              disabled
              class="h-8 w-8 rounded-lg bg-primary-500 flex items-center justify-center text-white hover:bg-primary-600 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Overlay prévisualisation plein écran ───────────────────────── -->
  <div id="preview-overlay" class="hidden fixed inset-0 z-[9999] bg-black/90" role="dialog" aria-modal="true">

    <div id="preview-loading" class="absolute inset-0 hidden items-center justify-center z-20">
      <div class="h-9 w-9 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
    </div>

    <div class="absolute top-0 inset-x-0 z-10 flex items-center gap-3 px-4 py-3 bg-gradient-to-b from-black/70 to-transparent pointer-events-none">
      <p id="preview-name" class="flex-1 text-sm font-medium text-white truncate"></p>
      <p id="preview-size-top" class="shrink-0 text-xs text-white/50"></p>
      <button id="preview-download" title="Télécharger"
        class="pointer-events-auto h-9 w-9 rounded-lg bg-white/15 hover:bg-white/25 flex items-center justify-center text-white transition-colors shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
      </button>
      <button id="preview-close" title="Fermer (Échap)"
        class="pointer-events-auto h-9 w-9 rounded-lg bg-white/15 hover:bg-white/25 flex items-center justify-center text-white transition-colors shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div id="preview-body" class="absolute inset-0 flex items-center justify-center pt-16 pb-4 px-4">

      <img id="preview-img" class="hidden max-w-full max-h-full object-contain rounded-md shadow-2xl select-none" alt=""/>

      <iframe id="preview-pdf" class="hidden rounded-md shadow-2xl bg-white" title="Aperçu PDF"
        style="width:min(92vw,900px);height:min(88vh,900px)"></iframe>

      <video id="preview-video" class="hidden max-w-full max-h-full rounded-md shadow-2xl" controls preload="metadata"></video>

      <div id="preview-audio-wrap" class="hidden flex-col items-center gap-5 p-10 rounded-2xl bg-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        <audio id="preview-audio" controls class="w-72"></audio>
      </div>

      <div id="preview-generic" class="hidden flex-col items-center gap-4 p-10 rounded-2xl bg-white/10 text-center">
        <div class="h-16 w-16 rounded-xl bg-white/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <p id="preview-generic-name" class="text-white font-semibold text-sm max-w-xs break-all"></p>
        <p id="preview-generic-size" class="text-white/50 text-xs"></p>
        <button id="preview-generic-dl"
          class="inline-flex items-center gap-2 rounded-lg bg-white/20 hover:bg-white/30 px-5 py-2.5 text-sm font-semibold text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Télécharger
        </button>
      </div>

    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', async () => {
      const page      = document.getElementById('messages-page')
      if (!page) return
      const convId    = page.dataset.convId ? parseInt(page.dataset.convId) : null
      const loadingEl = document.getElementById('loading-state')!
      const emptyEl   = document.getElementById('empty-state')!
      const areaEl    = document.getElementById('messages-area')!
      const container = document.getElementById('messages-container')!
      const input     = document.getElementById('message-input')  as HTMLTextAreaElement
      const sendBtn   = document.getElementById('send-btn')       as HTMLButtonElement
      const attachBtn = document.getElementById('attach-btn')     as HTMLButtonElement
      const attachMenu= document.getElementById('attach-menu')    as HTMLDivElement
      const filePreviewEl = document.getElementById('file-preview') as HTMLDivElement
      const fileInput  = document.getElementById('file-input')   as HTMLInputElement
      const imageInput = document.getElementById('image-input')  as HTMLInputElement
      let echoChannel: any = null
      let selectedFiles: File[] = []

      // ── Utils ─────────────────────────────────────────────────────
      function escHtml(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }
      function fmtDate(iso: string) {
        const d = new Date(iso)
        return d.toLocaleDateString('fr-FR', { day:'2-digit', month:'short' }) + ' ' + d.toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' })
      }
      function scrollToBottom() { container.scrollTop = container.scrollHeight }

      // ── Attachments helpers ───────────────────────────────────────
      async function loadAuthImages() {
        const s = JSON.parse(localStorage.getItem('wwa_session') || 'null')
        if (!s?.token) return
        document.querySelectorAll<HTMLImageElement>('[data-auth-src]:not([data-auth-loaded])').forEach(async img => {
          img.dataset.authLoaded = '1'
          try {
            const r = await fetch(img.dataset.authSrc!, { headers: { Authorization: `Bearer ${s.token}` } })
            if (r.ok) img.src = URL.createObjectURL(await r.blob())
          } catch {}
        })
      }

      async function downloadWithAuth(url: string, filename: string) {
        const s = JSON.parse(localStorage.getItem('wwa_session') || 'null')
        if (!s?.token) return
        try {
          const r = await fetch(url, { headers: { Authorization: `Bearer ${s.token}` } })
          if (!r.ok) return
          const a = document.createElement('a')
          a.href = URL.createObjectURL(await r.blob())
          a.download = filename
          a.click()
        } catch {}
      }

      // ── Overlay prévisualisation ────────────────────────────────────
      interface AttachmentRef {
        previewUrl: string; downloadUrl: string; filename: string
        mimeType: string; isImage: boolean; humanSize: string
      }
      let currentPreview: AttachmentRef | null = null
      let previewBlobUrl = ''

      const OVERLAY_PANELS = ['preview-img', 'preview-pdf', 'preview-video', 'preview-audio-wrap', 'preview-generic']

      function hidePanels() {
        OVERLAY_PANELS.forEach(id => {
          const el = document.getElementById(id)!
          el.classList.add('hidden'); el.classList.remove('flex')
        })
      }
      function showPanel(id: string) {
        const el = document.getElementById(id)!
        el.classList.remove('hidden')
        if (id === 'preview-audio-wrap' || id === 'preview-generic') el.classList.add('flex')
      }

      function openPreview(att: AttachmentRef) {
        currentPreview = att
        const overlay   = document.getElementById('preview-overlay')!
        const loadingEl = document.getElementById('preview-loading')!
        document.getElementById('preview-name')!.textContent        = att.filename
        document.getElementById('preview-size-top')!.textContent    = att.humanSize
        document.getElementById('preview-generic-name')!.textContent= att.filename
        document.getElementById('preview-generic-size')!.textContent= att.humanSize

        hidePanels()
        loadingEl.classList.remove('hidden'); loadingEl.classList.add('flex')
        overlay.classList.remove('hidden')
        document.body.style.overflow = 'hidden'

        if (previewBlobUrl) { URL.revokeObjectURL(previewBlobUrl); previewBlobUrl = '' }

        const s = JSON.parse(localStorage.getItem('wwa_session') || 'null')
        const headers: Record<string, string> = s?.token ? { Authorization: `Bearer ${s.token}` } : {}

        fetch(att.previewUrl, { headers })
          .then(async r => {
            loadingEl.classList.add('hidden'); loadingEl.classList.remove('flex')
            if (!r.ok) { showPanel('preview-generic'); return }
            const blob = await r.blob()
            previewBlobUrl = URL.createObjectURL(blob)
            const mime = (att.mimeType ?? '').toLowerCase()
            if (att.isImage) {
              ;(document.getElementById('preview-img') as HTMLImageElement).src = previewBlobUrl
              showPanel('preview-img')
            } else if (mime === 'application/pdf') {
              ;(document.getElementById('preview-pdf') as HTMLIFrameElement).src = previewBlobUrl
              showPanel('preview-pdf')
            } else if (mime.startsWith('video/')) {
              ;(document.getElementById('preview-video') as HTMLVideoElement).src = previewBlobUrl
              showPanel('preview-video')
            } else if (mime.startsWith('audio/')) {
              ;(document.getElementById('preview-audio') as HTMLAudioElement).src = previewBlobUrl
              showPanel('preview-audio-wrap')
            } else {
              showPanel('preview-generic')
            }
          })
          .catch(() => {
            loadingEl.classList.add('hidden'); loadingEl.classList.remove('flex')
            showPanel('preview-generic')
          })
      }

      function closePreview() {
        document.getElementById('preview-overlay')!.classList.add('hidden')
        document.body.style.overflow = ''
        try { (document.getElementById('preview-video') as HTMLVideoElement).pause() } catch {}
        try { (document.getElementById('preview-audio') as HTMLAudioElement).pause() } catch {}
        if (previewBlobUrl) { URL.revokeObjectURL(previewBlobUrl); previewBlobUrl = '' }
      }

      document.getElementById('preview-close')?.addEventListener('click', closePreview)
      document.getElementById('preview-download')?.addEventListener('click', () => {
        if (currentPreview) downloadWithAuth(currentPreview.downloadUrl, currentPreview.filename)
      })
      document.getElementById('preview-generic-dl')?.addEventListener('click', () => {
        if (currentPreview) downloadWithAuth(currentPreview.downloadUrl, currentPreview.filename)
      })
      document.getElementById('preview-body')?.addEventListener('click', e => {
        if (e.target === e.currentTarget) closePreview()
      })
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !document.getElementById('preview-overlay')!.classList.contains('hidden')) closePreview()
      })

      // Clic sur pièce jointe → ouvrir prévisualisation
      container.addEventListener('click', e => {
        const el = (e.target as Element).closest('[data-preview-url]') as HTMLElement | null
        if (!el) return
        openPreview({
          previewUrl:  el.dataset.previewUrl!,
          downloadUrl: el.dataset.previewDownload!,
          filename:    el.dataset.previewFilename!,
          mimeType:    el.dataset.previewMime ?? '',
          isImage:     el.dataset.previewIsImage === 'true',
          humanSize:   el.dataset.previewSize ?? '',
        })
      })

      function renderAttachments(attachments: any[], isCandidate: boolean): string {
        if (!attachments?.length) return ''
        return attachments.map((a: any) => {
          const pAttrs = `data-preview-url="${a.previewUrl}" data-preview-download="${a.downloadUrl}" data-preview-filename="${escHtml(a.originalName)}" data-preview-mime="${escHtml(a.mimeType ?? '')}" data-preview-is-image="${a.isImage}" data-preview-size="${escHtml(a.humanSize ?? '')}"`
          if (a.isImage) {
            return `<div class="mt-1.5 rounded-xl overflow-hidden cursor-pointer group relative max-w-[78vw] sm:max-w-xs" ${pAttrs}>
                      <img data-auth-src="${a.previewUrl}"
                           src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
                           class="w-full max-h-60 object-cover bg-neutral-100 dark:bg-neutral-800 group-hover:opacity-75 transition-opacity"
                           alt="${escHtml(a.originalName)}"/>
                      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                        <div class="h-10 w-10 rounded-full bg-black/50 flex items-center justify-center">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                          </svg>
                        </div>
                      </div>
                      <div class="flex items-center justify-between gap-2 px-2.5 py-1.5 bg-black/20 dark:bg-black/40 text-[10px] text-white">
                        <span class="truncate">${escHtml(a.originalName)}</span>
                        <span class="shrink-0 opacity-70">${a.humanSize}</span>
                      </div>
                    </div>`
          }
          const cardStyle = isCandidate
            ? 'border-primary-200 bg-primary-50 text-primary-700 dark:border-primary-800/60 dark:bg-primary-950 dark:text-primary-200'
            : 'border-neutral-200 bg-white dark:bg-neutral-800 dark:border-neutral-700 text-neutral-700 dark:text-neutral-200'
          return `<div class="flex items-center gap-3 mt-1.5 px-3 py-2.5 rounded-xl border ${cardStyle} cursor-pointer hover:opacity-80 transition-opacity max-w-[78vw] sm:max-w-xs" ${pAttrs}>
                    <div class="h-9 w-9 rounded-lg ${isCandidate ? 'bg-primary-100 dark:bg-primary-900' : 'bg-primary-50 dark:bg-primary-950'} flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-500 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-xs font-medium truncate">${escHtml(a.originalName)}</p>
                      <p class="text-[10px] opacity-60 mt-0.5">${a.humanSize}</p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                  </div>`
        }).join('')
      }

      function appendMessage(msg: any, animate: boolean) {
        const isCandidate = msg.senderRole === 'candidate'
        const hasContent  = msg.content?.trim().length > 0
        const attachments = msg.attachments || []
        const bubbleBg    = isCandidate
          ? 'bg-primary-500 text-white'
          : 'bg-white border border-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-200'

        const wrapper = document.createElement('div')
        wrapper.className = `flex items-end gap-2.5 ${isCandidate ? 'justify-end' : 'justify-start'}${animate ? ' animate-fade-in' : ''}`
        wrapper.dataset.msgId = msg.id
        wrapper.innerHTML = `
          ${!isCandidate ? '<div class="h-7 w-7 rounded-full bg-primary-500 flex items-center justify-center shrink-0 mb-0.5"><span class="text-[10px] font-bold text-white">W</span></div>' : ''}
          <div class="max-w-[85%] sm:max-w-[70%]">
            ${hasContent ? `<div class="rounded-xl px-3.5 py-2.5 ${bubbleBg}"><p class="text-sm leading-relaxed whitespace-pre-wrap">${escHtml(msg.content)}</p></div>` : ''}
            ${renderAttachments(attachments, isCandidate)}
            <div class="flex items-center gap-1.5 mt-1 ${isCandidate ? 'justify-end' : ''}">
              <p class="text-[10px] text-neutral-400">${fmtDate(msg.createdAt)}</p>
              ${isCandidate ? `<span class="text-[10px] ${msg.read ? 'text-primary-400' : 'text-neutral-300'}" ${!msg.read ? 'data-msg-unread' : ''}>${msg.read ? '✓✓' : '✓'}</span>` : ''}
            </div>
          </div>`
        container.appendChild(wrapper)
        scrollToBottom()
        loadAuthImages()
      }

      // ── File preview chips ────────────────────────────────────────
      function addFiles(list: FileList) {
        selectedFiles = [...selectedFiles, ...Array.from(list)].slice(0, 5)
        renderFilePreview(); updateSendState()
        attachMenu?.classList.add('hidden')
      }
      function removeFile(idx: number) { selectedFiles.splice(idx, 1); renderFilePreview(); updateSendState() }
      function renderFilePreview() {
        if (!selectedFiles.length) { filePreviewEl.classList.add('hidden'); filePreviewEl.innerHTML = ''; return }
        filePreviewEl.classList.remove('hidden'); filePreviewEl.classList.add('flex')
        filePreviewEl.innerHTML = selectedFiles.map((f, i) => {
          const thumb = f.type.startsWith('image/')
            ? `<img src="${URL.createObjectURL(f)}" class="h-8 w-8 rounded object-cover shrink-0" alt=""/>`
            : `<div class="h-8 w-8 rounded bg-primary-50 dark:bg-primary-950 flex items-center justify-center shrink-0"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>`
          return `<div class="flex items-center gap-1.5 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 px-2 py-1 text-xs text-neutral-600 dark:text-neutral-300">${thumb}<span class="max-w-[100px] truncate">${escHtml(f.name)}</span><button data-remove="${i}" class="ml-0.5 text-neutral-400 hover:text-primary-500 dark:hover:text-primary-400 transition-colors font-medium">×</button></div>`
        }).join('')
      }
      filePreviewEl?.addEventListener('click', e => {
        const btn = (e.target as Element).closest('[data-remove]') as HTMLElement | null
        if (btn) removeFile(parseInt(btn.dataset.remove!))
      })
      fileInput?.addEventListener('change',  () => fileInput.files  && addFiles(fileInput.files))
      imageInput?.addEventListener('change', () => imageInput.files && addFiles(imageInput.files))

      function updateSendState() { sendBtn.disabled = input.value.trim() === '' && selectedFiles.length === 0 }

      // ── Chargement initial ────────────────────────────────────────
      if (!convId) {
        loadingEl.classList.add('hidden')
        emptyEl.classList.remove('hidden'); emptyEl.classList.add('flex')
        return
      }

      try {
        const resp = await fetch(`/api/conversations/${convId}/messages`)
        loadingEl.classList.add('hidden')
        if (!resp.ok) { emptyEl.classList.remove('hidden'); emptyEl.classList.add('flex'); return }
        const messages: any[] = await resp.json()
        areaEl.classList.remove('hidden'); areaEl.classList.add('flex')
        if (messages.length === 0) {
          container.innerHTML = '<p class="text-center text-xs text-neutral-400 py-8">Aucun message — l\'équipe WWA vous répondra ici</p>'
        } else {
          messages.forEach(m => appendMessage(m, false))
        }
        scrollToBottom()
      } catch {
        loadingEl.classList.add('hidden'); emptyEl.classList.remove('hidden'); emptyEl.classList.add('flex'); return
      }

      // ── Compose ───────────────────────────────────────────────────
      input.addEventListener('input', () => {
        updateSendState()
        input.style.height = 'auto'
        input.style.height = Math.min(input.scrollHeight, 128) + 'px'
      })
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendBtn.click() }
      })
      attachBtn?.addEventListener('click', e => { e.stopPropagation(); attachMenu?.classList.toggle('hidden') })
      document.addEventListener('click', () => attachMenu?.classList.add('hidden'))

      sendBtn.addEventListener('click', async () => {
        const text = input.value.trim()
        if (!text && selectedFiles.length === 0) return
        const s = JSON.parse(localStorage.getItem('wwa_session') || 'null')
        if (!s?.token) return

        const snapshot = [...selectedFiles]; const snapshotText = text
        input.value = ''; input.style.height = 'auto'
        selectedFiles = []; renderFilePreview(); updateSendState()
        sendBtn.disabled = true
        const icon = sendBtn.innerHTML
        sendBtn.innerHTML = `<div class="h-3.5 w-3.5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>`

        try {
          let body: FormData | string
          const headers: Record<string, string> = { Authorization: `Bearer ${s.token}` }
          if (snapshot.length > 0) {
            const fd = new FormData()
            if (snapshotText) fd.append('content', snapshotText)
            snapshot.forEach(f => fd.append('files[]', f))
            body = fd
          } else {
            body = JSON.stringify({ content: snapshotText })
            headers['Content-Type'] = 'application/json'
          }
          const resp = await fetch(`/api/conversations/${convId}/messages`, { method: 'POST', headers, body })
          if (resp.ok) {
            const msg = await resp.json()
            container.querySelector('p.text-neutral-400')?.remove()
            appendMessage(msg, true)
          } else {
            input.value = snapshotText; selectedFiles = snapshot; renderFilePreview()
          }
        } catch {
          input.value = snapshotText; selectedFiles = snapshot; renderFilePreview()
        } finally { sendBtn.innerHTML = icon; updateSendState(); input.focus() }
      })

      // ── Echo ──────────────────────────────────────────────────────
      function subscribeEcho() {
        const echo = (window as any).__echoInstance
        if (!echo || !convId || echoChannel) return
        echoChannel = echo.private(`conversation.${convId}`)
          .listen('.message.sent', (data: any) => {
            if (data.senderRole === 'admin') {
              appendMessage(data, true)
              fetch(`/api/conversations/${convId}/messages`)
              document.dispatchEvent(new CustomEvent('wwa:new-notification'))
            }
          })
          .listen('.message.read', () => {
            document.querySelectorAll('[data-msg-unread]').forEach(el => { el.textContent = '✓✓'; el.removeAttribute('data-msg-unread') })
          })
      }
      document.addEventListener('wwa:echo-ready', subscribeEcho)
      subscribeEcho()

      // ── Polling fallback (si Echo/Reverb non connecté) ────────────────
      let lastPollAt   = new Date().toISOString()
      let pollInterval: ReturnType<typeof setInterval> | null = null

      if (convId) {
        pollInterval = setInterval(async () => {
          const echo = (window as any).__echoInstance
          if (echo?.connector?.pusher?.connection?.state === 'connected') return
          try {
            const resp = await fetch(`/api/conversations/${convId}/poll?since=${encodeURIComponent(lastPollAt)}`)
            if (!resp.ok) return
            const { newMessages } = await resp.json()
            newMessages?.forEach((msg: any) => {
              if (msg.senderRole === 'admin' && !document.querySelector(`[data-msg-id="${msg.id}"]`)) {
                container.querySelector('p.text-neutral-400')?.remove()
                appendMessage(msg, true)
                document.dispatchEvent(new CustomEvent('wwa:new-notification'))
              }
            })
            if (newMessages?.length) lastPollAt = new Date().toISOString()
          } catch {}
        }, 8000)
      }

      document.addEventListener('astro:before-swap', () => {
        echoChannel?.stopListening('.message.sent')
        echoChannel?.stopListening('.message.read')
        if (pollInterval) { clearInterval(pollInterval); pollInterval = null }
      })
    })
  </script>
</DashboardLayout>
