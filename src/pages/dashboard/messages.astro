---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import { MOCK_MESSAGES, MOCK_CONVERSATIONS, formatDateTime } from '../../lib/mock-data'



// En prod: filtrer par session.sub (email candidat)
// Pour la démo, on prend la première conversation (jb.ondo)
const candidateConv = MOCK_CONVERSATIONS[0]!
const messages = MOCK_MESSAGES[candidateConv.id] ?? []
---

<DashboardLayout title="Messages" activeNav="messages">
  <div class="flex flex-col h-[calc(100vh-4rem)] lg:h-screen">

    <!-- En-tête -->
    <div class="px-6 py-4 bg-white border-b border-neutral-100 shrink-0">
      <h1 class="text-lg font-headings font-semibold text-neutral-700">Messages</h1>
      <p class="text-xs text-neutral-400 mt-0.5">Votre conversation avec l'équipe WorldWise Admission</p>
    </div>

    {messages.length === 0 ? (
      <div class="flex-1 flex items-center justify-center text-neutral-400">
        <div class="text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          <p class="text-sm">Aucun message pour l'instant</p>
          <p class="text-xs mt-1">L'équipe WWA vous contactera ici</p>
        </div>
      </div>
    ) : (
      <!-- Messages -->
      <div class="flex-1 overflow-y-auto px-6 py-4 space-y-3" id="messages-container">
        {messages.map(msg => (
          <div class={`flex ${msg.senderRole === 'candidate' ? 'justify-end' : 'justify-start'}`}>
            {msg.senderRole === 'admin' && (
              <div class="h-8 w-8 rounded-full bg-primary-100 flex items-center justify-center shrink-0 mr-2 mt-auto">
                <span class="text-xs font-bold text-primary-600">W</span>
              </div>
            )}
            <div class={`max-w-[70%] rounded-xl px-4 py-2.5 ${
              msg.senderRole === 'candidate'
                ? 'bg-amber-500 text-white'
                : 'bg-white border border-neutral-100 text-neutral-700'
            }`}>
              {msg.senderRole === 'admin' && (
                <p class="text-xs font-semibold text-primary-600 mb-1">{msg.senderName}</p>
              )}
              <p class="text-sm leading-relaxed">{msg.content}</p>
              <p class={`text-xs mt-1.5 ${msg.senderRole === 'candidate' ? 'text-amber-100' : 'text-neutral-400'}`}>
                {formatDateTime(msg.createdAt)}
              </p>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Zone de saisie -->
    <div class="border-t border-neutral-100 bg-white p-4 shrink-0">
      <div class="max-w-3xl mx-auto flex gap-2">
        <input
          id="message-input"
          type="text"
          placeholder="Écrire un message à l'équipe WWA…"
          class="flex-1 rounded-lg border border-neutral-200 px-3.5 py-2.5 text-sm text-neutral-700 placeholder:text-neutral-400 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 transition"
        />
        <button
          id="send-btn"
          class="rounded-lg bg-amber-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-amber-600 transition"
        >
          Envoyer
        </button>
      </div>
    </div>
  </div>

  <script>
    const sendBtn = document.getElementById('send-btn')
    const input = document.getElementById('message-input') as HTMLInputElement
    const container = document.getElementById('messages-container')

    if (container) container.scrollTop = container.scrollHeight

    sendBtn?.addEventListener('click', () => {
      if (!input?.value.trim()) return
      // TODO: appeler l'API backend
      alert('Messagerie disponible après intégration du backend Laravel.')
    })

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        sendBtn?.click()
      }
    })
  </script>
</DashboardLayout>
