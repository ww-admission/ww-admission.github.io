---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import { STATUS_LABELS, STATUS_COLORS, formatDate, type CandidatureStatus } from '../../lib/mock-data'



// En prod: récupérer depuis le backend via session.sub (email)
// Pour le moment, candidature mockée si le candidat a soumis via localStorage (formulaire public)
// eslint-disable-next-line prefer-const
let MOCK_STATUS: CandidatureStatus = 'reviewing'
const MOCK_DESTINATION = 'Chine'
const MOCK_PROGRAMME = 'Médecine générale'
const MOCK_SUBMITTED = '2026-05-20'

const TIMELINE = [
  { label: 'Candidature soumise', done: true, date: MOCK_SUBMITTED },
  { label: 'Examen du dossier', done: MOCK_STATUS !== 'pending', date: MOCK_STATUS !== 'pending' ? '2026-05-22' : null },
  { label: 'Décision de l\'université', done: MOCK_STATUS === 'accepted' || MOCK_STATUS === 'rejected', date: null },
  { label: 'Démarches de visa', done: false, date: null },
  { label: 'Départ étudiant', done: false, date: null },
]
---

<DashboardLayout title="Aperçu" activeNav="overview">
  <div class="p-6 max-w-4xl mx-auto space-y-6">

    <div>
      <h1 class="text-2xl font-headings font-semibold text-neutral-700">Mon espace</h1>
      <p class="text-sm text-neutral-400 mt-1">Bonjour, {session.name} 👋</p>
    </div>

    <!-- Statut candidature -->
    <div class="bg-white rounded-xl border border-neutral-100 p-6">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-xs font-medium text-neutral-400 uppercase tracking-wide mb-1">Votre candidature</p>
          <h2 class="text-lg font-semibold text-neutral-700">{MOCK_DESTINATION} — {MOCK_PROGRAMME}</h2>
          <p class="text-sm text-neutral-400 mt-1">Soumise le {formatDate(MOCK_SUBMITTED)}</p>
        </div>
        <div>
          <span class={`inline-block rounded-full px-3.5 py-1.5 text-sm font-semibold ${STATUS_COLORS[MOCK_STATUS]}`}>
            {STATUS_LABELS[MOCK_STATUS]}
          </span>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Timeline de suivi -->
      <div class="bg-white rounded-xl border border-neutral-100 p-5">
        <h2 class="text-sm font-semibold text-neutral-700 mb-5">Suivi de votre dossier</h2>
        <ol class="relative border-l border-neutral-100 space-y-6 ml-3">
          {TIMELINE.map((step, i) => (
            <li class="ml-6">
              <span class={`absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full ring-4 ring-white text-xs font-bold ${
                step.done
                  ? 'bg-green-500 text-white'
                  : i === TIMELINE.findIndex(s => !s.done)
                    ? 'bg-amber-400 text-white animate-pulse'
                    : 'bg-neutral-100 text-neutral-400'
              }`}>
                {step.done ? '✓' : i + 1}
              </span>
              <p class={`text-sm font-medium ${step.done ? 'text-neutral-700' : 'text-neutral-400'}`}>{step.label}</p>
              {step.date && <p class="text-xs text-neutral-400 mt-0.5">{formatDate(step.date)}</p>}
            </li>
          ))}
        </ol>
      </div>

      <!-- Actions rapides -->
      <div class="space-y-4">
        <div class="bg-white rounded-xl border border-neutral-100 p-5">
          <h2 class="text-sm font-semibold text-neutral-700 mb-3">Actions</h2>
          <div class="space-y-2">
            <a href="/dashboard/candidature" class="flex items-center gap-2.5 rounded-lg p-2.5 text-sm text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Voir ma candidature
            </a>
            <a href="/dashboard/messages" class="flex items-center gap-2.5 rounded-lg p-2.5 text-sm text-neutral-600 hover:bg-neutral-50 hover:text-neutral-900 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Mes messages
            </a>
          </div>
        </div>

        <div class="bg-amber-50 rounded-xl border border-amber-100 p-5">
          <h3 class="text-sm font-semibold text-amber-800 mb-2">Votre dossier est en cours d'examen</h3>
          <p class="text-xs text-amber-700 leading-relaxed">
            Notre équipe analyse votre dossier. Vous serez notifié par email et via votre espace lorsqu'une décision sera prise.
          </p>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
