---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import DiscussionOffcanvas from '../../components/blocks/DiscussionOffcanvas.astro'
import { STATUS_LABELS, STATUS_COLORS, type CandidatureStatus } from '../../lib/mock-data'
import { backendFetch } from '../../lib/auth'

const session = Astro.locals.session!

let candidature: any = null
let conversationId: number | null = null

try {
  const resp = await backendFetch('/candidatures', session)
  if (resp.ok) { const d = await resp.json(); candidature = (d.data ?? d)[0] ?? null }
} catch {}

if (candidature) {
  try {
    const resp = await backendFetch('/conversations', session)
    if (resp.ok) { const c: any[] = await resp.json(); conversationId = c[0]?.id ?? null }
  } catch {}
}

function fmtDate(iso: string) {
  if (!iso) return '—'
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })
}

const statusOrder  = ['pending', 'reviewing', 'on_hold', 'accepted', 'rejected']
const currentStep  = candidature ? statusOrder.indexOf(candidature.status) : -1

type TStep = { label: string; date: string | null; done: boolean }
const timelineSteps: TStep[] = [
  { label: 'Candidature soumise',       date: candidature?.submittedAt ?? null,                        done: currentStep >= 0 },
  { label: 'Examen du dossier',         date: currentStep >= 1 ? (candidature?.updatedAt ?? null) : null, done: currentStep >= 1 },
  { label: 'Compléments éventuels',     date: null,                                                    done: currentStep >= 2 },
  { label: "Décision de l'université",  date: null,                                                    done: currentStep >= 3 },
  { label: 'Démarches visa & départ',   date: null,                                                    done: false },
]
---

<DashboardLayout title="Aperçu" activeNav="overview">

  {candidature && conversationId && (
    <DiscussionOffcanvas
      candidatureId={candidature.id}
      conversationId={conversationId}
      role="candidate"
    />
  )}

  <div class="p-6 lg:p-8 max-w-4xl mx-auto space-y-8">

    <!-- En-tête -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Mon espace</p>
      <h1 class="font-headings text-2xl font-bold text-neutral-800 dark:text-neutral-100">Bonjour, {session.name.split(' ')[0]} 👋</h1>
    </div>

    {!candidature ? (
      <!-- CTA déposer candidature -->
      <div class="bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
        <div class="h-1.5 bg-primary-500"></div>
        <div class="p-8 flex flex-col items-center text-center">
          <div class="h-16 w-16 rounded-full bg-primary-50 flex items-center justify-center mb-5 dark:bg-primary-950">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="font-headings text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">Déposez votre dossier</h2>
          <p class="text-sm text-neutral-400 mb-6 max-w-sm">
            Vous n'avez pas encore soumis de candidature. Commencez votre parcours avec WorldWise Admission.
          </p>
          <a
            href="/dashboard/candidature"
            class="inline-flex items-center gap-2 rounded bg-primary-500 px-5 py-2.5 text-sm font-bold text-white hover:text-white hover:bg-primary-600 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Déposer ma candidature
          </a>
        </div>
      </div>
    ) : (
      <>
        <!-- Carte statut candidature -->
        <div class="bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
          <div class="h-1.5 bg-primary-500"></div>
          <div class="p-5 flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1">
              <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Votre candidature</p>
              <h2 class="font-headings text-lg font-bold text-neutral-800 dark:text-neutral-100">
                {candidature.destination} — {candidature.programme}
              </h2>
              <p class="text-xs text-neutral-400 mt-1">Soumise le {fmtDate(candidature.submittedAt)}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class={`inline-flex items-center rounded-full px-3.5 py-1.5 text-sm font-semibold ${STATUS_COLORS[candidature.status as CandidatureStatus] ?? 'bg-neutral-100 text-neutral-600'}`}>
                {STATUS_LABELS[candidature.status as CandidatureStatus] ?? candidature.status}
              </span>
              {conversationId && (
                <button
                  data-open-discussion
                  class="inline-flex items-center gap-1.5 rounded border border-neutral-200 px-3 py-1.5 text-xs font-semibold text-neutral-500 hover:border-primary-300 hover:text-primary-600 hover:bg-primary-50 transition-all dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-primary-700 dark:hover:bg-primary-950 dark:hover:text-primary-400"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  Discussion
                </button>
              )}
            </div>
          </div>
        </div>

        <!-- Grille : Timeline + Accès rapide -->
        <div class="grid lg:grid-cols-5 gap-6">

          <!-- Timeline de suivi (col-span-3) -->
          <div class="lg:col-span-3 bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
            <div class="px-5 py-4 border-b border-neutral-50 flex items-center gap-2 dark:border-neutral-800">
              <div class="h-6 w-1 rounded-full bg-primary-500"></div>
              <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Suivi de votre dossier</h2>
            </div>
            <div class="p-5">
              <ol class="relative space-y-4">
                {timelineSteps.map((step, i) => (
                  <li class="flex items-start gap-4">
                    <!-- Indicateur -->
                    <div class="flex flex-col items-center shrink-0">
                      <div class={`h-8 w-8 rounded-full border-2 flex items-center justify-center ${
                        step.done
                          ? 'border-primary-500 bg-primary-500'
                          : i === currentStep + 1
                          ? 'border-gold-400 bg-gold-50 dark:border-gold-500 dark:bg-gold-900/40'
                          : 'border-neutral-200 bg-white dark:border-neutral-700 dark:bg-neutral-900'
                      }`}>
                        {step.done ? (
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                          </svg>
                        ) : i === currentStep + 1 ? (
                          <div class="h-2 w-2 rounded-full bg-gold-500 animate-pulse"></div>
                        ) : (
                          <div class="h-2 w-2 rounded-full bg-neutral-200 dark:bg-neutral-700"></div>
                        )}
                      </div>
                      {i < timelineSteps.length - 1 && (
                        <div class={`w-px flex-1 mt-1 h-4 ${step.done ? 'bg-primary-200 dark:bg-primary-800' : 'bg-neutral-100 dark:bg-neutral-800'}`}></div>
                      )}
                    </div>
                    <!-- Label -->
                    <div class="pt-1.5">
                      <p class={`text-sm font-semibold ${step.done ? 'text-neutral-700 dark:text-neutral-200' : i === currentStep + 1 ? 'text-gold-700 dark:text-gold-400' : 'text-neutral-300 dark:text-neutral-600'}`}>
                        {step.label}
                      </p>
                      {step.date && <p class="text-xs text-neutral-400 mt-0.5">{fmtDate(step.date)}</p>}
                      {i === currentStep + 1 && <p class="text-xs text-gold-600 dark:text-gold-400 mt-0.5">Étape en cours</p>}
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </div>

          <!-- Actions rapides (col-span-2) -->
          <div class="lg:col-span-2 space-y-4">

            <div class="bg-white border border-neutral-100 rounded overflow-hidden dark:bg-neutral-900 dark:border-neutral-800">
              <div class="px-5 py-4 border-b border-neutral-50 dark:border-neutral-800">
                <h2 class="font-headings font-semibold text-sm text-neutral-700 dark:text-neutral-200">Accès rapide</h2>
              </div>
              <nav class="p-3 space-y-0.5">
                {[
                  { href: '/dashboard/candidature', label: 'Mon dossier', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
                  { href: '/dashboard/messages',    label: 'Messagerie',  icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
                ].map(link => (
                  <a href={link.href} class="flex items-center gap-3 rounded px-3 py-2.5 text-sm text-neutral-500 hover:bg-neutral-50 hover:text-neutral-800 transition-colors group dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400 group-hover:text-primary-400 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                      <path stroke-linecap="round" stroke-linejoin="round" d={link.icon}/>
                    </svg>
                    {link.label}
                  </a>
                ))}
              </nav>
            </div>

            <!-- Notification contextuelle selon statut -->
            {candidature.status === 'accepted' && (
              <div class="rounded border border-primary-100 bg-primary-50 p-4 dark:bg-primary-950 dark:border-primary-900">
                <p class="text-sm font-bold text-primary-700 dark:text-primary-300 mb-1">Candidature acceptée</p>
                <p class="text-xs text-primary-600 leading-relaxed">Votre candidature a été acceptée. L'équipe WWA vous contactera prochainement pour les prochaines étapes.</p>
              </div>
            )}
            {candidature.status === 'reviewing' && (
              <div class="rounded border border-primary-100 bg-primary-50 p-4 dark:bg-primary-950 dark:border-primary-900">
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 h-2 w-2 rounded-full bg-primary-500 shrink-0 animate-pulse"></span>
                  <div>
                    <p class="text-sm font-semibold text-primary-700 dark:text-primary-300 mb-1">Dossier en cours d'examen</p>
                    <p class="text-xs text-primary-500 dark:text-primary-400 leading-relaxed">L'équipe WWA analyse votre candidature. Nous vous contacterons si des compléments sont nécessaires.</p>
                  </div>
                </div>
              </div>
            )}
            {candidature.status === 'rejected' && (
              <div class="rounded border border-neutral-200 bg-neutral-50 p-4 dark:bg-neutral-800 dark:border-neutral-700">
                <p class="text-sm font-semibold text-neutral-600 dark:text-neutral-300 mb-1">Candidature non retenue</p>
                <p class="text-xs text-neutral-400 leading-relaxed mb-2">N'hésitez pas à contacter l'équipe WWA pour en savoir plus sur les prochaines étapes.</p>
                <a href="/dashboard/messages" class="text-xs font-semibold text-primary-500 hover:text-primary-600 transition-colors">Contacter l'équipe →</a>
              </div>
            )}
          </div>
        </div>
      </>
    )}
  </div>
</DashboardLayout>
